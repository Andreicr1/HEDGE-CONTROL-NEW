{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/resources/*",
      "/css/*",
      "/i18n/*",
      "/service/*",
      "/model/*",
      "/controller/*",
      "/view/*",
      "/util/*",
      "/test/*",
      "/localService/*",
      "*.js",
      "*.css",
      "*.json",
      "*.xml",
      "*.html",
      "*.properties"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".properties": "text/plain"
  }
}
