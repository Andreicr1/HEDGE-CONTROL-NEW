{
    "_version": "2.0.0",
    "sap.app": {
        "id": "hedgecontrol",
        "type": "application",
        "i18n": {
            "bundleUrl": "i18n/i18n.properties",
            "supportedLocales": ["pt-BR", ""],
            "fallbackLocale": ""
        },
        "applicationVersion": {
            "version": "2.0.0"
        },
        "title": "Alcast Hedge Platform",
        "description": "Hedge Control",
        "dataSources": {},
        "sourceTemplate": {
            "id": "@sap/ux-app-migrator:freestyle",
            "version": "1.20.3",
            "toolsId": "1bf0db9e-4261-4b73-802b-23239d6c0f06"
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        },
        "supportedThemes": [
            "sap_horizon"
        ]
    },
    "sap.ui5": {
        "flexEnabled": false,
        "rootView": {
            "viewName": "hedgecontrol.view.App",
            "type": "XML",
            "id": "app"
        },
        "dependencies": {
            "minUI5Version": "1.136.0",
            "libs": {
                "sap.m": {},
                "sap.f": {},
                "sap.tnt": {},
                "sap.ui.core": {},
                "sap.ui.layout": {},
                "sap.ui.table": {},
                "sap.uxap": {},
                "sap.viz": { "lazy": true }
            }
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "hedgecontrol.i18n.i18n",
                    "supportedLocales": ["pt_BR", ""],
                    "fallbackLocale": ""
                }
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.f.routing.Router",
                "type": "View",
                "viewType": "XML",
                "path": "hedgecontrol.view",
                "controlId": "fcl",
                "controlAggregation": "beginColumnPages"
            },
            "routes": [
                {
                    "pattern": "",
                    "name": "home",
                    "target": "home"
                },
                {
                    "pattern": "exposures",
                    "name": "exposures",
                    "target": "exposuresList"
                },
                {
                    "pattern": "exposures/{exposureId}",
                    "name": "exposureDetail",
                    "target": [
                        "exposuresList",
                        "exposureDetail"
                    ]
                },
                {
                    "pattern": "orders",
                    "name": "orders",
                    "target": "ordersList"
                },
                {
                    "pattern": "orders/create/{type}",
                    "name": "orderCreate",
                    "target": [
                        "ordersList",
                        "orderCreate"
                    ]
                },
                {
                    "pattern": "orders/{orderId}",
                    "name": "orderDetail",
                    "target": [
                        "ordersList",
                        "orderDetail"
                    ]
                },
                {
                    "pattern": "rfq",
                    "name": "rfq",
                    "target": "rfqList"
                },
                {
                    "pattern": "rfq/create:?query:",
                    "name": "rfqCreate",
                    "target": [
                        "rfqList",
                        "rfqCreate"
                    ]
                },
                {
                    "pattern": "rfq/{rfqId}",
                    "name": "rfqDetail",
                    "target": [
                        "rfqList",
                        "rfqDetail"
                    ]
                },
                {
                    "pattern": "rfq/{rfqId}/doc",
                    "name": "rfqDocument",
                    "target": [
                        "rfqList",
                        "rfqDetail",
                        "rfqDocument"
                    ]
                },
                {
                    "pattern": "contracts",
                    "name": "contracts",
                    "target": "contractsList"
                },
                {
                    "pattern": "contracts/create",
                    "name": "contractCreate",
                    "target": [
                        "contractsList",
                        "contractCreate"
                    ]
                },
                {
                    "pattern": "contracts/{contractId}",
                    "name": "contractDetail",
                    "target": [
                        "contractsList",
                        "contractDetail"
                    ]
                },
                {
                    "pattern": "linkages",
                    "name": "linkages",
                    "target": "linkagesList"
                },
                {
                    "pattern": "linkages/{linkageId}",
                    "name": "linkageDetail",
                    "target": [
                        "linkagesList",
                        "linkageDetail"
                    ]
                },
                {
                    "pattern": "cashflow",
                    "name": "cashflow",
                    "target": "cashflow"
                },
                {
                    "pattern": "pnl",
                    "name": "pnl",
                    "target": "pnl"
                },
                {
                    "pattern": "scenario",
                    "name": "scenario",
                    "target": "scenario"
                },
                {
                    "pattern": "mtm",
                    "name": "mtm",
                    "target": "mtm"
                },
                {
                    "pattern": "market-data",
                    "name": "marketData",
                    "target": "marketData"
                },
                {
                    "pattern": "deals",
                    "name": "deals",
                    "target": "ordersList"
                },
                {
                    "pattern": "deals/create",
                    "name": "dealCreate",
                    "target": [
                        "ordersList",
                        "dealCreate"
                    ]
                },
                {
                    "pattern": "deals/{dealId}",
                    "name": "dealDetail",
                    "target": [
                        "ordersList",
                        "dealDetail"
                    ]
                },
                {
                    "pattern": "counterparties",
                    "name": "counterparties",
                    "target": "counterpartiesList"
                },
                {
                    "pattern": "counterparties/create",
                    "name": "counterpartyCreate",
                    "target": [
                        "counterpartiesList",
                        "counterpartyCreate"
                    ]
                },
                {
                    "pattern": "counterparties/{counterpartyId}",
                    "name": "counterpartyDetail",
                    "target": [
                        "counterpartiesList",
                        "counterpartyDetail"
                    ]
                },
                {
                    "pattern": "audit-trail",
                    "name": "auditTrail",
                    "target": "auditTrail"
                },
                {
                    "pattern": "finance-pipeline",
                    "name": "financePipeline",
                    "target": "financePipeline"
                },
                {
                    "pattern": ":catchAll:",
                    "name": "notFound",
                    "target": "notFound"
                }
            ],
            "targets": {
                "home": {
                    "name": "Home",
                    "controlAggregation": "beginColumnPages"
                },
                "exposuresList": {
                    "name": "ExposuresList",
                    "controlAggregation": "beginColumnPages"
                },
                "exposureDetail": {
                    "name": "ExposureDetail",
                    "controlAggregation": "midColumnPages"
                },
                "ordersList": {
                    "name": "OrdersList",
                    "controlAggregation": "beginColumnPages"
                },
                "orderCreate": {
                    "name": "OrderCreate",
                    "controlAggregation": "midColumnPages"
                },
                "orderDetail": {
                    "name": "OrderDetail",
                    "controlAggregation": "midColumnPages"
                },
                "rfqList": {
                    "name": "RfqList",
                    "controlAggregation": "beginColumnPages"
                },
                "rfqCreate": {
                    "name": "RfqCreate",
                    "controlAggregation": "midColumnPages"
                },
                "rfqDetail": {
                    "name": "RfqDetail",
                    "controlAggregation": "midColumnPages"
                },
                "rfqDocument": {
                    "name": "RfqDocument",
                    "controlAggregation": "endColumnPages"
                },
                "contractsList": {
                    "name": "ContractsList",
                    "controlAggregation": "beginColumnPages"
                },
                "contractCreate": {
                    "name": "ContractCreate",
                    "controlAggregation": "midColumnPages"
                },
                "contractDetail": {
                    "name": "ContractDetail",
                    "controlAggregation": "midColumnPages"
                },
                "linkagesList": {
                    "name": "LinkagesList",
                    "controlAggregation": "beginColumnPages"
                },
                "linkageDetail": {
                    "name": "LinkageDetail",
                    "controlAggregation": "midColumnPages"
                },
                "cashflow": {
                    "name": "Cashflow",
                    "controlAggregation": "beginColumnPages"
                },
                "pnl": {
                    "name": "Pnl",
                    "controlAggregation": "beginColumnPages"
                },
                "scenario": {
                    "name": "Scenario",
                    "controlAggregation": "beginColumnPages"
                },
                "mtm": {
                    "name": "Mtm",
                    "controlAggregation": "beginColumnPages"
                },
                "marketData": {
                    "name": "MarketData",
                    "controlAggregation": "beginColumnPages"
                },
                "dealsList": {
                    "name": "DealsList",
                    "controlAggregation": "beginColumnPages"
                },
                "dealCreate": {
                    "name": "DealCreate",
                    "controlAggregation": "midColumnPages"
                },
                "dealDetail": {
                    "name": "DealDetail",
                    "controlAggregation": "midColumnPages"
                },
                "counterpartiesList": {
                    "name": "CounterpartiesList",
                    "controlAggregation": "beginColumnPages"
                },
                "counterpartyCreate": {
                    "name": "CounterpartyCreate",
                    "controlAggregation": "midColumnPages"
                },
                "counterpartyDetail": {
                    "name": "CounterpartyDetail",
                    "controlAggregation": "midColumnPages"
                },
                "auditTrail": {
                    "name": "AuditTrail",
                    "controlAggregation": "beginColumnPages"
                },
                "financePipeline": {
                    "name": "FinancePipeline",
                    "controlAggregation": "beginColumnPages"
                },
                "blocked": {
                    "name": "Blocked",
                    "controlAggregation": "beginColumnPages"
                },
                "notFound": {
                    "name": "NotFound",
                    "controlAggregation": "beginColumnPages"
                }
            }
        }
    }
}
