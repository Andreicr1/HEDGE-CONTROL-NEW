<mvc:View
  controllerName="hedgecontrol.controller.ExposureDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:uxap="sap.uxap"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <uxap:ObjectPageLayout id="exposureDetailPage" showTitleInHeaderContent="true" busy="{expDetail>/busy}">
    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <Title text="{path: 'expDetail>/detail/commodity', formatter: 'formatter.capitalize'} — {path: 'expDetail>/detail/source_type', formatter: 'formatter.exposureDirectionLabel'}" />
        </uxap:heading>
        <uxap:expandedContent>
          <ObjectStatus text="{path: 'expDetail>/detail/status', formatter: 'formatter.capitalize'}"
            state="{path: 'expDetail>/detail/status', formatter: 'formatter.statusState'}" />
        </uxap:expandedContent>
        <uxap:actions>
          <Button text="Hedge" icon="sap-icon://shield" press=".onHedge" type="Emphasized"
                  visible="{= ${expDetail>/detail/price_type} === 'variable' &amp;&amp; ${expDetail>/detail/open_tons} > 0}" />
          <Button icon="sap-icon://decline" press=".onClose" tooltip="{i18n>close}" type="Transparent" />
        </uxap:actions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>
    <uxap:headerContent>
      <HBox class="sapUiSmallMarginEnd">
        <VBox class="sapUiSmallMarginEnd">
          <ObjectAttribute title="{i18n>colOriginalTons}" text="{path: 'expDetail>/detail/original_tons', formatter: 'formatter.numberTwoDecimals'} MT" />
          <ObjectAttribute title="{i18n>colHedgedTons}" text="{path: 'expDetail>/detail/hedged_tons', formatter: 'formatter.numberTwoDecimals'} MT" />
          <ObjectAttribute title="{i18n>colOpenTons}" text="{path: 'expDetail>/detail/open_tons', formatter: 'formatter.numberTwoDecimals'} MT" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <ObjectAttribute title="{i18n>colSourceType}" text="{path: 'expDetail>/detail/source_type', formatter: 'formatter.capitalize'}" />
          <ObjectAttribute title="{i18n>colOrderType}" text="{path: 'expDetail>/detail/order_type', formatter: 'formatter.capitalize'}" />
          <ObjectAttribute title="{i18n>colPriceType}" text="{path: 'expDetail>/detail/price_type', formatter: 'formatter.capitalize'}" />
        </VBox>
      </HBox>
    </uxap:headerContent>

    <uxap:sections>
      <!-- Section 1: Exposure Data -->
      <uxap:ObjectPageSection title="{i18n>sectionExposureData}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                emptySpanXL="0" emptySpanL="0" emptySpanM="0"
                columnsXL="2" columnsL="2" columnsM="1">
                <form:content>
                  <core:Title text="{i18n>sectionExposure}" />
                  <Label text="{i18n>colId}" />
                  <Text text="{path: 'expDetail>/detail/id', formatter: 'formatter.shortUuid'}" />
                  <Label text="{i18n>colCommodity}" />
                  <Text text="{path: 'expDetail>/detail/commodity', formatter: 'formatter.capitalize'}" />
                  <Label text="{i18n>colDirection}" />
                  <ObjectStatus text="{path: 'expDetail>/detail/source_type', formatter: 'formatter.exposureDirectionLabel'}"
                    state="{path: 'expDetail>/detail/source_type', formatter: 'formatter.exposureDirectionState'}" />
                  <Label text="{i18n>colOriginalTons}" />
                  <Text text="{path: 'expDetail>/detail/original_tons', formatter: 'formatter.numberTwoDecimals'}" />
                  <Label text="{i18n>colHedgedTons}" />
                  <Text text="{path: 'expDetail>/detail/hedged_tons', formatter: 'formatter.numberTwoDecimals'}" />
                  <Label text="{i18n>colOpenTons}" />
                  <ObjectNumber number="{path: 'expDetail>/detail/open_tons', formatter: 'formatter.numberTwoDecimals'}"
                    state="{= ${expDetail>/detail/open_tons} > 0 ? 'Warning' : 'Success'}" />
                  <Label text="{i18n>colSettlementMonth}" />
                  <Text text="{expDetail>/detail/settlement_month}" />
                  <Label text="{i18n>colStatus}" />
                  <ObjectStatus text="{path: 'expDetail>/detail/status', formatter: 'formatter.capitalize'}"
                    state="{path: 'expDetail>/detail/status', formatter: 'formatter.statusState'}" />

                  <core:Title text="{i18n>sectionSettlementDates}" />
                  <Label text="{i18n>colDeliveryDateStart}" />
                  <Text text="{path: 'expDetail>/detail/delivery_date_start', formatter: 'formatter.dateDisplay'}" />
                  <Label text="{i18n>colDeliveryDateEnd}" />
                  <Text text="{path: 'expDetail>/detail/delivery_date_end', formatter: 'formatter.dateDisplay'}" />

                  <core:Title text="{i18n>sectionOrderInfo}" />
                  <Label text="{i18n>colSourceType}" />
                  <Text text="{path: 'expDetail>/detail/source_type', formatter: 'formatter.capitalize'}" />
                  <Label text="{i18n>colOrderType}" />
                  <Text text="{path: 'expDetail>/detail/order_type', formatter: 'formatter.capitalize'}" />
                  <Label text="{i18n>counterpartyNameLabel}" visible="{= !!${expDetail>/detail/counterparty_name}}" />
                  <Text text="{expDetail>/detail/counterparty_name}" visible="{= !!${expDetail>/detail/counterparty_name}}" />
                  <Label text="{i18n>colPriceType}" />
                  <Text text="{path: 'expDetail>/detail/price_type', formatter: 'formatter.capitalize'}" />

                  <!-- Fixed price value -->
                  <Label text="{i18n>colFixedPriceValue}" visible="{= ${expDetail>/detail/price_type} === 'fixed' &amp;&amp; !!${expDetail>/detail/avg_entry_price}}" />
                  <Text text="{expDetail>/detail/avg_entry_price} USD/MT" visible="{= ${expDetail>/detail/price_type} === 'fixed' &amp;&amp; !!${expDetail>/detail/avg_entry_price}}" />

                  <!-- Variable price convention details -->
                  <Label text="{i18n>colPricingConvention}" visible="{= ${expDetail>/detail/price_type} === 'variable' &amp;&amp; !!${expDetail>/detail/pricing_convention}}" />
                  <Text text="{expDetail>/detail/pricing_convention}" visible="{= ${expDetail>/detail/price_type} === 'variable' &amp;&amp; !!${expDetail>/detail/pricing_convention}}" />

                  <Label text="{i18n>referenceMonth}" visible="{= ${expDetail>/detail/pricing_convention} === 'AVG' &amp;&amp; !!${expDetail>/detail/reference_month}}" />
                  <Text text="{expDetail>/detail/reference_month}" visible="{= ${expDetail>/detail/pricing_convention} === 'AVG' &amp;&amp; !!${expDetail>/detail/reference_month}}" />

                  <Label text="{i18n>observationDateStart}" visible="{= ${expDetail>/detail/pricing_convention} === 'AVGInter' &amp;&amp; !!${expDetail>/detail/observation_date_start}}" />
                  <Text text="{path: 'expDetail>/detail/observation_date_start', formatter: 'formatter.dateDisplay'}" visible="{= ${expDetail>/detail/pricing_convention} === 'AVGInter' &amp;&amp; !!${expDetail>/detail/observation_date_start}}" />
                  <Label text="{i18n>observationDateEnd}" visible="{= ${expDetail>/detail/pricing_convention} === 'AVGInter' &amp;&amp; !!${expDetail>/detail/observation_date_end}}" />
                  <Text text="{path: 'expDetail>/detail/observation_date_end', formatter: 'formatter.dateDisplay'}" visible="{= ${expDetail>/detail/pricing_convention} === 'AVGInter' &amp;&amp; !!${expDetail>/detail/observation_date_end}}" />

                  <Label text="{i18n>fixingDate}" visible="{= ${expDetail>/detail/pricing_convention} === 'C2R' &amp;&amp; !!${expDetail>/detail/fixing_date}}" />
                  <Text text="{path: 'expDetail>/detail/fixing_date', formatter: 'formatter.dateDisplay'}" visible="{= ${expDetail>/detail/pricing_convention} === 'C2R' &amp;&amp; !!${expDetail>/detail/fixing_date}}" />

                  <!-- Notes -->
                  <Label text="{i18n>notes}" visible="{= !!${expDetail>/detail/order_notes}}" />
                  <Text text="{expDetail>/detail/order_notes}" visible="{= !!${expDetail>/detail/order_notes}}" />

                  <Label text="{i18n>colCreatedAt}" />
                  <Text text="{path: 'expDetail>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
                </form:content>
              </form:SimpleForm>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Section 2: Linked Hedge Contracts -->
      <uxap:ObjectPageSection title="{i18n>sectionLinkedContracts}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <Table items="{expDetail>/detail/linked_contracts}" noDataText="{i18n>noLinkedContracts}">
                <columns>
                  <Column><header><Text text="{i18n>colContractId}" /></header></Column>
                  <Column><header><Text text="{i18n>colCommodity}" /></header></Column>
                  <Column><header><Text text="{i18n>colClassification}" /></header></Column>
                  <Column hAlign="End"><header><Text text="{i18n>colQuantityMt}" /></header></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{path: 'expDetail>contract_id', formatter: 'formatter.shortUuid'}" />
                      <Text text="{path: 'expDetail>commodity', formatter: 'formatter.capitalize'}" />
                      <Text text="{path: 'expDetail>classification', formatter: 'formatter.capitalize'}" />
                      <Text text="{path: 'expDetail>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
    </uxap:sections>
  </uxap:ObjectPageLayout>
</mvc:View>
