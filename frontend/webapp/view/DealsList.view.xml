<mvc:View
  controllerName="hedgecontrol.controller.DealsList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="dealsListPage" showFooter="false" busy="{deals>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>dealsTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newDeal}" icon="sap-icon://add" press=".onCreateDeal" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="20rem" search=".onSearch" placeholder="{i18n>search}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox>
        <MessageStrip
          text="{deals>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${deals>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <List id="dealsList" items="{deals>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" itemPress=".onDealSelect">
          <items>
            <ObjectListItem
              title="{deals>name}"
              intro="{deals>reference}"
              type="Navigation"
              number="{= Math.round(${deals>hedge_ratio} * 100) + '%'}"
              numberUnit="Hedge"
              numberState="{= ${deals>hedge_ratio} >= 1 ? 'Success' : (${deals>hedge_ratio} >= 0.5 ? 'Warning' : 'Error')}"
              icon="sap-icon://detail-view">
              <attributes>
                <ObjectAttribute text="{path: 'deals>commodity', formatter: 'formatter.capitalize'}" />
                <ObjectAttribute text="{i18n>colPhysicalTons}: {path: 'deals>total_physical_tons', formatter: 'formatter.numberTwoDecimals'} MT" />
                <ObjectAttribute text="{path: 'deals>created_at', formatter: 'formatter.dateTimeDisplay'}" />
              </attributes>
              <firstStatus>
                <ObjectStatus text="{path: 'deals>status', formatter: 'formatter.capitalize'}"
                  state="{path: 'deals>status', formatter: 'formatter.statusState'}" />
              </firstStatus>
            </ObjectListItem>
          </items>
        </List>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
