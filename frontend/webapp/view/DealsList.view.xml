<mvc:View
  controllerName="hedgecontrol.controller.DealsList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="dealsListPage" showFooter="false" busy="{deals>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>dealsTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newDeal}" icon="sap-icon://add" press=".onCreateDeal" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{deals>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${deals>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <Table id="dealsTable" items="{deals>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" selectionChange=".onDealSelect">
          <headerToolbar>
            <OverflowToolbar>
              <Title text="{i18n>dealsTitle}" level="H3" />
              <ToolbarSpacer />
              <SearchField width="15rem" search=".onSearch" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column width="8rem"><header><Text text="{i18n>colReference}" /></header></Column>
            <Column><header><Text text="{i18n>colDealName}" /></header></Column>
            <Column><header><Text text="{i18n>colCommodity}" /></header></Column>
            <Column width="8rem"><header><Text text="{i18n>colStatus}" /></header></Column>
            <Column hAlign="End"><header><Text text="{i18n>colPhysicalTons}" /></header></Column>
            <Column hAlign="End"><header><Text text="{i18n>colHedgeTons}" /></header></Column>
            <Column width="10rem"><header><Text text="{i18n>colHedgeRatio}" /></header></Column>
            <Column><header><Text text="{i18n>colCreatedAt}" /></header></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{deals>reference}" />
                <Text text="{deals>name}" />
                <Text text="{path: 'deals>commodity', formatter: 'formatter.capitalize'}" />
                <ObjectStatus text="{path: 'deals>status', formatter: 'formatter.capitalize'}"
                  state="{path: 'deals>status', formatter: 'formatter.statusState'}" />
                <Text text="{path: 'deals>total_physical_tons', formatter: 'formatter.numberTwoDecimals'}" />
                <Text text="{path: 'deals>total_hedge_tons', formatter: 'formatter.numberTwoDecimals'}" />
                <ProgressIndicator
                  percentValue="{= Math.min(${deals>hedge_ratio} * 100, 100)}"
                  displayValue="{= Math.round(${deals>hedge_ratio} * 100) + '%'}"
                  state="{= ${deals>hedge_ratio} >= 1 ? 'Success' : (${deals>hedge_ratio} >= 0.5 ? 'Warning' : 'Error')}"
                  showValue="true" />
                <Text text="{path: 'deals>created_at', formatter: 'formatter.dateTimeDisplay'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
