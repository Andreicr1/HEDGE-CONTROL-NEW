<mvc:View
  controllerName="hedgecontrol.controller.DealsList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="dealsListPage" showFooter="false" busy="{deals>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>dealsTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newDeal}" icon="sap-icon://add" press=".onCreateDeal" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox>
        <MessageStrip
          text="{deals>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${deals>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <Table id="dealsList" items="{deals>/items}" growing="true" growingThreshold="50"
          mode="SingleSelectMaster" itemPress=".onDealSelect">
          <noData>
            <IllustratedMessage illustrationType="sapIllus-EmptyList"
                title="{i18n>emptyStateTitle}" description="{i18n>emptyStateDescription}" />
          </noData>
          <headerToolbar>
            <OverflowToolbar>
              <Title text="{i18n>dealsTitle}" level="H3" />
              <ToolbarSpacer />
              <SearchField width="15rem" search=".onSearch" placeholder="{i18n>search}" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column><Text text="{i18n>colDealName}" /></Column>
            <Column><Text text="{i18n>colReference}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colCommodity}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPhysicalTons}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colHedgeRatio}" /></Column>
            <Column><Text text="{i18n>colStatus}" /></Column>
            <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCreatedAt}" /></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{deals>name}" />
                <Text text="{deals>reference}" />
                <Text text="{path: 'deals>commodity', formatter: 'formatter.capitalize'}" />
                <ObjectNumber number="{path: 'deals>total_physical_tons', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
                <ObjectStatus
                  text="{= Math.round(${deals>hedge_ratio} * 100) + '%'}"
                  state="{= ${deals>hedge_ratio} >= 1 ? 'Success' : (${deals>hedge_ratio} >= 0.5 ? 'Warning' : 'Error')}" />
                <ObjectStatus text="{path: 'deals>status', formatter: 'formatter.capitalize'}"
                  state="{path: 'deals>status', formatter: 'formatter.statusState'}" />
                <Text text="{path: 'deals>created_at', formatter: 'formatter.dateTimeDisplay'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
