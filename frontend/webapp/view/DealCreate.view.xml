<mvc:View
  controllerName="hedgecontrol.controller.DealCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">
  <f:DynamicPage id="dealCreatePage" showFooter="true" busy="{dealCrt>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>newDeal}" />
        </f:heading>
        <f:actions>
          <Button icon="sap-icon://decline" press=".onCancel" tooltip="{i18n>cancel}" type="Transparent" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{dealCrt>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${dealCrt>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <form:Form id="dealForm" editable="true">
          <form:layout>
            <form:ColumnLayout columnsM="1" columnsL="1" columnsXL="1" />
          </form:layout>
          <form:formContainers>
            <form:FormContainer title="{i18n>sectionDealInfo}">
              <form:formElements>
                <form:FormElement label="{i18n>colDealName}">
                  <form:fields>
                    <Input value="{dealCrt>/form/name}" required="true" placeholder="{i18n>placeholderDealName}" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colCommodity}">
                  <form:fields>
                    <Select selectedKey="{dealCrt>/form/commodity}">
                      <core:Item key="" text="{i18n>selectCommodity}" />
                      <core:Item key="aluminium" text="{i18n>commodityAluminium}" />
                      <core:Item key="copper" text="{i18n>commodityCopper}" />
                      <core:Item key="zinc" text="{i18n>commodityZinc}" />
                      <core:Item key="nickel" text="{i18n>commodityNickel}" />
                      <core:Item key="lead" text="{i18n>commodityLead}" />
                      <core:Item key="tin" text="{i18n>commodityTin}" />
                    </Select>
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
          </form:formContainers>
        </form:Form>
      </VBox>
    </f:content>
    <f:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="{i18n>submit}" press=".onSubmit" type="Emphasized" />
        <Button text="{i18n>cancel}" press=".onCancel" />
      </OverflowToolbar>
    </f:footer>
  </f:DynamicPage>
</mvc:View>
