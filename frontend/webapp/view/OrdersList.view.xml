<mvc:View
  controllerName="hedgecontrol.controller.OrdersList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="ordersListPage" showFooter="false" busy="{ord>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>comercialTitle}" />
        </f:heading>
        <f:actions>
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox>
        <MessageStrip
          text="{ord>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${ord>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <IconTabBar id="comercialTabs" select=".onTabSelect" selectedKey="{ord>/selectedTab}" class="sapUiNoContentPadding">
          <items>
            <!-- ══ TAB: Deals ══ -->
            <IconTabFilter key="deals" text="{i18n>tabDeals}" icon="sap-icon://detail-view" count="{ord>/dealsCount}">
              <Table id="dealsTabList" items="{ord>/deals}" growing="true" growingThreshold="50"
                mode="SingleSelectMaster" itemPress=".onDealSelect">
                <noData>
                  <IllustratedMessage illustrationType="sapIllus-EmptyList"
                      title="{i18n>emptyStateTitle}" description="{i18n>emptyStateDescription}" />
                </noData>
                <headerToolbar>
                  <OverflowToolbar>
                    <Title text="{i18n>tabDeals}" level="H3" />
                    <ToolbarSpacer />
                    <SearchField width="15rem" search=".onSearchDeals" placeholder="{i18n>search}" />
                    <Button text="{i18n>newDeal}" icon="sap-icon://add" press=".onCreateDeal" type="Emphasized" />
                  </OverflowToolbar>
                </headerToolbar>
                <columns>
                  <Column><Text text="{i18n>colDealName}" /></Column>
                  <Column><Text text="{i18n>colReference}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colCommodity}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPhysicalTons}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colHedgeRatio}" /></Column>
                  <Column><Text text="{i18n>colStatus}" /></Column>
                </columns>
                <items>
                  <ColumnListItem type="Navigation">
                    <cells>
                      <Text text="{ord>name}" />
                      <Text text="{ord>reference}" />
                      <Text text="{path: 'ord>commodity', formatter: 'formatter.capitalize'}" />
                      <ObjectNumber number="{path: 'ord>total_physical_tons', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
                      <ObjectStatus
                        text="{= Math.round(${ord>hedge_ratio} * 100) + '%'}"
                        state="{= ${ord>hedge_ratio} >= 1 ? 'Success' : (${ord>hedge_ratio} >= 0.5 ? 'Warning' : 'Error')}" />
                      <ObjectStatus text="{path: 'ord>status', formatter: 'formatter.capitalize'}"
                        state="{path: 'ord>status', formatter: 'formatter.statusState'}" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </IconTabFilter>
            <!-- ══ TAB: Sales Orders ══ -->
            <IconTabFilter key="salesOrders" text="{i18n>tabSalesOrders}" icon="sap-icon://sales-order" count="{ord>/soCount}">
              <Table id="soList" items="{ord>/salesOrders}" growing="true" growingThreshold="50"
                mode="SingleSelectMaster" itemPress=".onOrderSelect">
                <noData>
                  <IllustratedMessage illustrationType="sapIllus-EmptyList"
                      title="{i18n>emptyStateTitle}" description="{i18n>emptyStateDescription}" />
                </noData>
                <headerToolbar>
                  <OverflowToolbar>
                    <Title text="{i18n>tabSalesOrders}" level="H3" />
                    <ToolbarSpacer />
                    <SearchField width="15rem" search=".onSearchSO" placeholder="{i18n>search}" />
                    <Button text="{i18n>newSalesOrder}" icon="sap-icon://add" press=".onCreateSales" type="Emphasized" />
                  </OverflowToolbar>
                </headerToolbar>
                <columns>
                  <Column><Text text="{i18n>colId}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colQuantityMt}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPriceType}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colAvgEntryPrice}" /></Column>
                  <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCreatedAt}" /></Column>
                </columns>
                <items>
                  <ColumnListItem type="Navigation">
                    <cells>
                      <Text text="{path: 'ord>id', formatter: 'formatter.shortUuid'}" />
                      <ObjectNumber number="{path: 'ord>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
                      <Text text="{path: 'ord>price_type', formatter: 'formatter.capitalize'}" />
                      <ObjectNumber number="{path: 'ord>avg_entry_price', formatter: 'formatter.priceFourDecimals'}" />
                      <Text text="{path: 'ord>created_at', formatter: 'formatter.dateTimeDisplay'}" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </IconTabFilter>
            <!-- ══ TAB: Purchase Orders ══ -->
            <IconTabFilter key="purchaseOrders" text="{i18n>tabPurchaseOrders}" icon="sap-icon://cart" count="{ord>/poCount}">
              <Table id="poList" items="{ord>/purchaseOrders}" growing="true" growingThreshold="50"
                mode="SingleSelectMaster" itemPress=".onOrderSelect">
                <noData>
                  <IllustratedMessage illustrationType="sapIllus-EmptyList"
                      title="{i18n>emptyStateTitle}" description="{i18n>emptyStateDescription}" />
                </noData>
                <headerToolbar>
                  <OverflowToolbar>
                    <Title text="{i18n>tabPurchaseOrders}" level="H3" />
                    <ToolbarSpacer />
                    <SearchField width="15rem" search=".onSearchPO" placeholder="{i18n>search}" />
                    <Button text="{i18n>newPurchaseOrder}" icon="sap-icon://add" press=".onCreatePurchase" type="Emphasized" />
                  </OverflowToolbar>
                </headerToolbar>
                <columns>
                  <Column><Text text="{i18n>colId}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colQuantityMt}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPriceType}" /></Column>
                  <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colAvgEntryPrice}" /></Column>
                  <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCreatedAt}" /></Column>
                </columns>
                <items>
                  <ColumnListItem type="Navigation">
                    <cells>
                      <Text text="{path: 'ord>id', formatter: 'formatter.shortUuid'}" />
                      <ObjectNumber number="{path: 'ord>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
                      <Text text="{path: 'ord>price_type', formatter: 'formatter.capitalize'}" />
                      <ObjectNumber number="{path: 'ord>avg_entry_price', formatter: 'formatter.priceFourDecimals'}" />
                      <Text text="{path: 'ord>created_at', formatter: 'formatter.dateTimeDisplay'}" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </IconTabFilter>
          </items>
        </IconTabBar>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
