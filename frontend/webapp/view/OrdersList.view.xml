<mvc:View
  controllerName="hedgecontrol.controller.OrdersList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="ordersListPage" showFooter="false" busy="{ord>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>ordersTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newSalesOrder}" icon="sap-icon://add" press=".onCreateSales" type="Emphasized" />
          <Button text="{i18n>newPurchaseOrder}" icon="sap-icon://add" press=".onCreatePurchase" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{ord>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${ord>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <Table id="ordersTable" items="{ord>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" selectionChange=".onOrderSelect">
          <headerToolbar>
            <OverflowToolbar>
              <Title text="{i18n>ordersTitle}" level="H3" />
              <ToolbarSpacer />
              <SearchField width="15rem" search=".onSearch" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column width="8rem"><header><Text text="{i18n>colId}" /></header></Column>
            <Column><header><Text text="{i18n>colOrderType}" /></header></Column>
            <Column><header><Text text="{i18n>colPriceType}" /></header></Column>
            <Column hAlign="End"><header><Text text="{i18n>colQuantityMt}" /></header></Column>
            <Column><header><Text text="{i18n>colPricingConvention}" /></header></Column>
            <Column hAlign="End"><header><Text text="{i18n>colAvgEntryPrice}" /></header></Column>
            <Column><header><Text text="{i18n>colCreatedAt}" /></header></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{path: 'ord>id', formatter: 'formatter.shortUuid'}" />
                <ObjectStatus text="{ord>order_type}" state="{= ${ord>order_type} === 'SO' ? 'Information' : 'Warning'}" />
                <Text text="{path: 'ord>price_type', formatter: 'formatter.capitalize'}" />
                <Text text="{path: 'ord>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" />
                <Text text="{ord>pricing_convention}" />
                <Text text="{path: 'ord>avg_entry_price', formatter: 'formatter.priceFourDecimals'}" />
                <Text text="{path: 'ord>created_at', formatter: 'formatter.dateTimeDisplay'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
