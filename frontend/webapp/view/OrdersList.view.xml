<mvc:View
  controllerName="hedgecontrol.controller.OrdersList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="ordersListPage" showFooter="false" busy="{ord>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>ordersTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newSalesOrder}" icon="sap-icon://add" press=".onCreateSales" type="Emphasized" />
          <Button text="{i18n>newPurchaseOrder}" icon="sap-icon://add" press=".onCreatePurchase" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="20rem" search=".onSearch" placeholder="{i18n>search}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox>
        <MessageStrip
          text="{ord>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${ord>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <List id="ordersList" items="{ord>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" selectionChange=".onOrderSelect">
          <items>
            <ObjectListItem
              title="{ord>order_type} — {path: 'ord>id', formatter: 'formatter.shortUuid'}"
              type="Navigation"
              number="{path: 'ord>quantity_mt', formatter: 'formatter.numberTwoDecimals'}"
              numberUnit="MT"
              icon="{= ${ord>order_type} === 'SO' ? 'sap-icon://sales-order' : 'sap-icon://cart'}">
              <attributes>
                <ObjectAttribute text="{i18n>colPriceType}: {path: 'ord>price_type', formatter: 'formatter.capitalize'}" />
                <ObjectAttribute text="{i18n>colAvgEntryPrice}: {path: 'ord>avg_entry_price', formatter: 'formatter.priceFourDecimals'}" />
                <ObjectAttribute text="{path: 'ord>created_at', formatter: 'formatter.dateTimeDisplay'}" />
              </attributes>
              <firstStatus>
                <ObjectStatus text="{ord>order_type}"
                  state="{= ${ord>order_type} === 'SO' ? 'Information' : 'Warning'}" />
              </firstStatus>
            </ObjectListItem>
          </items>
        </List>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
