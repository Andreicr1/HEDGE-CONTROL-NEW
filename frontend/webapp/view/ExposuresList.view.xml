<mvc:View
  controllerName="hedgecontrol.controller.ExposuresList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form"
  xmlns:l="sap.ui.layout"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="exposuresListPage" showFooter="false" busy="{exp>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>exposuresTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>reconcile}" icon="sap-icon://synchronize" press=".onReconcile" type="Emphasized" />
          <Button text="{i18n>refresh}" icon="sap-icon://refresh" press=".onRefresh" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{exp>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${exp>/errorMessage}}"
          class="sapUiSmallMarginBottom" />

        <MessageStrip
          text="{exp>/reconcileMessage}"
          type="Success"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${exp>/reconcileMessage}}"
          class="sapUiSmallMarginBottom" />

        <!-- Net Exposure Summary -->
        <Panel headerText="{i18n>netExposureSummary}" expandable="true" expanded="true" class="sapUiSmallMarginBottom">
          <List items="{exp>/netItems}" noDataText="{i18n>noNetExposure}" showSeparators="None">
            <CustomListItem>
              <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                labelSpanXL="7" labelSpanL="7" labelSpanM="5" labelSpanS="6"
                emptySpanXL="0" emptySpanL="0" emptySpanM="0"
                columnsXL="2" columnsL="2" columnsM="1">
                <form:content>
                  <core:Title text="{path: 'exp>commodity', formatter: 'formatter.capitalize'}" />
                  <Label text="{i18n>colOriginalLong}" />
                  <ObjectNumber number="{path: 'exp>long_original', formatter: 'formatter.numberTwoDecimals'}" />
                  <Label text="{i18n>colOriginalShort}" />
                  <ObjectNumber number="{path: 'exp>short_original', formatter: 'formatter.numberTwoDecimals'}" />
                  <Label text="{i18n>colHedgedLong}" />
                  <ObjectNumber number="{path: 'exp>long_hedged', formatter: 'formatter.numberTwoDecimals'}" state="Success" />
                  <Label text="{i18n>colHedgedShort}" />
                  <ObjectNumber number="{path: 'exp>short_hedged', formatter: 'formatter.numberTwoDecimals'}" state="Success" />
                  <Label text="{i18n>colLongTons}" />
                  <ObjectNumber number="{path: 'exp>long_tons', formatter: 'formatter.numberTwoDecimals'}" state="Warning" />
                  <Label text="{i18n>colShortTons}" />
                  <ObjectNumber number="{path: 'exp>short_tons', formatter: 'formatter.numberTwoDecimals'}" state="Warning" />
                  <Label text="{i18n>colNetTons}" design="Bold" />
                  <ObjectNumber number="{path: 'exp>net_tons', formatter: 'formatter.numberTwoDecimals'}"
                    state="{= ${exp>net_tons} >= 0 ? 'Success' : 'Error'}" emphasized="true" />
                </form:content>
              </form:SimpleForm>
            </CustomListItem>
          </List>
        </Panel>

        <!-- Exposure Items List -->
        <Table id="exposureList"
          items="{exp>/engineItems}"
          growing="true"
          growingThreshold="50"
          noDataText="{i18n>noData}"
          mode="SingleSelectMaster"
          itemPress=".onExposureSelect">
          <headerToolbar>
            <OverflowToolbar>
              <Title text="{i18n>exposuresList}" level="H3" />
              <ToolbarSpacer />
              <SearchField width="15rem" search=".onSearch" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column><Text text="{i18n>colCommodity}" /></Column>
            <Column><Text text="{i18n>colSourceType}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colOpenTons}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colSettlementMonth}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colPriceType}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colOriginalTons}" /></Column>
            <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colHedgedTons}" /></Column>
            <Column><Text text="{i18n>colStatus}" /></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{path: 'exp>commodity', formatter: 'formatter.capitalize'}" />
                <Text text="{path: 'exp>source_type', formatter: 'formatter.exposureTypeLabel'}" />
                <ObjectNumber
                  number="{path: 'exp>open_tons', formatter: 'formatter.numberTwoDecimals'}"
                  unit="MT"
                  state="{= ${exp>open_tons} > 0 ? 'Warning' : 'Success'}" />
                <Text text="{parts: [{path: 'exp>pricing_convention'}, {path: 'exp>reference_month'}, {path: 'exp>observation_date_start'}, {path: 'exp>observation_date_end'}, {path: 'exp>fixing_date'}, {path: 'exp>settlement_month'}], formatter: 'formatter.exposureSettlementValue'}" />
                <Text text="{path: 'exp>price_type', formatter: 'formatter.priceTypeLabel'}" />
                <ObjectNumber number="{path: 'exp>original_tons', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
                <ObjectNumber number="{path: 'exp>hedged_tons', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
                <ObjectStatus text="{path: 'exp>status', formatter: 'formatter.capitalize'}"
                  state="{path: 'exp>status', formatter: 'formatter.statusState'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
