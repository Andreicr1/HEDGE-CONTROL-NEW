<mvc:View
  controllerName="hedgecontrol.controller.Mtm"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:t="sap.ui.table"
  xmlns:viz="sap.viz.ui5.controls"
  xmlns:vizData="sap.viz.ui5.data"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="mtmPage" headerExpanded="true" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>mtmTitle}" />
        </f:heading>
        <f:snappedContent>
          <Text text="{mtm>/summaryText}" />
        </f:snappedContent>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <HBox alignItems="End" wrap="Wrap" class="sapUiSmallMargin">
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>mtmFilterContracts}" labelFor="mtmContractSelector" />
            <MultiComboBox id="mtmContractSelector"
              placeholder="{i18n>mtmFilterContractsPlaceholder}"
              width="28rem"
              items="{mtm>/contractList}"
              selectionChange=".onContractSelectionChange">
              <core:Item key="{mtm>id}" text="{mtm>label}" />
            </MultiComboBox>
          </VBox>
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>asOfDate}" labelFor="mtmDatePicker" />
            <DatePicker id="mtmDatePicker"
              displayFormat="dd/MM/yyyy"
              valueFormat="yyyy-MM-dd"
              placeholder="dd/MM/yyyy"
              width="12rem" />
          </VBox>
          <Button id="mtmGoButton"
            text="{i18n>mtmGoButton}"
            type="Emphasized"
            press=".onCalculateMtm"
            class="sapUiSmallMarginEnd" />
          <CheckBox id="mtmSelectAll"
            text="{i18n>mtmSelectAllContracts}"
            selected="{mtm>/selectAll}"
            select=".onSelectAllContracts" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <VBox class="sapUiSmallMargin">

        <!-- Summary Strip -->
        <Panel visible="{mtm>/resultLoaded}" class="sapUiSmallMarginBottom">
          <headerToolbar>
            <Toolbar>
              <Title text="{i18n>mtmSummary}" level="H4" />
            </Toolbar>
          </headerToolbar>
          <HBox wrap="Wrap" class="sapUiSmallMargin" justifyContent="SpaceBetween">
            <VBox class="sapUiSmallMarginEnd" width="auto">
              <Label text="{i18n>mtmTotalMtmValue}" />
              <ObjectNumber number="{ path: 'mtm>/totals/total_mtm', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                state="{ path: 'mtm>/totals/total_mtm', formatter: '.formatMtmState' }" emphasized="true" />
            </VBox>
            <VBox class="sapUiSmallMarginEnd" width="auto">
              <Label text="{i18n>mtmContractsCount}" />
              <ObjectNumber number="{mtm>/totals/contract_count}" />
            </VBox>
            <VBox width="auto">
              <Label text="{i18n>mtmTotalQuantity}" />
              <ObjectNumber number="{ path: 'mtm>/totals/total_quantity', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
            </VBox>
          </HBox>
        </Panel>

        <!-- VizFrame: MtM per contract bar chart -->
        <viz:VizFrame id="mtmChart"
          vizType="bar"
          width="100%"
          height="300px"
          class="hcVizFrame sapUiSmallMarginBottom"
          visible="{mtm>/resultLoaded}">
          <viz:dataset>
            <vizData:FlattenedDataset data="{path: 'mtm>/chartData'}">
              <vizData:dimensions>
                <vizData:DimensionDefinition name="Contrato" value="{label}" />
              </vizData:dimensions>
              <vizData:measures>
                <vizData:MeasureDefinition name="MtM" value="{mtm}" />
              </vizData:measures>
            </vizData:FlattenedDataset>
          </viz:dataset>
          <viz:feeds>
            <viz:FeedItem id="mtmValueAxis" uid="valueAxis" values="['MtM']" />
            <viz:FeedItem id="mtmCategoryAxis" uid="categoryAxis" values="['Contrato']" />
          </viz:feeds>
        </viz:VizFrame>

        <!-- TreeTable Breakdown -->
          rows="{path: 'mtm>/treeData', parameters: { arrayNames: ['children'] }}"
          selectionMode="None"
          visibleRowCountMode="Auto"
          minAutoRowCount="10"
          enableColumnReordering="false"
          expandFirstLevel="true"
          visible="{mtm>/resultLoaded}">
          <t:toolbar>
            <Toolbar>
              <Title text="{i18n>mtmBreakdown}" level="H4" />
              <ToolbarSpacer />
              <Button icon="sap-icon://expand-all" tooltip="{i18n>mtmExpandAll}" press=".onExpandAll" />
              <Button icon="sap-icon://collapse-all" tooltip="{i18n>mtmCollapseAll}" press=".onCollapseAll" />
            </Toolbar>
          </t:toolbar>
          <t:columns>
            <t:Column width="22rem">
              <Label text="{i18n>mtmColDescription}" />
              <t:template>
                <Text text="{mtm>description}" wrapping="false" />
              </t:template>
            </t:Column>
            <t:Column width="8rem" hAlign="Center">
              <Label text="{i18n>colCommodity}" />
              <t:template>
                <Text text="{mtm>commodity}" />
              </t:template>
            </t:Column>
            <t:Column width="10rem" hAlign="End">
              <Label text="{i18n>colQuantityMt}" />
              <t:template>
                <Text text="{ path: 'mtm>quantity', formatter: 'formatter.numberTwoDecimals' }" />
              </t:template>
            </t:Column>
            <t:Column width="10rem" hAlign="End">
              <Label text="{i18n>mtmColEntryPrice}" />
              <t:template>
                <Text text="{ path: 'mtm>entryPrice', formatter: 'formatter.priceFourDecimals' }" />
              </t:template>
            </t:Column>
            <t:Column width="10rem" hAlign="End">
              <Label text="{i18n>mtmColPriceD1}" />
              <t:template>
                <Text text="{ path: 'mtm>priceD1', formatter: 'formatter.priceFourDecimals' }" />
              </t:template>
            </t:Column>
            <t:Column width="12rem" hAlign="End">
              <Label text="{i18n>mtmColMtmValue}" />
              <t:template>
                <ObjectNumber number="{ path: 'mtm>mtmValue', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                  state="{ path: 'mtm>mtmValue', formatter: '.formatMtmState' }" />
              </t:template>
            </t:Column>
          </t:columns>
        </t:TreeTable>

        <!-- Empty state -->
        <IllustratedMessage
          visible="{= !${mtm>/resultLoaded} }"
          illustrationType="sapIllus-NoData"
          title="{i18n>mtmEmptyTitle}"
          description="{i18n>mtmEmptyDescription}" />

      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
