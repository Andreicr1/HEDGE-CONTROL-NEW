<mvc:View
  controllerName="hedgecontrol.controller.ContractDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:uxap="sap.uxap"
  xmlns:layout="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <uxap:ObjectPageLayout id="contractDetailPage" busy="{ctrDet>/busy}" showTitleInHeaderContent="true">

    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <HBox alignItems="Center">
            <Title text="{ctrDet>/reference}" class="sapUiSmallMarginEnd" />
            <ObjectStatus text="{ path: 'ctrDet>/classification', formatter: 'formatter.classificationText' }"
              state="{ path: 'ctrDet>/classification', formatter: 'formatter.classificationState' }" />
            <ObjectStatus text="{ path: 'ctrDet>/status', formatter: 'formatter.capitalize' }"
              state="{ path: 'ctrDet>/status', formatter: 'formatter.statusState' }"
              class="sapUiSmallMarginBegin" />
          </HBox>
        </uxap:heading>
        <uxap:actions>
          <Button text="{i18n>settle}" icon="sap-icon://money-bills" type="Emphasized"
            press=".onSettle" visible="{= ${ctrDet>/status} === 'active' &amp;&amp; !${ctrDet>/deleted_at}}" />
          <Button text="{i18n>archive}" icon="sap-icon://delete" type="Reject"
            press=".onArchive" visible="{ path: 'ctrDet>/deleted_at', formatter: '.isNotArchived' }" />
          <Button text="{i18n>close}" icon="sap-icon://decline" type="Default" press=".onClose" />
        </uxap:actions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>

    <uxap:headerContent>
      <HBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>commodity}" />
          <Text text="{ctrDet>/commodity}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>quantityMt}" />
          <ObjectNumber number="{ path: 'ctrDet>/quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>counterparty}" />
          <Text text="{ctrDet>/_counterparty_name}" />
        </VBox>
        <VBox>
          <Label text="{i18n>mtmPreviousDay}" />
          <ObjectNumber number="{ path: 'ctrDet>/_mtm_value', formatter: 'formatter.priceFourDecimals' }"
            unit="{ctrDet>/_mtm_unit}"
            state="{ path: 'ctrDet>/_mtm_value', formatter: '.formatMtmState' }" />
        </VBox>
      </HBox>
    </uxap:headerContent>

    <uxap:sections>

      <!-- Dados do Contrato -->
      <uxap:ObjectPageSection title="{i18n>contractData}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <form:Form editable="false">
                <form:layout>
                  <form:ColumnLayout columnsM="2" columnsL="2" columnsXL="2" />
                </form:layout>
                <form:formContainers>

                  <form:FormContainer title="{i18n>contractInfo}">
                    <form:formElements>
                      <form:FormElement label="{i18n>contractReference}">
                        <Text text="{ctrDet>/reference}" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>commodity}">
                        <Text text="{ctrDet>/commodity}" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>counterparty}">
                        <Text text="{ctrDet>/_counterparty_name}" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>quantityMt}">
                        <ObjectNumber number="{ path: 'ctrDet>/quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>classification}">
                        <ObjectStatus text="{ path: 'ctrDet>/classification', formatter: 'formatter.classificationText' }"
                          state="{ path: 'ctrDet>/classification', formatter: 'formatter.classificationState' }" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>status}">
                        <ObjectStatus text="{ path: 'ctrDet>/status', formatter: 'formatter.capitalize' }"
                          state="{ path: 'ctrDet>/status', formatter: 'formatter.statusState' }" />
                      </form:FormElement>
                    </form:formElements>
                  </form:FormContainer>

                  <form:FormContainer title="{i18n>financialTerms}">
                    <form:formElements>
                      <form:FormElement label="{i18n>fixedPrice}">
                        <ObjectNumber number="{ path: 'ctrDet>/fixed_price_value', formatter: 'formatter.priceFourDecimals' }"
                          unit="{ctrDet>/fixed_price_unit}" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>variablePriceType}">
                        <Text text="{ path: 'ctrDet>/float_pricing_convention', formatter: 'formatter.floatPricingText' }" />
                      </form:FormElement>
                      <form:FormElement label="Período de Verificação"
                        visible="{= !!${ctrDet>/float_pricing_convention} }">
                        <Text text="{
                          parts: [
                            'ctrDet>/float_pricing_convention',
                            'ctrDet>/pricing_period_month',
                            'ctrDet>/pricing_period_year',
                            'ctrDet>/fixing_date',
                            'ctrDet>/avg_computation_days'
                          ],
                          formatter: 'formatter.verificationPeriodText'
                        }" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>premiumDiscount}">
                        <ObjectNumber number="{ path: 'ctrDet>/premium_discount', formatter: 'formatter.priceFourDecimals' }"
                          unit="{ctrDet>/fixed_price_unit}" />
                      </form:FormElement>
                    </form:formElements>
                  </form:FormContainer>

                </form:formContainers>
              </form:Form>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Datas -->
      <uxap:ObjectPageSection title="{i18n>dates}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <form:Form editable="false">
                <form:layout>
                  <form:ColumnLayout columnsM="2" columnsL="2" columnsXL="2" />
                </form:layout>
                <form:formContainers>
                  <form:FormContainer>
                    <form:formElements>
                      <form:FormElement label="{i18n>tradeDate}">
                        <Text text="{ path: 'ctrDet>/trade_date', formatter: 'formatter.dateDisplay' }" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>promptDate}">
                        <Text text="{ path: 'ctrDet>/prompt_date', formatter: 'formatter.dateDisplay' }" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>settlementDate}">
                        <Text text="{ path: 'ctrDet>/settlement_date', formatter: 'formatter.dateDisplay' }" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>createdAt}">
                        <Text text="{ path: 'ctrDet>/created_at', formatter: 'formatter.dateTimeDisplay' }" />
                      </form:FormElement>
                    </form:formElements>
                  </form:FormContainer>
                </form:formContainers>
              </form:Form>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Vínculos (Deals + Ordens vinculadas) -->
      <uxap:ObjectPageSection title="{i18n>linkagesTitle}">
        <uxap:subSections>

          <!-- Deals Vinculados -->
          <uxap:ObjectPageSubSection title="{i18n>linkedDeals}">
            <uxap:blocks>
              <VBox class="sapUiSmallMargin" visible="{= ${ctrDet>/_linkages} &amp;&amp; ${ctrDet>/_linkages}.length > 0 }">
                <Table items="{ path: 'ctrDet>/_linkages' }"
                  noDataText="{i18n>noLinkedDeals}" growing="true" growingThreshold="20">
                  <columns>
                    <Column width="18%"><Text text="{i18n>colDealReference}" /></Column>
                    <Column width="22%"><Text text="{i18n>colDealName}" /></Column>
                    <Column width="12%"><Text text="{i18n>colDealStatus}" /></Column>
                    <Column hAlign="End" width="16%"><Text text="{i18n>colPhysicalTons}" /></Column>
                    <Column hAlign="End" width="16%"><Text text="{i18n>colHedgeTons}" /></Column>
                    <Column hAlign="End" width="16%"><Text text="{i18n>colHedgeRatio}" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem type="Navigation" press=".onNavigateToDeal">
                      <cells>
                        <Link text="{ctrDet>reference}" press=".onNavigateToDeal" />
                        <Text text="{ctrDet>name}" />
                        <ObjectStatus text="{ path: 'ctrDet>status', formatter: 'formatter.capitalize' }"
                          state="{ path: 'ctrDet>status', formatter: 'formatter.statusState' }" />
                        <ObjectNumber number="{ path: 'ctrDet>total_physical_tons', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
                        <ObjectNumber number="{ path: 'ctrDet>total_hedge_tons', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
                        <Text text="{ path: 'ctrDet>hedge_ratio', formatter: 'formatter.percentDisplay' }" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>

              <MessageStrip text="{i18n>noLinkedDeals}" type="Information"
                visible="{= !${ctrDet>/_linkages} || ${ctrDet>/_linkages}.length === 0 }"
                class="sapUiSmallMargin" />
            </uxap:blocks>
          </uxap:ObjectPageSubSection>

          <!-- Ordens Vinculadas -->
          <uxap:ObjectPageSubSection title="{= ${ctrDet>/classification} === 'long' ? 'Ordens de Compra Vinculadas (PO)' : 'Ordens de Venda Vinculadas (SO)' }">
            <uxap:blocks>
              <VBox class="sapUiSmallMargin"
                visible="{= ${ctrDet>/_allOrders} &amp;&amp; ${ctrDet>/_allOrders}.length > 0 }">
                <Table items="{ path: 'ctrDet>/_allOrders' }"
                  noDataText="-" growing="true" growingThreshold="20">
                  <columns>
                    <Column width="25%"><Text text="{i18n>colOrderType}" /></Column>
                    <Column hAlign="End" width="25%"><Text text="{i18n>quantityMt}" /></Column>
                    <Column hAlign="End" width="25%"><Text text="{i18n>colAveragePrice}" /></Column>
                    <Column width="25%"><Text text="{i18n>currency}" /></Column>
                  </columns>
                  <items>
                    <ColumnListItem type="Navigation" press=".onNavigateToLinkedOrder">
                      <cells>
                        <Text text="{ path: 'ctrDet>linked_type', formatter: 'formatter.dealLinkedTypeText' }" />
                        <ObjectNumber number="{ path: 'ctrDet>quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
                        <ObjectNumber number="{ path: 'ctrDet>avg_entry_price', formatter: 'formatter.priceFourDecimals' }" />
                        <Text text="{ctrDet>currency}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>

              <MessageStrip text="{i18n>noLinkedOrders}" type="Information"
                visible="{= !${ctrDet>/_allOrders} || ${ctrDet>/_allOrders}.length === 0 }"
                class="sapUiSmallMargin" />
            </uxap:blocks>
          </uxap:ObjectPageSubSection>

        </uxap:subSections>
      </uxap:ObjectPageSection>

    </uxap:sections>

  </uxap:ObjectPageLayout>
</mvc:View>
