<mvc:View
  controllerName="hedgecontrol.controller.NotFound"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m">
  <Page
    title="{i18n>notFoundTitle}"
    showNavButton="true"
    navButtonPress=".onNavBack"
    class="sapUiResponsiveContentPadding">
    <content>
      <IllustratedMessage
        title="{i18n>notFoundTitle}"
        description="{i18n>notFoundDescription}"
        illustrationType="sapIllus-PageNotFound"
        illustrationSize="Auto">
        <additionalContent>
          <Button text="{i18n>notFoundBackHome}" press=".onNavBack" type="Emphasized" />
        </additionalContent>
      </IllustratedMessage>
    </content>
  </Page>
</mvc:View>
