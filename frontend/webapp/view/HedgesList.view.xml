<mvc:View
  controllerName="hedgecontrol.controller.HedgesList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="hedgesListPage" showFooter="false" busy="{hdg>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>hedgesTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newHedge}" icon="sap-icon://add" press=".onCreateHedge" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="20rem" search=".onSearch" placeholder="{i18n>search}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox>
        <MessageStrip
          text="{hdg>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${hdg>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <List id="hedgesList" items="{hdg>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" selectionChange=".onHedgeSelect">
          <items>
            <ObjectListItem
              title="{hdg>reference}"
              intro="{path: 'hdg>commodity', formatter: 'formatter.capitalize'}"
              type="Navigation"
              number="{path: 'hdg>tons', formatter: 'formatter.numberTwoDecimals'}"
              numberUnit="MT"
              icon="{= ${hdg>direction} === 'buy' ? 'sap-icon://cart-approval' : 'sap-icon://cart'}">
              <attributes>
                <ObjectAttribute text="{path: 'hdg>direction', formatter: 'formatter.capitalize'}" />
                <ObjectAttribute text="{i18n>colPricePerTon}: {path: 'hdg>price_per_ton', formatter: 'formatter.priceFourDecimals'}" />
                <ObjectAttribute text="{i18n>colSettlementDate}: {path: 'hdg>settlement_date', formatter: 'formatter.dateDisplay'}" />
              </attributes>
              <firstStatus>
                <ObjectStatus text="{path: 'hdg>status', formatter: 'formatter.capitalize'}"
                  state="{path: 'hdg>status', formatter: 'formatter.statusState'}" />
              </firstStatus>
            </ObjectListItem>
          </items>
        </List>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
