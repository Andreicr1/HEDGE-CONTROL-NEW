<mvc:View
  controllerName="hedgecontrol.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:tnt="sap.tnt"
  xmlns:f="sap.f"
  displayBlock="true">
  <tnt:ToolPage id="toolPage" sideExpanded="true">
    <tnt:header>
      <f:ShellBar
        id="appShellBar"
        title="{i18n>headerTitle}"
        secondTitle="{i18n>headerSecondTitle}"
        homeIcon="images/3e08f7a5932f9da5a3e3ae48c3f051b3899ace69.png"
        homeIconTooltip="{i18n>headerHomeTooltip}"
        showMenuButton="true"
        showNavButton="true"
        showNotifications="true"
        notificationsNumber="{app>/notificationsCount}"
        showProductSwitcher="false"
        showSearch="false"
        menuButtonPressed=".onMenuButtonPressed"
        navButtonPressed=".onNavButtonPressed"
        notificationsPressed=".onNotificationsPressed"
        avatarPressed=".onAvatarPressed"
        homeIconPressed=".onHomeIconPressed">
        <f:searchManager>
          <f:SearchManager
            id="shellSearchManager"
            placeholder="{i18n>search}"
            search=".onShellSearch" />
        </f:searchManager>
        <f:profile>
          <Avatar
            id="shellAvatar"
            initials="{app>/userInitials}"
            displaySize="XS"
            displayShape="Circle"
            backgroundColor="Accent6" />
        </f:profile>
        <f:menu>
          <Menu id="shellTitleMenu">
            <MenuItem text="{i18n>navOverview}" icon="sap-icon://home" press=".onTitleMenuAction" />
            <MenuItem text="{i18n>navExposures}" icon="sap-icon://product" press=".onTitleMenuAction" />
            <MenuItem text="{i18n>navComercial}" icon="sap-icon://customer-and-supplier" press=".onTitleMenuAction" />
            <MenuItem text="{i18n>navRfq}" icon="sap-icon://request" press=".onTitleMenuAction" />
            <MenuItem text="{i18n>navContracts}" icon="sap-icon://document" press=".onTitleMenuAction" />
          </Menu>
        </f:menu>
        <f:additionalContent>
          <OverflowToolbarButton
            icon="sap-icon://sys-help"
            tooltip="{i18n>headerHelp}"
            type="Transparent"
            press=".onHelpPressed" />
        </f:additionalContent>
      </f:ShellBar>
    </tnt:header>
    <tnt:sideContent>
      <tnt:SideNavigation id="sideNavigation" selectedKey="{app>/selectedKey}" itemSelect=".onNavigationItemSelect">
        <tnt:item>
          <tnt:NavigationList>
            <!-- Home -->
            <tnt:NavigationListItem key="home" text="{i18n>navOverview}" icon="sap-icon://home" />
            <!-- Operações (Trading) -->
            <tnt:NavigationListItem text="{i18n>navGroupTrading}" icon="sap-icon://batch-payments" expanded="true">
              <tnt:NavigationListItem key="exposures" text="{i18n>navExposures}" />
              <tnt:NavigationListItem key="orders" text="{i18n>navComercial}" />
              <tnt:NavigationListItem key="rfq" text="{i18n>navRfq}" />
              <tnt:NavigationListItem key="contracts" text="{i18n>navContracts}" />
              <tnt:NavigationListItem key="counterparties" text="{i18n>navCounterparties}" />
            </tnt:NavigationListItem>
            <!-- Análises (Analytics) -->
            <tnt:NavigationListItem text="{i18n>navGroupAnalytics}" icon="sap-icon://area-chart" expanded="true">
              <tnt:NavigationListItem key="cashflow" text="{i18n>navCashflow}" />
              <tnt:NavigationListItem key="pnl" text="{i18n>navPnl}" />
              <tnt:NavigationListItem key="mtm" text="{i18n>navMtm}" />
            </tnt:NavigationListItem>
          </tnt:NavigationList>
        </tnt:item>
        <tnt:fixedItem>
          <tnt:NavigationList>
            <tnt:NavigationListItem key="auditTrail" text="{i18n>navAudit}" icon="sap-icon://inspect" />
            <tnt:NavigationListItem key="marketData" text="{i18n>navMarketData}" icon="sap-icon://database" />
          </tnt:NavigationList>
        </tnt:fixedItem>
      </tnt:SideNavigation>
    </tnt:sideContent>
    <tnt:mainContents>
      <f:FlexibleColumnLayout id="fcl" layout="{app>/layout}" />
    </tnt:mainContents>
  </tnt:ToolPage>
</mvc:View>
