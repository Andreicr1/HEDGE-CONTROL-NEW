<mvc:View
  controllerName="hedgecontrol.controller.Scenario"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:layout="sap.ui.layout"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="scenarioPage" headerExpanded="true" showFooter="true">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>scenarioTitle}" />
        </f:heading>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">

        <!-- Period Parameters -->
        <Panel headerText="{i18n>parameters}">
          <form:Form editable="true">
            <form:layout>
              <form:ColumnLayout columnsM="3" columnsL="3" columnsXL="3" />
            </form:layout>
            <form:formContainers>
              <form:FormContainer>
                <form:formElements>
                  <form:FormElement label="{i18n>asOfDate}">
                    <DatePicker id="scenAsOfDate" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd"
                      value="{scen>/as_of_date}" placeholder="dd/MM/yyyy" />
                  </form:FormElement>
                  <form:FormElement label="{i18n>periodStart}">
                    <DatePicker id="scenPeriodStart" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd"
                      value="{scen>/period_start}" placeholder="dd/MM/yyyy" />
                  </form:FormElement>
                  <form:FormElement label="{i18n>periodEnd}">
                    <DatePicker id="scenPeriodEnd" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd"
                      value="{scen>/period_end}" placeholder="dd/MM/yyyy" />
                  </form:FormElement>
                </form:formElements>
              </form:FormContainer>
            </form:formContainers>
          </form:Form>
        </Panel>

        <!-- Deltas -->
        <Panel headerText="{i18n>deltas}" class="sapUiSmallMarginTop">
          <Toolbar>
            <ToolbarSpacer />
            <MenuButton text="{i18n>addDelta}" icon="sap-icon://add" type="Emphasized">
              <menu>
                <Menu>
                  <MenuItem text="{i18n>addUnlinkedHedge}" press=".onAddDeltaHedge" />
                  <MenuItem text="{i18n>adjustOrderQuantity}" press=".onAddDeltaOrder" />
                  <MenuItem text="{i18n>addPriceOverride}" press=".onAddDeltaPrice" />
                </Menu>
              </menu>
            </MenuButton>
          </Toolbar>

          <Table items="{scen>/deltas}" noDataText="{i18n>noDeltas}">
            <columns>
              <Column><header><Text text="{i18n>deltaType}" /></header></Column>
              <Column><header><Text text="{i18n>details}" /></header></Column>
              <Column width="4rem"><header><Text text="" /></header></Column>
            </columns>
            <items>
              <ColumnListItem>
                <Text text="{scen>delta_type}" />
                <Text text="{scen>_summary}" />
                <Button icon="sap-icon://delete" type="Transparent" press=".onRemoveDelta" />
              </ColumnListItem>
            </items>
          </Table>
        </Panel>

        <!-- Results -->
        <Panel headerText="{i18n>results}" visible="{scen>/hasResults}" class="sapUiSmallMarginTop">
          <IconTabBar class="sapUiNoContentPadding">
            <items>

              <IconTabFilter text="{i18n>commercialExposure}" key="comm" icon="sap-icon://shipping-status">
                <form:Form editable="false">
                  <form:layout>
                    <form:ColumnLayout columnsM="2" columnsL="2" columnsXL="2" />
                  </form:layout>
                  <form:formContainers>
                    <form:FormContainer>
                      <form:formElements>
                        <form:FormElement label="{i18n>commodity}">
                          <Text text="{scen>/results/commercial_exposure_snapshot/commodity}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>direction}">
                          <Text text="{scen>/results/commercial_exposure_snapshot/direction}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>quantityMt}">
                          <ObjectNumber number="{ path: 'scen>/results/commercial_exposure_snapshot/quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                  </form:formContainers>
                </form:Form>
              </IconTabFilter>

              <IconTabFilter text="{i18n>globalExposure}" key="glob" icon="sap-icon://world">
                <form:Form editable="false">
                  <form:layout>
                    <form:ColumnLayout columnsM="2" columnsL="2" columnsXL="2" />
                  </form:layout>
                  <form:formContainers>
                    <form:FormContainer>
                      <form:formElements>
                        <form:FormElement label="{i18n>commodity}">
                          <Text text="{scen>/results/global_exposure_snapshot/commodity}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>netPosition}">
                          <ObjectNumber number="{ path: 'scen>/results/global_exposure_snapshot/net_position', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>hedgeRatio}">
                          <Text text="{ path: 'scen>/results/global_exposure_snapshot/hedge_ratio', formatter: 'formatter.numberTwoDecimals' }" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                  </form:formContainers>
                </form:Form>
              </IconTabFilter>

              <IconTabFilter text="{i18n>mtm}" key="mtm" icon="sap-icon://line-chart">
                <Table items="{scen>/results/mtm_snapshot}" noDataText="{i18n>noData}">
                  <columns>
                    <Column><header><Text text="{i18n>objectType}" /></header></Column>
                    <Column><header><Text text="{i18n>objectId}" /></header></Column>
                    <Column><header><Text text="{i18n>mtmValue}" /></header></Column>
                    <Column><header><Text text="{i18n>priceD1}" /></header></Column>
                    <Column><header><Text text="{i18n>entryPrice}" /></header></Column>
                    <Column><header><Text text="{i18n>quantityMt}" /></header></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <Text text="{scen>object_type}" />
                      <Text text="{ path: 'scen>object_id', formatter: 'formatter.shortUuid' }" />
                      <ObjectNumber number="{ path: 'scen>mtm_value', formatter: 'formatter.numberTwoDecimals' }" unit="USD" />
                      <ObjectNumber number="{ path: 'scen>price_d1', formatter: 'formatter.priceFourDecimals' }" />
                      <ObjectNumber number="{ path: 'scen>entry_price', formatter: 'formatter.priceFourDecimals' }" />
                      <ObjectNumber number="{ path: 'scen>quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
                    </ColumnListItem>
                  </items>
                </Table>
              </IconTabFilter>

              <IconTabFilter text="{i18n>pnl}" key="pl" icon="sap-icon://money-bills">
                <Table items="{scen>/results/pl_snapshot}" noDataText="{i18n>noData}">
                  <columns>
                    <Column><header><Text text="{i18n>entityType}" /></header></Column>
                    <Column><header><Text text="{i18n>entityId}" /></header></Column>
                    <Column><header><Text text="{i18n>periodStart}" /></header></Column>
                    <Column><header><Text text="{i18n>periodEnd}" /></header></Column>
                    <Column><header><Text text="{i18n>realizedPl}" /></header></Column>
                    <Column><header><Text text="{i18n>unrealizedMtm}" /></header></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <Text text="{scen>entity_type}" />
                      <Text text="{ path: 'scen>entity_id', formatter: 'formatter.shortUuid' }" />
                      <Text text="{ path: 'scen>period_start', formatter: 'formatter.dateDisplay' }" />
                      <Text text="{ path: 'scen>period_end', formatter: 'formatter.dateDisplay' }" />
                      <ObjectNumber number="{ path: 'scen>realized_pl', formatter: 'formatter.numberTwoDecimals' }" unit="USD" />
                      <ObjectNumber number="{ path: 'scen>unrealized_mtm', formatter: 'formatter.numberTwoDecimals' }" unit="USD" />
                    </ColumnListItem>
                  </items>
                </Table>
              </IconTabFilter>

              <IconTabFilter text="{i18n>cashflow}" key="cf" icon="sap-icon://money-bills">
                <VBox>
                  <Panel headerText="{i18n>analytic}">
                    <ObjectNumber number="{ path: 'scen>/results/cashflow_snapshot/analytic/total_net_cashflow', formatter: 'formatter.numberTwoDecimals' }" unit="USD" />
                  </Panel>
                  <Panel headerText="{i18n>baseline}">
                    <ObjectNumber number="{ path: 'scen>/results/cashflow_snapshot/baseline/total_net_cashflow', formatter: 'formatter.numberTwoDecimals' }" unit="USD" />
                  </Panel>
                </VBox>
              </IconTabFilter>

            </items>
          </IconTabBar>
        </Panel>

      </VBox>
    </f:content>

    <f:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="{i18n>runWhatIf}" type="Emphasized" icon="sap-icon://simulate" press=".onRunWhatIf" />
      </OverflowToolbar>
    </f:footer>

  </f:DynamicPage>
</mvc:View>
