<mvc:View
  controllerName="hedgecontrol.controller.RfqList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="rfqListPage" showFooter="false" busy="{rfq>/busy}"
    class="sapUiResponsivePadding--header sapUiResponsivePadding--content">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>rfqTitle}" level="H3" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newRfq}" icon="sap-icon://add" press=".onCreateRfq" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" type="Transparent" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <SearchField
          placeholder="{i18n>search}"
          liveChange=".onSearch"
          search=".onSearch"
          width="100%" />
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox>
        <MessageStrip
          text="{rfq>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${rfq>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <List id="rfqTable" items="{rfq>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" selectionChange=".onRfqSelect">
          <items>
            <ObjectListItem
              title="{rfq>rfq_number}"
              type="Navigation"
              number="{rfq>quantity_mt}"
              numberUnit="MT">
              <attributes>
                <ObjectAttribute text="{rfq>commodity}" />
                <ObjectAttribute text="{ path: 'rfq>created_at', formatter: 'formatter.dateDisplay' }" />
              </attributes>
              <firstStatus>
                <ObjectStatus text="{rfq>state}"
                  state="{= ${rfq>state} === 'AWARDED' ? 'Success' : (${rfq>state} === 'CLOSED' ? 'None' : 'Information')}" />
              </firstStatus>
            </ObjectListItem>
          </items>
        </List>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
