<mvc:View
  controllerName="hedgecontrol.controller.RfqList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="rfqListPage" showFooter="false" busy="{rfq>/busy}"
    class="sapUiResponsivePadding--header sapUiResponsivePadding--content">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>rfqTitle}" level="H3" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newRfq}" icon="sap-icon://add" press=".onCreateRfq" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" type="Transparent" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <SearchField
          placeholder="{i18n>search}"
          liveChange=".onSearch"
          search=".onSearch"
          width="100%" />
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox>
        <MessageStrip
          text="{rfq>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${rfq>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <Table id="rfqTable" items="{rfq>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" selectionChange=".onRfqSelect">
          <columns>
            <Column width="8rem"><header><Text text="{i18n>colRfqNumber}" /></header></Column>
            <Column><header><Text text="{i18n>colCommodity}" /></header></Column>
            <Column><header><Text text="{i18n>colDirection}" /></header></Column>
            <Column hAlign="End"><header><Text text="{i18n>colQuantityMt}" /></header></Column>
            <Column><header><Text text="{i18n>colState}" /></header></Column>
            <Column><header><Text text="{i18n>colCreatedAt}" /></header></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{rfq>rfq_number}" />
                <Text text="{rfq>commodity}" />
                <ObjectStatus text="{rfq>direction}" state="{= ${rfq>direction} === 'BUY' ? 'Success' : 'Error'}" />
                <Text text="{path: 'rfq>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" />
                <ObjectStatus text="{rfq>state}" state="{path: 'rfq>state', formatter: 'formatter.statusState'}" />
                <Text text="{path: 'rfq>created_at', formatter: 'formatter.dateTimeDisplay'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
