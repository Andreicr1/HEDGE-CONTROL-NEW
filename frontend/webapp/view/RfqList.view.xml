<mvc:View
  controllerName="hedgecontrol.controller.RfqList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="rfqListPage" showFooter="false" busy="{rfq>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>rfqTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newRfq}" icon="sap-icon://add" press=".onCreateRfq" type="Emphasized" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="100%" search=".onSearch" liveChange=".onSearch" placeholder="{i18n>search}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox>
        <MessageStrip
          text="{rfq>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${rfq>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <List id="rfqTable"
          items="{ path: 'rfq>/items', sorter: { path: 'created_at', descending: true } }"
          growing="true"
          growingThreshold="50"
          mode="SingleSelectMaster"
          itemPress=".onRfqSelect"
          noDataText="{i18n>noData}">
          <items>
            <ObjectListItem
              title="{rfq>commodity} — {rfq>direction}"
              intro="{rfq>rfq_number}"
              type="Navigation"
              number="{path: 'rfq>quantity_mt', formatter: 'formatter.numberTwoDecimals'}"
              numberUnit="MT"
              icon="sap-icon://request">
              <attributes>
                <ObjectAttribute text="{i18n>colIntent}: {rfq>intent}" />
                <ObjectAttribute text="{path: 'rfq>created_at', formatter: 'formatter.dateTimeDisplay'}" />
              </attributes>
              <firstStatus>
                <ObjectStatus text="{rfq>state}"
                  state="{path: 'rfq>state', formatter: 'formatter.statusState'}" />
              </firstStatus>
            </ObjectListItem>
          </items>
        </List>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
