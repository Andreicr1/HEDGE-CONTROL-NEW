<mvc:View
  controllerName="hedgecontrol.controller.RfqList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="rfqListPage" showFooter="false" busy="{rfq>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>rfqTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newRfq}" icon="sap-icon://add" press=".onCreateRfq" type="Emphasized" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox>
        <MessageStrip
          text="{rfq>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${rfq>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <Table id="rfqTable"
          items="{ path: 'rfq>/items', sorter: { path: 'created_at', descending: true } }"
          growing="true"
          growingThreshold="50"
          mode="SingleSelectMaster"
          itemPress=".onRfqSelect">
          <noData>
            <IllustratedMessage illustrationType="sapIllus-EmptyList"
                title="{i18n>emptyStateTitle}" description="{i18n>emptyStateDescription}" />
          </noData>
          <headerToolbar>
            <OverflowToolbar>
              <Title text="{i18n>rfqTitle}" level="H3" />
              <ToolbarSpacer />
              <SearchField width="15rem" search=".onSearch" liveChange=".onSearch" placeholder="{i18n>search}" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column><Text text="{i18n>colRfqNumber}" /></Column>
            <Column><Text text="{i18n>colCommodity}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colDirection}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colQuantityMt}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colIntent}" /></Column>
            <Column><Text text="{i18n>colState}" /></Column>
            <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCreatedAt}" /></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{rfq>rfq_number}" />
                <Text text="{path: 'rfq>commodity', formatter: 'formatter.capitalize'}" />
                <Text text="{rfq>direction}" />
                <ObjectNumber number="{path: 'rfq>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
                <Text text="{rfq>intent}" />
                <ObjectStatus text="{rfq>state}"
                  state="{path: 'rfq>state', formatter: 'formatter.statusState'}" />
                <Text text="{path: 'rfq>created_at', formatter: 'formatter.dateTimeDisplay'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
