<mvc:View
  controllerName="hedgecontrol.controller.RfqCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  xmlns:l="sap.ui.layout"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="rfqCreatePage" showFooter="true" busy="{rfqCrt>/busy}">

    <!-- ===== Title Bar ===== -->
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="Criar RFQ" />
        </f:heading>
        <f:navigationActions>
          <Button icon="sap-icon://nav-back" press=".onCancel" tooltip="Voltar" type="Transparent" />
        </f:navigationActions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">

        <MessageStrip
          text="{rfqCrt>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${rfqCrt>/errorMessage}}"
          class="sapUiSmallMarginBottom" />

        <!-- ===== Card 1 — Trade Setup ===== -->
        <Panel headerText="Trade Setup" class="sapUiSmallMarginBottom">

          <!-- Global fields -->
          <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="2">
            <Label text="Empresa" required="true" />
            <RadioButtonGroup id="rbCompany" selectedIndex="{rfqCrt>/companyIndex}" columns="2">
              <RadioButton text="Alcast Brasil" />
              <RadioButton text="Alcast Trading" />
            </RadioButtonGroup>

            <Label text="Commodity" required="true" />
            <Select selectedKey="{rfqCrt>/commodity}">
              <core:Item key="Aluminium" text="Aluminium" />
              <core:Item key="Copper" text="Copper" />
              <core:Item key="Zinc" text="Zinc" />
              <core:Item key="Nickel" text="Nickel" />
              <core:Item key="Lead" text="Lead" />
              <core:Item key="Tin" text="Tin" />
            </Select>

            <Label text="Intenção" required="true" />
            <Select selectedKey="{rfqCrt>/intent}" change=".onIntentChange">
              <core:Item key="GLOBAL_POSITION" text="Posição Global" />
              <core:Item key="COMMERCIAL_HEDGE" text="Hedge Comercial" />
            </Select>
          </form:SimpleForm>

          <!-- Order selector for Commercial Hedge -->
          <VBox visible="{= ${rfqCrt>/intent} === 'COMMERCIAL_HEDGE'}" class="sapUiSmallMargin">
            <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="2">
              <Label text="Ordem (PO / SO)" required="true" />
              <Select id="selOrder" selectedKey="{rfqCrt>/orderId}" change=".onOrderChange"
                items="{rfqCrt>/orders}">
                <core:Item key="{rfqCrt>key}" text="{rfqCrt>text}" />
              </Select>
            </form:SimpleForm>
            <MessageStrip
              text="Exposição: {rfqCrt>/exposureOriginal} MT total · {rfqCrt>/exposureOpen} MT em aberto ({rfqCrt>/exposureCommodity})"
              type="Information" showIcon="true"
              visible="{= !!${rfqCrt>/exposureOpen}}"
              class="sapUiSmallMarginTop" />
          </VBox>

          <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="2">
            <Label text="Tipo de Trade" required="true" />
            <Select id="selTradeType" selectedKey="{rfqCrt>/tradeType}" change=".onTradeTypeChange">
              <core:Item key="Swap" text="Swap" />
              <core:Item key="Forward" text="Forward" />
            </Select>

            <Label text="Quantidade (MT)" required="true" />
            <Input value="{rfqCrt>/quantity}" type="Number" placeholder="0"
              description="{= ${rfqCrt>/exposureOpen} ? 'Máx: ' + ${rfqCrt>/exposureOpen} + ' MT' : ''}" />
          </form:SimpleForm>

          <!-- Dynamic trade cards -->
          <VBox id="tradesContainer" items="{rfqCrt>/trades}" class="sapUiSmallMarginTop">
            <Panel class="sapUiTinyMarginBottom">
              <headerToolbar>
                <OverflowToolbar>
                  <Title text="{rfqCrt>title}" level="H4" />
                  <ToolbarSpacer />
                  <Button text="Queda" icon="sap-icon://trend-down" press=".onTemplateQueda" type="Ghost"
                    tooltip="Proteção de Queda: Buy AVG + Sell Fix" />
                  <Button text="Alta" icon="sap-icon://trend-up" press=".onTemplateAlta" type="Ghost"
                    tooltip="Proteção de Alta: Sell AVG + Buy Fix" />
                  <Button text="Spread" icon="sap-icon://overlay" press=".onTemplateSpread" type="Ghost"
                    tooltip="Spread: Buy AVG + Sell AVG" />
                  <ToolbarSeparator />
                  <Button icon="sap-icon://delete" press=".onRemoveTrade" type="Reject"
                    tooltip="Remover Trade"
                    visible="{= ${rfqCrt>index} > 0}" />
                </OverflowToolbar>
              </headerToolbar>
              <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="2">

                <!-- ——— Leg 1 ——— -->
                <core:Title text="Leg 1" />

                <Label text="Side" required="true" />
                <RadioButtonGroup selectedIndex="{rfqCrt>leg1/sideIndex}" select=".onSide1Change" columns="2">
                  <RadioButton text="Compra" />
                  <RadioButton text="Venda" />
                </RadioButtonGroup>

                <Label text="Price Type" required="true" />
                <Select selectedKey="{rfqCrt>leg1/priceType}" change=".onPriceType1Change">
                  <core:Item key="" text="Selecione..." />
                  <core:Item key="AVG" text="AVG" />
                  <core:Item key="AVGInter" text="AVG Period" />
                  <core:Item key="Fix" text="Fix" />
                  <core:Item key="C2R" text="C2R" />
                </Select>

                <!-- AVG: Month / Year -->
                <Label text="Mês" required="true"
                  visible="{= ${rfqCrt>leg1/priceType} === 'AVG'}" />
                <Select selectedKey="{rfqCrt>leg1/monthName}"
                  visible="{= ${rfqCrt>leg1/priceType} === 'AVG'}" change=".onMonth1Change">
                  <core:Item key="January" text="January" />
                  <core:Item key="February" text="February" />
                  <core:Item key="March" text="March" />
                  <core:Item key="April" text="April" />
                  <core:Item key="May" text="May" />
                  <core:Item key="June" text="June" />
                  <core:Item key="July" text="July" />
                  <core:Item key="August" text="August" />
                  <core:Item key="September" text="September" />
                  <core:Item key="October" text="October" />
                  <core:Item key="November" text="November" />
                  <core:Item key="December" text="December" />
                </Select>

                <Label text="Ano" required="true"
                  visible="{= ${rfqCrt>leg1/priceType} === 'AVG'}" />
                <Select selectedKey="{rfqCrt>leg1/year}"
                  visible="{= ${rfqCrt>leg1/priceType} === 'AVG'}" change=".onYear1Change"
                  items="{ path: 'rfqCrt>/yearItems', templateShareable: true }">
                  <core:Item key="{rfqCrt>key}" text="{rfqCrt>text}" />
                </Select>

                <!-- AVGInter: Start / End Date -->
                <Label text="Data Início" required="true"
                  visible="{= ${rfqCrt>leg1/priceType} === 'AVGInter'}" />
                <DatePicker value="{rfqCrt>leg1/startDate}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
                  visible="{= ${rfqCrt>leg1/priceType} === 'AVGInter'}" />

                <Label text="Data Fim" required="true"
                  visible="{= ${rfqCrt>leg1/priceType} === 'AVGInter'}" />
                <DatePicker value="{rfqCrt>leg1/endDate}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
                  visible="{= ${rfqCrt>leg1/priceType} === 'AVGInter'}" />

                <!-- Fix / C2R: Fixing Date (read-only, auto-calculated) -->
                <Label text="Fixing Date"
                  visible="{= ${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R'}" />
                <DatePicker value="{rfqCrt>leg1/fixingDate}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
                  enabled="false"
                  visible="{= ${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R'}" />

                <!-- Fix / C2R: Settlement Date (display only) -->
                <Label text="Settlement Date"
                  visible="{= ${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R'}" />
                <Text text="{rfqCrt>leg1/settlementDate}"
                  visible="{= ${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R'}" />

                <!-- Fix / C2R: Order Type -->
                <Label text="Tipo de Ordem"
                  visible="{= ${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R'}" />
                <Select selectedKey="{rfqCrt>leg1/orderType}"
                  visible="{= ${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R'}">
                  <core:Item key="At Market" text="At Market" />
                  <core:Item key="Limit" text="Limit" />
                  <core:Item key="Resting" text="Resting" />
                </Select>

                <!-- Order Validity -->
                <Label text="Validade da Ordem"
                  visible="{= (${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R') &amp;&amp; ${rfqCrt>leg1/orderType} !== '' &amp;&amp; ${rfqCrt>leg1/orderType} !== 'At Market'}" />
                <Select selectedKey="{rfqCrt>leg1/orderValidity}"
                  visible="{= (${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R') &amp;&amp; ${rfqCrt>leg1/orderType} !== '' &amp;&amp; ${rfqCrt>leg1/orderType} !== 'At Market'}">
                  <core:Item key="Day" text="Day" />
                  <core:Item key="GTC" text="GTC" />
                  <core:Item key="3 Hours" text="3 Hours" />
                  <core:Item key="6 Hours" text="6 Hours" />
                  <core:Item key="12 Hours" text="12 Hours" />
                  <core:Item key="Until Further Notice" text="Until Further Notice" />
                </Select>

                <!-- Limit Price -->
                <Label text="Preço Limite"
                  visible="{= (${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R') &amp;&amp; ${rfqCrt>leg1/orderType} === 'Limit'}" />
                <Input value="{rfqCrt>leg1/limitPrice}" type="Number" placeholder="USD"
                  visible="{= (${rfqCrt>leg1/priceType} === 'Fix' || ${rfqCrt>leg1/priceType} === 'C2R') &amp;&amp; ${rfqCrt>leg1/orderType} === 'Limit'}" />

              </form:SimpleForm>

              <!-- ——— Leg 2 (visible only for Swap) ——— -->
              <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="2"
                visible="{= ${rfqCrt>/tradeType} === 'Swap'}">
                <core:Title text="Leg 2" />

                <Label text="Side" required="true" />
                <RadioButtonGroup selectedIndex="{rfqCrt>leg2/sideIndex}" select=".onSide2Change" columns="2">
                  <RadioButton text="Compra" />
                  <RadioButton text="Venda" />
                </RadioButtonGroup>

                <Label text="Price Type" required="true" />
                <Select selectedKey="{rfqCrt>leg2/priceType}" change=".onPriceType2Change">
                  <core:Item key="" text="Selecione..." />
                  <core:Item key="AVG" text="AVG" />
                  <core:Item key="AVGInter" text="AVG Period" />
                  <core:Item key="Fix" text="Fix" />
                  <core:Item key="C2R" text="C2R" />
                </Select>

                <!-- Leg 2 AVG: Month / Year -->
                <Label text="Mês" required="true"
                  visible="{= ${rfqCrt>leg2/priceType} === 'AVG'}" />
                <Select selectedKey="{rfqCrt>leg2/monthName}"
                  visible="{= ${rfqCrt>leg2/priceType} === 'AVG'}" change=".onMonth2Change">
                  <core:Item key="January" text="January" />
                  <core:Item key="February" text="February" />
                  <core:Item key="March" text="March" />
                  <core:Item key="April" text="April" />
                  <core:Item key="May" text="May" />
                  <core:Item key="June" text="June" />
                  <core:Item key="July" text="July" />
                  <core:Item key="August" text="August" />
                  <core:Item key="September" text="September" />
                  <core:Item key="October" text="October" />
                  <core:Item key="November" text="November" />
                  <core:Item key="December" text="December" />
                </Select>

                <Label text="Ano" required="true"
                  visible="{= ${rfqCrt>leg2/priceType} === 'AVG'}" />
                <Select selectedKey="{rfqCrt>leg2/year}"
                  visible="{= ${rfqCrt>leg2/priceType} === 'AVG'}" change=".onYear2Change"
                  items="{ path: 'rfqCrt>/yearItems', templateShareable: true }">
                  <core:Item key="{rfqCrt>key}" text="{rfqCrt>text}" />
                </Select>

                <!-- Leg 2 AVGInter: Start / End Date -->
                <Label text="Data Início" required="true"
                  visible="{= ${rfqCrt>leg2/priceType} === 'AVGInter'}" />
                <DatePicker value="{rfqCrt>leg2/startDate}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
                  visible="{= ${rfqCrt>leg2/priceType} === 'AVGInter'}" />

                <Label text="Data Fim" required="true"
                  visible="{= ${rfqCrt>leg2/priceType} === 'AVGInter'}" />
                <DatePicker value="{rfqCrt>leg2/endDate}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
                  visible="{= ${rfqCrt>leg2/priceType} === 'AVGInter'}" />

                <!-- Leg 2 Fix / C2R: Fixing Date (read-only) -->
                <Label text="Fixing Date"
                  visible="{= ${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R'}" />
                <DatePicker value="{rfqCrt>leg2/fixingDate}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy"
                  enabled="false"
                  visible="{= ${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R'}" />

                <!-- Leg 2 Fix / C2R: Settlement Date (display only) -->
                <Label text="Settlement Date"
                  visible="{= ${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R'}" />
                <Text text="{rfqCrt>leg2/settlementDate}"
                  visible="{= ${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R'}" />

                <!-- Leg 2 Fix / C2R: Order Type -->
                <Label text="Tipo de Ordem"
                  visible="{= ${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R'}" />
                <Select selectedKey="{rfqCrt>leg2/orderType}"
                  visible="{= ${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R'}">
                  <core:Item key="At Market" text="At Market" />
                  <core:Item key="Limit" text="Limit" />
                  <core:Item key="Resting" text="Resting" />
                </Select>

                <!-- Leg 2 Order Validity -->
                <Label text="Validade da Ordem"
                  visible="{= (${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R') &amp;&amp; ${rfqCrt>leg2/orderType} !== '' &amp;&amp; ${rfqCrt>leg2/orderType} !== 'At Market'}" />
                <Select selectedKey="{rfqCrt>leg2/orderValidity}"
                  visible="{= (${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R') &amp;&amp; ${rfqCrt>leg2/orderType} !== '' &amp;&amp; ${rfqCrt>leg2/orderType} !== 'At Market'}">
                  <core:Item key="Day" text="Day" />
                  <core:Item key="GTC" text="GTC" />
                  <core:Item key="3 Hours" text="3 Hours" />
                  <core:Item key="6 Hours" text="6 Hours" />
                  <core:Item key="12 Hours" text="12 Hours" />
                  <core:Item key="Until Further Notice" text="Until Further Notice" />
                </Select>

                <!-- Leg 2 Limit Price -->
                <Label text="Preço Limite"
                  visible="{= (${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R') &amp;&amp; ${rfqCrt>leg2/orderType} === 'Limit'}" />
                <Input value="{rfqCrt>leg2/limitPrice}" type="Number" placeholder="USD"
                  visible="{= (${rfqCrt>leg2/priceType} === 'Fix' || ${rfqCrt>leg2/priceType} === 'C2R') &amp;&amp; ${rfqCrt>leg2/orderType} === 'Limit'}" />

              </form:SimpleForm>
            </Panel>
          </VBox>

          <!-- Trade actions toolbar -->
          <OverflowToolbar class="sapUiSmallMarginTop">
            <Button text="Novo Trade" icon="sap-icon://add" press=".onAddTrade" type="Ghost" />
            <ToolbarSpacer />
            <Button text="Gerar Texto RFQ" press=".onGenerate" type="Emphasized" icon="sap-icon://create-form" />
          </OverflowToolbar>

        </Panel>

        <!-- ===== Card 2 — Text Preview (bilingual) ===== -->
        <Panel headerText="Texto da Cotação" visible="{rfqCrt>/showResult}" class="sapUiSmallMarginBottom">
          <VBox class="sapUiSmallMargin">
            <HBox width="100%">
              <VBox width="50%" class="sapUiSmallMarginEnd">
                <Label text="English (LME)" design="Bold" class="sapUiTinyMarginBottom" />
                <TextArea value="{rfqCrt>/textEn}" rows="12" width="100%" editable="false" growing="true" growingMaxLines="30" />
              </VBox>
              <VBox width="50%">
                <Label text="Português (Banco)" design="Bold" class="sapUiTinyMarginBottom" />
                <TextArea value="{rfqCrt>/textPt}" rows="12" width="100%" editable="false" growing="true" growingMaxLines="30" />
              </VBox>
            </HBox>

            <HBox class="sapUiSmallMarginTop">
              <Button text="Copiar EN" icon="sap-icon://copy" press=".onCopyTextEn" type="Ghost" class="sapUiSmallMarginEnd" />
              <Button text="Copiar PT" icon="sap-icon://copy" press=".onCopyTextPt" type="Ghost" class="sapUiSmallMarginEnd" />
              <Button text="WhatsApp" icon="sap-icon://share-2" press=".onSendWhatsApp" type="Ghost" />
            </HBox>

            <MessageStrip text="{rfqCrt>/pptInfo}" type="Information" showIcon="true"
              visible="{= !!${rfqCrt>/pptInfo}}" class="sapUiSmallMarginTop" />
          </VBox>
        </Panel>

        <!-- ===== Card 3 — Counterparty Selection ===== -->
        <Panel headerText="Contrapartes" class="sapUiSmallMarginBottom">
          <Table items="{rfqCrt>/counterparties}" mode="None" growing="true" growingThreshold="20">
            <columns>
              <Column width="4rem"><Text text="Sel." /></Column>
              <Column><Text text="Nome" /></Column>
              <Column><Text text="Tipo" /></Column>
              <Column><Text text="Idioma RFQ" /></Column>
              <Column><Text text="{i18n>colCountry}" /></Column>
              <Column><Text text="{i18n>colWhatsAppPhone}" /></Column>
            </columns>
            <items>
              <ColumnListItem>
                <cells>
                  <CheckBox selected="{rfqCrt>selected}" select=".onCounterpartySelectionChange" />
                  <Text text="{rfqCrt>name}" />
                  <Text text="{path: 'rfqCrt>type', formatter: 'formatter.counterpartyType'}" />
                  <ObjectStatus
                    text="{= ${rfqCrt>type} === 'bank_br' ? 'Portugu\u00eas' : 'English'}"
                    state="{= ${rfqCrt>type} === 'bank_br' ? 'Information' : 'Success'}" />
                  <Text text="{rfqCrt>country}" />
                  <Text text="{rfqCrt>whatsapp_phone}" />
                </cells>
              </ColumnListItem>
            </items>
          </Table>
          <OverflowToolbar>
            <ToolbarSpacer />
            <ObjectNumber
              number="{rfqCrt>/selectedCount}"
              unit="selecionada(s)"
              state="Information" />
          </OverflowToolbar>
        </Panel>

      </VBox>
    </f:content>

    <!-- ===== Footer ===== -->
    <f:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="Enviar RFQ" press=".onSubmitRfq" type="Emphasized" icon="sap-icon://outgoing-call" />
        <Button text="Cancelar" press=".onCancel" type="Transparent" />
      </OverflowToolbar>
    </f:footer>

  </f:DynamicPage>
</mvc:View>
