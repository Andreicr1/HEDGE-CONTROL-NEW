<mvc:View
  controllerName="hedgecontrol.controller.FinancePipeline"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="financePipelinePage" showFooter="false" busy="{fp>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>pipelineTitle}" />
        </f:heading>
        <f:actions>
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{fp>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${fp>/errorMessage}}"
          class="sapUiSmallMarginBottom" />

        <!-- Trigger Panel -->
        <Panel headerText="{i18n>pipelineTrigger}" expandable="false" class="sapUiSmallMarginBottom">
          <HBox alignItems="End" class="sapUiSmallMargin">
            <VBox class="sapUiSmallMarginEnd">
              <Label text="{i18n>pipelineRunDate}" />
              <DatePicker value="{fp>/runDate}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" placeholder="dd/MM/yyyy" />
            </VBox>
            <Button text="{i18n>pipelineExecute}" icon="sap-icon://play" press=".onTriggerPipeline" type="Emphasized" />
          </HBox>
        </Panel>

        <!-- Runs Table -->
        <Table id="runsTable" items="{fp>/runs}" growing="true" growingThreshold="30"
          noDataText="{i18n>noPipelineRuns}" mode="SingleSelectMaster" selectionChange=".onRunSelect">
          <headerToolbar>
            <OverflowToolbar>
              <Title text="{i18n>pipelineRuns}" level="H3" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column width="8rem"><header><Text text="{i18n>colId}" /></header></Column>
            <Column><header><Text text="{i18n>colRunDate}" /></header></Column>
            <Column width="8rem"><header><Text text="{i18n>colStatus}" /></header></Column>
            <Column width="10rem"><header><Text text="{i18n>colProgress}" /></header></Column>
            <Column><header><Text text="{i18n>colStartedAt}" /></header></Column>
            <Column><header><Text text="{i18n>colFinishedAt}" /></header></Column>
            <Column><header><Text text="{i18n>colError}" /></header></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{path: 'fp>id', formatter: 'formatter.shortUuid'}" />
                <Text text="{path: 'fp>run_date', formatter: 'formatter.dateDisplay'}" />
                <ObjectStatus text="{path: 'fp>status', formatter: 'formatter.capitalize'}"
                  state="{= ${fp>status} === 'completed' ? 'Success' : (${fp>status} === 'running' ? 'Information' : 'Error')}" />
                <ProgressIndicator
                  percentValue="{= ${fp>steps_total} > 0 ? Math.round((${fp>steps_completed} / ${fp>steps_total}) * 100) : 0}"
                  displayValue="{= ${fp>steps_completed} + '/' + ${fp>steps_total}}"
                  state="{= ${fp>status} === 'completed' ? 'Success' : (${fp>status} === 'running' ? 'Information' : 'Error')}"
                  showValue="true" />
                <Text text="{path: 'fp>started_at', formatter: 'formatter.dateTimeDisplay'}" />
                <Text text="{path: 'fp>finished_at', formatter: 'formatter.dateTimeDisplay'}" />
                <Text text="{fp>error_message}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>

        <!-- Run Detail (Steps) -->
        <Panel headerText="{i18n>pipelineSteps}" expandable="false"
          visible="{= !!${fp>/selectedRun}}" class="sapUiSmallMarginTop">
          <VBox class="sapUiSmallMargin">
            <HBox class="sapUiSmallMarginBottom">
              <ObjectStatus text="{path: 'fp>/selectedRun/status', formatter: 'formatter.capitalize'}"
                state="{= ${fp>/selectedRun/status} === 'completed' ? 'Success' : (${fp>/selectedRun/status} === 'running' ? 'Information' : 'Error')}"
                class="sapUiSmallMarginEnd" />
              <Text text="{i18n>pipelineRunDate}: " class="sapUiSmallMarginEnd" />
              <Text text="{path: 'fp>/selectedRun/run_date', formatter: 'formatter.dateDisplay'}" class="sapUiTinyMarginEnd" />
              <ToolbarSpacer />
              <Button icon="sap-icon://decline" press=".onCloseDetail" tooltip="{i18n>close}" type="Transparent" />
            </HBox>
            <Table items="{fp>/selectedRun/steps}" noDataText="{i18n>noSteps}">
              <columns>
                <Column width="3rem" hAlign="Center"><header><Text text="#" /></header></Column>
                <Column><header><Text text="{i18n>colStepName}" /></header></Column>
                <Column width="8rem"><header><Text text="{i18n>colStatus}" /></header></Column>
                <Column hAlign="End"><header><Text text="{i18n>colRecordsProcessed}" /></header></Column>
                <Column><header><Text text="{i18n>colStartedAt}" /></header></Column>
                <Column><header><Text text="{i18n>colFinishedAt}" /></header></Column>
                <Column><header><Text text="{i18n>colError}" /></header></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{fp>step_number}" />
                    <Text text="{fp>step_name}" />
                    <ObjectStatus text="{path: 'fp>status', formatter: 'formatter.capitalize'}"
                      state="{= ${fp>status} === 'completed' ? 'Success' : (${fp>status} === 'running' ? 'Information' : (${fp>status} === 'failed' ? 'Error' : 'None'))}" />
                    <ObjectNumber number="{fp>records_processed}" />
                    <Text text="{path: 'fp>started_at', formatter: 'formatter.dateTimeDisplay'}" />
                    <Text text="{path: 'fp>finished_at', formatter: 'formatter.dateTimeDisplay'}" />
                    <Text text="{fp>error_message}" />
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </VBox>
        </Panel>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
