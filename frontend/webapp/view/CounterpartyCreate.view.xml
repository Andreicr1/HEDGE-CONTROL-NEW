<mvc:View
  controllerName="hedgecontrol.controller.CounterpartyCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">
  <f:DynamicPage id="counterpartyCreatePage" showFooter="true" busy="{cptyCrt>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>newCounterparty}" />
        </f:heading>
        <f:actions>
          <Button icon="sap-icon://decline" press=".onCancel" tooltip="{i18n>cancel}" type="Transparent" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{cptyCrt>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${cptyCrt>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <form:Form id="counterpartyForm" editable="true">
          <form:layout>
            <form:ColumnLayout columnsM="2" columnsL="3" columnsXL="4" />
          </form:layout>
          <form:formContainers>
            <form:FormContainer title="{i18n>sectionIdentification}">
              <form:formElements>
                <form:FormElement label="{i18n>colType}">
                  <form:fields>
                    <Select selectedKey="{cptyCrt>/form/type}">
                      <core:Item key="broker" text="{i18n>typeBroker}" />
                      <core:Item key="bank_br" text="{i18n>typeBankBr}" />
                    </Select>
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colName}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/name}" required="true" placeholder="{i18n>placeholderName}" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colShortName}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/short_name}" placeholder="{i18n>placeholderShortName}" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colTaxId}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/tax_id}" placeholder="{i18n>placeholderTaxId}" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colCountry}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/country}" required="true" maxLength="3" placeholder="{i18n>placeholderCountry}" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colCity}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/city}" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
            <form:FormContainer title="{i18n>sectionContact}">
              <form:formElements>
                <form:FormElement label="{i18n>colContactName}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/contact_name}" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colContactEmail}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/contact_email}" type="Email" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colContactPhone}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/contact_phone}" type="Tel" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colWhatsAppPhone}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/whatsapp_phone}" type="Tel" placeholder="+5511999999999" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
            <form:FormContainer title="{i18n>sectionFinancial}">
              <form:formElements>
                <form:FormElement label="{i18n>colCreditLimit}">
                  <form:fields>
                    <Input value="{cptyCrt>/form/credit_limit_usd}" type="Number" placeholder="0.00" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
            <form:FormContainer title="{i18n>sectionCompliance}">
              <form:formElements>
                <form:FormElement label="{i18n>colKycStatus}">
                  <form:fields>
                    <Select selectedKey="{cptyCrt>/form/kyc_status}">
                      <core:Item key="pending" text="{i18n>kycPending}" />
                      <core:Item key="approved" text="{i18n>kycApproved}" />
                    </Select>
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colRiskRating}">
                  <form:fields>
                    <Select selectedKey="{cptyCrt>/form/risk_rating}">
                      <core:Item key="low" text="{i18n>riskLow}" />
                      <core:Item key="medium" text="{i18n>riskMedium}" />
                      <core:Item key="high" text="{i18n>riskHigh}" />
                    </Select>
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colNotes}">
                  <form:fields>
                    <TextArea value="{cptyCrt>/form/notes}" rows="3" growing="true" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
          </form:formContainers>
        </form:Form>
      </VBox>
    </f:content>
    <f:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="{i18n>submit}" press=".onSubmit" type="Emphasized" />
        <Button text="{i18n>cancel}" press=".onCancel" />
      </OverflowToolbar>
    </f:footer>
  </f:DynamicPage>
</mvc:View>
