<mvc:View
  controllerName="hedgecontrol.controller.Home"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:layout="sap.ui.layout">
  <f:DynamicPage id="homePage" showFooter="false">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>homeTitle}" />
        </f:heading>
        <f:content>
          <ObjectStatus text="{home>/lastRefresh}" state="Information" />
        </f:content>
        <f:actions>
          <Button
            id="homeRefreshBtn"
            icon="sap-icon://refresh"
            tooltip="{i18n>refresh}"
            press=".onRefresh"
            type="Transparent" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">

        <!-- KPI Tiles -->
        <f:GridContainer id="kpiGrid" class="sapUiSmallMarginTop" snapToRow="true">
          <f:layout>
            <f:GridContainerSettings rowSize="5rem" columnSize="16rem" gap="0.5rem" />
          </f:layout>
          <f:layoutS>
            <f:GridContainerSettings rowSize="5rem" columnSize="100%" gap="0.5rem" />
          </f:layoutS>

          <!-- Net Exposure KPI -->
          <GenericTile
            id="kpiExposure"
            header="{i18n>homeKpiNetExposure}"
            subheader="{i18n>homeKpiNetExposureSub}"
            press=".onNavToExposures"
            state="{home>/kpiState}"
            frameType="TwoByOne">
            <tileContent>
              <TileContent unit="MT">
                <content>
                  <NumericContent
                    value="{home>/kpiExposureValue}"
                    scale="{home>/kpiExposureScale}"
                    withMargin="false"
                    valueColor="{home>/kpiExposureColor}" />
                </content>
              </TileContent>
            </tileContent>
          </GenericTile>

          <!-- Orders KPI -->
          <GenericTile
            id="kpiOrders"
            header="{i18n>homeKpiOrders}"
            subheader="{i18n>homeKpiOrdersSub}"
            press=".onNavToOrders"
            state="{home>/kpiState}"
            frameType="OneByOne">
            <tileContent>
              <TileContent>
                <content>
                  <NumericContent
                    value="{home>/kpiOrdersCount}"
                    withMargin="false" />
                </content>
              </TileContent>
            </tileContent>
          </GenericTile>

          <!-- Contracts KPI -->
          <GenericTile
            id="kpiContracts"
            header="{i18n>homeKpiContracts}"
            subheader="{i18n>homeKpiContractsSub}"
            press=".onNavToContracts"
            state="{home>/kpiState}"
            frameType="OneByOne">
            <tileContent>
              <TileContent>
                <content>
                  <NumericContent
                    value="{home>/kpiContractsCount}"
                    withMargin="false" />
                </content>
              </TileContent>
            </tileContent>
          </GenericTile>

          <!-- RFQs KPI -->
          <GenericTile
            id="kpiRfqs"
            header="{i18n>homeKpiRfqs}"
            subheader="{i18n>homeKpiRfqsSub}"
            press=".onNavToRfq"
            state="{home>/kpiState}"
            frameType="OneByOne">
            <tileContent>
              <TileContent>
                <content>
                  <NumericContent
                    value="{home>/kpiRfqsCount}"
                    withMargin="false" />
                </content>
              </TileContent>
            </tileContent>
          </GenericTile>

          <!-- PnL / MTM link tile -->
          <GenericTile
            id="kpiPnl"
            header="{i18n>homeCardPnl}"
            subheader="{i18n>homeCardPnlSub}"
            press=".onNavToPnl"
            frameType="OneByOne">
            <tileContent>
              <TileContent>
                <content>
                  <NumericContent
                    value="{home>/kpiPnlValue}"
                    withMargin="false"
                    valueColor="{home>/kpiPnlColor}" />
                </content>
              </TileContent>
            </tileContent>
          </GenericTile>

          <!-- Cashflow link tile -->
          <GenericTile
            id="kpiCashflow"
            header="{i18n>homeCardCashflow}"
            subheader="{i18n>homeCardCashflowSub}"
            press=".onNavToCashflow"
            frameType="OneByOne">
            <tileContent>
              <TileContent>
                <content>
                  <NumericContent
                    value="{home>/kpiCashflowValue}"
                    withMargin="false" />
                </content>
              </TileContent>
            </tileContent>
          </GenericTile>

        </f:GridContainer>

        <!-- Error strip (hidden by default) -->
        <MessageStrip
          id="homeErrorStrip"
          text="{home>/errorMessage}"
          type="Error"
          showIcon="true"
          visible="{= !!${home>/errorMessage} }"
          class="sapUiSmallMarginTop" />

        <Panel headerText="{i18n>homePlatformInfo}" class="sapUiSmallMarginTop">
          <VBox class="sapUiSmallMargin">
            <Text text="{i18n>homePlatformDescription}" />
          </VBox>
        </Panel>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
