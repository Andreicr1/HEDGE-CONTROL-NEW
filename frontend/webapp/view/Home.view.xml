<mvc:View
  controllerName="hedgecontrol.controller.Home"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:layout="sap.ui.layout">
  <f:DynamicPage id="homePage" showFooter="false">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>homeTitle}" />
        </f:heading>
        <f:content>
          <ObjectStatus text="{i18n>homeSubtitle}" state="Information" />
        </f:content>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <layout:Grid defaultSpan="XL3 L4 M6 S12" class="sapUiSmallMarginTop">
          <layout:content>
            <GenericTile header="{i18n>homeCardExposures}" subheader="{i18n>homeCardExposuresSub}" press=".onNavToExposures" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
              <TileContent>
                <NumericContent value="" icon="sap-icon://product" />
              </TileContent>
            </GenericTile>
            <GenericTile header="{i18n>homeCardOrders}" subheader="{i18n>homeCardOrdersSub}" press=".onNavToOrders" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
              <TileContent>
                <NumericContent value="" icon="sap-icon://sales-order" />
              </TileContent>
            </GenericTile>
            <GenericTile header="{i18n>homeCardRfq}" subheader="{i18n>homeCardRfqSub}" press=".onNavToRfq" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
              <TileContent>
                <NumericContent value="" icon="sap-icon://request" />
              </TileContent>
            </GenericTile>
            <GenericTile header="{i18n>homeCardContracts}" subheader="{i18n>homeCardContractsSub}" press=".onNavToContracts" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
              <TileContent>
                <NumericContent value="" icon="sap-icon://document" />
              </TileContent>
            </GenericTile>
            <GenericTile header="{i18n>homeCardCashflow}" subheader="{i18n>homeCardCashflowSub}" press=".onNavToCashflow" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
              <TileContent>
                <NumericContent value="" icon="sap-icon://money-bills" />
              </TileContent>
            </GenericTile>
            <GenericTile header="{i18n>homeCardPnl}" subheader="{i18n>homeCardPnlSub}" press=".onNavToPnl" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
              <TileContent>
                <NumericContent value="" icon="sap-icon://line-chart" />
              </TileContent>
            </GenericTile>
          </layout:content>
        </layout:Grid>
        <Panel headerText="{i18n>homePlatformInfo}" class="sapUiSmallMarginTop">
          <VBox class="sapUiSmallMargin">
            <Text text="{i18n>homePlatformDescription}" />
          </VBox>
        </Panel>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
