<mvc:View
  controllerName="hedgecontrol.controller.DealDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <uxap:ObjectPageLayout id="dealDetailPage" busy="{dealDet>/busy}" showTitleInHeaderContent="true">

    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <HBox alignItems="Center">
            <Title text="{dealDet>/detail/reference} — {dealDet>/detail/name}" class="sapUiSmallMarginEnd" />
            <ObjectStatus text="{path: 'dealDet>/detail/status', formatter: 'formatter.capitalize'}"
              state="{path: 'dealDet>/detail/status', formatter: 'formatter.statusState'}" />
          </HBox>
        </uxap:heading>
        <uxap:actions>
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
          <Button text="{i18n>close}" icon="sap-icon://decline" press=".onClose" />
        </uxap:actions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>

    <uxap:headerContent>
      <HBox wrap="Wrap">
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colCommodity}" design="Bold" />
          <Text text="{path: 'dealDet>/detail/commodity', formatter: 'formatter.capitalize'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colPhysicalTons}" design="Bold" />
          <Text text="{path: 'dealDet>/detail/total_physical_tons', formatter: 'formatter.numberTwoDecimals'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colHedgeTons}" design="Bold" />
          <Text text="{path: 'dealDet>/detail/total_hedge_tons', formatter: 'formatter.numberTwoDecimals'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd" width="10rem">
          <Label text="{i18n>colHedgeRatio}" design="Bold" />
          <ProgressIndicator
            percentValue="{= Math.min(${dealDet>/detail/hedge_ratio} * 100, 100)}"
            displayValue="{= Math.round(${dealDet>/detail/hedge_ratio} * 100) + '%'}"
            state="{= ${dealDet>/detail/hedge_ratio} >= 1 ? 'Success' : (${dealDet>/detail/hedge_ratio} >= 0.5 ? 'Warning' : 'Error')}"
            showValue="true" />
        </VBox>
        <VBox>
          <Label text="{i18n>createdAt}" design="Bold" />
          <Text text="{path: 'dealDet>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
        </VBox>
      </HBox>
    </uxap:headerContent>

    <uxap:sections>

      <!-- Latest PNL Summary -->
      <uxap:ObjectPageSection title="{i18n>sectionPnlSummary}" titleUppercase="false"
        visible="{= !!${dealDet>/detail/latest_pnl}}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <HBox wrap="Wrap" class="sapUiSmallMargin">
                <VBox class="sapUiMediumMarginEnd">
                  <Label text="{i18n>colPhysicalRevenue}" design="Bold" />
                  <ObjectNumber
                    number="{path: 'dealDet>/detail/latest_pnl/physical_revenue', formatter: 'formatter.numberTwoDecimals'}"
                    unit="USD" />
                </VBox>
                <VBox class="sapUiMediumMarginEnd">
                  <Label text="{i18n>colPhysicalCost}" design="Bold" />
                  <ObjectNumber
                    number="{path: 'dealDet>/detail/latest_pnl/physical_cost', formatter: 'formatter.numberTwoDecimals'}"
                    unit="USD" />
                </VBox>
                <VBox class="sapUiMediumMarginEnd">
                  <Label text="{i18n>colHedgePnlRealized}" design="Bold" />
                  <ObjectNumber
                    number="{path: 'dealDet>/detail/latest_pnl/hedge_pnl_realized', formatter: 'formatter.numberTwoDecimals'}"
                    unit="USD"
                    state="{= ${dealDet>/detail/latest_pnl/hedge_pnl_realized} >= 0 ? 'Success' : 'Error'}" />
                </VBox>
                <VBox class="sapUiMediumMarginEnd">
                  <Label text="{i18n>colHedgePnlMtm}" design="Bold" />
                  <ObjectNumber
                    number="{path: 'dealDet>/detail/latest_pnl/hedge_pnl_mtm', formatter: 'formatter.numberTwoDecimals'}"
                    unit="USD"
                    state="{= ${dealDet>/detail/latest_pnl/hedge_pnl_mtm} >= 0 ? 'Success' : 'Error'}" />
                </VBox>
                <VBox>
                  <Label text="{i18n>colTotalPnl}" design="Bold" />
                  <ObjectNumber
                    number="{path: 'dealDet>/detail/latest_pnl/total_pnl', formatter: 'formatter.numberTwoDecimals'}"
                    unit="USD" emphasized="true"
                    state="{= ${dealDet>/detail/latest_pnl/total_pnl} >= 0 ? 'Success' : 'Error'}" />
                </VBox>
              </HBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Links -->
      <uxap:ObjectPageSection title="{i18n>sectionLinks}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <Table id="linksTable" items="{dealDet>/links}" noDataText="{i18n>noLinks}">
                  <headerToolbar>
                    <OverflowToolbar>
                      <Title text="{i18n>sectionLinks}" level="H3" />
                      <ToolbarSpacer />
                      <Button text="{i18n>addLink}" icon="sap-icon://add" press=".onAddLink" type="Emphasized" />
                    </OverflowToolbar>
                  </headerToolbar>
                  <columns>
                    <Column><header><Text text="{i18n>linkType}" /></header></Column>
                    <Column><header><Text text="{i18n>linkLinkedId}" /></header></Column>
                    <Column><header><Text text="{i18n>colCreatedAt}" /></header></Column>
                    <Column width="5rem" hAlign="Center"><header><Text text="" /></header></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <ObjectStatus text="{path: 'dealDet>linked_type', formatter: 'formatter.capitalize'}" />
                        <Text text="{path: 'dealDet>linked_id', formatter: 'formatter.shortUuid'}" />
                        <Text text="{path: 'dealDet>created_at', formatter: 'formatter.dateTimeDisplay'}" />
                        <Button icon="sap-icon://delete" type="Reject" press=".onRemoveLink" tooltip="{i18n>removeLink}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- PNL History -->
      <uxap:ObjectPageSection title="{i18n>sectionPnlHistory}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <Table id="pnlHistoryTable" items="{dealDet>/pnlHistory}" noDataText="{i18n>noPnlHistory}">
                  <headerToolbar>
                    <OverflowToolbar>
                      <Title text="{i18n>sectionPnlHistory}" level="H3" />
                      <ToolbarSpacer />
                      <Button text="{i18n>generatePnlSnapshot}" icon="sap-icon://create-form" press=".onTriggerPnlSnapshot" type="Emphasized" />
                    </OverflowToolbar>
                  </headerToolbar>
                  <columns>
                    <Column><header><Text text="{i18n>colSnapshotDate}" /></header></Column>
                    <Column hAlign="End"><header><Text text="{i18n>colPhysicalRevenue}" /></header></Column>
                    <Column hAlign="End"><header><Text text="{i18n>colPhysicalCost}" /></header></Column>
                    <Column hAlign="End"><header><Text text="{i18n>colHedgePnlRealized}" /></header></Column>
                    <Column hAlign="End"><header><Text text="{i18n>colHedgePnlMtm}" /></header></Column>
                    <Column hAlign="End"><header><Text text="{i18n>colTotalPnl}" /></header></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <Text text="{path: 'dealDet>snapshot_date', formatter: 'formatter.dateDisplay'}" />
                        <Text text="{path: 'dealDet>physical_revenue', formatter: 'formatter.numberTwoDecimals'}" />
                        <Text text="{path: 'dealDet>physical_cost', formatter: 'formatter.numberTwoDecimals'}" />
                        <ObjectNumber
                          number="{path: 'dealDet>hedge_pnl_realized', formatter: 'formatter.numberTwoDecimals'}"
                          state="{= ${dealDet>hedge_pnl_realized} >= 0 ? 'Success' : 'Error'}" />
                        <ObjectNumber
                          number="{path: 'dealDet>hedge_pnl_mtm', formatter: 'formatter.numberTwoDecimals'}"
                          state="{= ${dealDet>hedge_pnl_mtm} >= 0 ? 'Success' : 'Error'}" />
                        <ObjectNumber
                          number="{path: 'dealDet>total_pnl', formatter: 'formatter.numberTwoDecimals'}"
                          state="{= ${dealDet>total_pnl} >= 0 ? 'Success' : 'Error'}" emphasized="true" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

    </uxap:sections>

  </uxap:ObjectPageLayout>
</mvc:View>
