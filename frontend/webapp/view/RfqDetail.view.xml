<mvc:View
  controllerName="hedgecontrol.controller.RfqDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:l="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <uxap:ObjectPageLayout id="rfqDetailPage" showTitleInHeaderContent="false"
    alwaysShowContentHeader="false" showFooter="true" preserveHeaderStateOnScroll="true" busy="{rfqDet>/busy}"
    class="sapUiResponsivePadding--header sapUiResponsivePadding--content">

    <!-- ═══ Header Title ═══ -->
    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <HBox alignItems="Center">
            <Title text="{i18n>rfqDetailTitle}: {rfqDet>/detail/rfq_number}" class="sapUiSmallMarginEnd" />
            <ObjectStatus text="{rfqDet>/detail/state}" state="{path: 'rfqDet>/detail/state', formatter: 'formatter.statusState'}" />
          </HBox>
        </uxap:heading>
        <uxap:snappedContent>
          <HBox alignItems="Center" class="sapUiSmallMarginBegin">
            <ObjectStatus text="{rfqDet>/detail/commodity}" class="sapUiSmallMarginEnd" />
            <ObjectStatus text="{rfqDet>/detail/direction}" state="{= ${rfqDet>/detail/direction} === 'BUY' ? 'Success' : 'Error'}" class="sapUiSmallMarginEnd" />
            <Text text="{path: 'rfqDet>/detail/quantity_mt', formatter: 'formatter.numberTwoDecimals'} MT" />
          </HBox>
        </uxap:snappedContent>
        <uxap:actions>
          <Button text="{i18n>viewDocuments}" icon="sap-icon://document" press=".onViewDocuments" type="Transparent" />
        </uxap:actions>
        <uxap:navigationActions>
          <Button icon="sap-icon://full-screen" press=".onToggleMidFullScreen" tooltip="{i18n>fullScreen}" type="Transparent" />
          <Button icon="sap-icon://decline" press=".onClose" tooltip="{i18n>close}" type="Transparent" />
        </uxap:navigationActions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>

    <!-- ═══ Header Content — Key Attributes ═══ -->
    <uxap:headerContent>
      <HBox class="sapUiSmallMarginBeginEnd" alignItems="Start" wrap="Wrap">
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colCommodity}" design="Bold" />
          <Text text="{rfqDet>/detail/commodity}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colDirection}" design="Bold" />
          <ObjectStatus text="{rfqDet>/detail/direction}" state="{= ${rfqDet>/detail/direction} === 'BUY' ? 'Success' : 'Error'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colQuantityMt}" design="Bold" />
          <Text text="{path: 'rfqDet>/detail/quantity_mt', formatter: 'formatter.numberTwoDecimals'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colDeliveryWindow}" design="Bold" />
          <Text text="{path: 'rfqDet>/detail/delivery_window_start', formatter: 'formatter.dateDisplay'} – {path: 'rfqDet>/detail/delivery_window_end', formatter: 'formatter.dateDisplay'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colIntent}" design="Bold" />
          <Text text="{rfqDet>/detail/intent}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colCreatedAt}" design="Bold" />
          <Text text="{path: 'rfqDet>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
        </VBox>
      </HBox>
    </uxap:headerContent>

    <!-- ═══ Sections ═══ -->
    <uxap:sections>

      <!-- Section: General Information -->
      <uxap:ObjectPageSection title="{i18n>sectionGeneral}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <MessageStrip
                  text="{rfqDet>/errorMessage}"
                  type="Error"
                  showIcon="true"
                  showCloseButton="true"
                  visible="{= !!${rfqDet>/errorMessage}}"
                  class="sapUiSmallMarginBottom" />
                <form:Form editable="false">
                  <form:layout>
                    <form:ColumnLayout columnsM="1" columnsL="2" columnsXL="2" />
                  </form:layout>
                  <form:formContainers>
                    <form:FormContainer title="{i18n>sectionRfqInfo}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colRfqNumber}">
                          <form:fields><Text text="{rfqDet>/detail/rfq_number}" /></form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colIntent}">
                          <form:fields><Text text="{rfqDet>/detail/intent}" /></form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colCommodity}">
                          <form:fields><Text text="{rfqDet>/detail/commodity}" /></form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colDirection}">
                          <form:fields>
                            <ObjectStatus text="{rfqDet>/detail/direction}" state="{= ${rfqDet>/detail/direction} === 'BUY' ? 'Success' : 'Error'}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colQuantityMt}">
                          <form:fields><Text text="{path: 'rfqDet>/detail/quantity_mt', formatter: 'formatter.numberTwoDecimals'}" /></form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colOrderId}">
                          <form:fields><Link text="{path: 'rfqDet>/detail/order_id', formatter: 'formatter.shortUuid'}" press=".onNavigateToOrder"
                            visible="{= !!${rfqDet>/detail/order_id}}" /></form:fields>
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>sectionDeliveryWindow}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colDeliveryStart}">
                          <form:fields><Text text="{path: 'rfqDet>/detail/delivery_window_start', formatter: 'formatter.dateDisplay'}" /></form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colDeliveryEnd}">
                          <form:fields><Text text="{path: 'rfqDet>/detail/delivery_window_end', formatter: 'formatter.dateDisplay'}" /></form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colState}">
                          <form:fields>
                            <ObjectStatus text="{rfqDet>/detail/state}" state="{path: 'rfqDet>/detail/state', formatter: 'formatter.statusState'}" />
                          </form:fields>
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                  </form:formContainers>
                </form:Form>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Section: Exposure -->
      <uxap:ObjectPageSection title="{i18n>sectionExposure}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <form:Form editable="false">
                <form:layout>
                  <form:ColumnLayout columnsM="1" columnsL="2" columnsXL="2" />
                </form:layout>
                <form:formContainers>
                  <form:FormContainer>
                    <form:formElements>
                      <form:FormElement label="{i18n>colCommercialActiveMt}">
                        <form:fields><Text text="{path: 'rfqDet>/detail/commercial_active_mt', formatter: 'formatter.numberTwoDecimals'}" /></form:fields>
                      </form:FormElement>
                      <form:FormElement label="{i18n>colCommercialPassiveMt}">
                        <form:fields><Text text="{path: 'rfqDet>/detail/commercial_passive_mt', formatter: 'formatter.numberTwoDecimals'}" /></form:fields>
                      </form:FormElement>
                      <form:FormElement label="{i18n>colCommercialNetMt}">
                        <form:fields><Text text="{path: 'rfqDet>/detail/commercial_net_mt', formatter: 'formatter.numberTwoDecimals'}" /></form:fields>
                      </form:FormElement>
                      <form:FormElement label="{i18n>colReductionAppliedMt}">
                        <form:fields><Text text="{path: 'rfqDet>/detail/commercial_reduction_applied_mt', formatter: 'formatter.numberTwoDecimals'}" /></form:fields>
                      </form:FormElement>
                    </form:formElements>
                  </form:FormContainer>
                </form:formContainers>
              </form:Form>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Section: Quotes -->
      <uxap:ObjectPageSection title="{i18n>sectionQuotes}" id="quotesSection" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <OverflowToolbar>
                  <Title text="{i18n>sectionQuotes}" level="H4" />
                  <ToolbarSpacer />
                  <Button text="{i18n>refresh}" icon="sap-icon://refresh" press=".onRefresh" type="Transparent"
                    visible="{= ${rfqDet>/detail/state} === 'SENT' || ${rfqDet>/detail/state} === 'QUOTED'}" />
                  <Button text="{i18n>addQuote}" icon="sap-icon://add" press=".onAddQuote"
                    visible="{= ${rfqDet>/detail/state} !== 'CLOSED' &amp;&amp; ${rfqDet>/detail/state} !== 'AWARDED'}" />
                  <Button text="{i18n>viewRanking}" icon="sap-icon://numbered-text" press=".onViewRanking" />
                </OverflowToolbar>
                <Table items="{rfqDet>/quotes}" noDataText="{i18n>noQuotes}" mode="None">
                  <columns>
                    <Column><header><Text text="{i18n>colCounterpartyName}" /></header></Column>
                    <Column hAlign="End"><header><Text text="{i18n>colFixedPriceValue}" /></header></Column>
                    <Column><header><Text text="{i18n>colFixedPriceUnit}" /></header></Column>
                    <Column><header><Text text="{i18n>colFloatConvention}" /></header></Column>
                    <Column><header><Text text="{i18n>colReceivedAt}" /></header></Column>
                    <Column hAlign="Center"
                      visible="{= ${rfqDet>/detail/state} === 'SENT' || ${rfqDet>/detail/state} === 'QUOTED'}">
                      <header><Text text="{i18n>colActions}" /></header>
                    </Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <ObjectIdentifier title="{rfqDet>_counterparty_name}" text="{path: 'rfqDet>counterparty_id', formatter: 'formatter.shortUuid'}" />
                        <Text text="{path: 'rfqDet>fixed_price_value', formatter: 'formatter.priceFourDecimals'}" />
                        <Text text="{rfqDet>fixed_price_unit}" />
                        <Text text="{rfqDet>float_pricing_convention}" />
                        <Text text="{path: 'rfqDet>received_at', formatter: 'formatter.dateTimeDisplay'}" />
                        <HBox visible="{= ${rfqDet>/detail/state} === 'SENT' || ${rfqDet>/detail/state} === 'QUOTED'}" alignItems="Center">
                          <MenuButton text="{i18n>colActions}" type="Emphasized" icon="sap-icon://action">
                            <menu>
                              <Menu>
                                <MenuItem text="{i18n>btnContractQuote}" icon="sap-icon://accept" press=".onQuoteContract" />
                                <MenuItem text="{i18n>btnRefreshQuote}" icon="sap-icon://refresh" press=".onQuoteRefresh" />
                                <MenuItem text="{i18n>btnRejectQuote}" icon="sap-icon://decline" press=".onQuoteReject" />
                              </Menu>
                            </menu>
                          </MenuButton>
                        </HBox>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Section: Invitations (WhatsApp) -->
      <uxap:ObjectPageSection title="Convites" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <Table items="{rfqDet>/detail/invitations}" noDataText="{i18n>noData}" mode="None">
                <columns>
                  <Column><header><Text text="Contraparte" /></header></Column>
                  <Column><header><Text text="Telefone" /></header></Column>
                  <Column><header><Text text="Canal" /></header></Column>
                  <Column><header><Text text="Status Envio" /></header></Column>
                  <Column><header><Text text="Enviado em" /></header></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{rfqDet>recipient_name}" />
                      <Text text="{rfqDet>recipient_phone}" />
                      <ObjectStatus text="{rfqDet>channel}" icon="sap-icon://message-popup" />
                      <ObjectStatus text="{rfqDet>send_status}"
                        state="{= ${rfqDet>send_status} === 'sent' ? 'Success' : (${rfqDet>send_status} === 'failed' ? 'Error' : 'Warning')}"
                        icon="{= ${rfqDet>send_status} === 'sent' ? 'sap-icon://accept' : (${rfqDet>send_status} === 'failed' ? 'sap-icon://error' : 'sap-icon://pending')}" />
                      <Text text="{path: 'rfqDet>sent_at', formatter: 'formatter.dateTimeDisplay'}" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Section: Ranking -->
      <uxap:ObjectPageSection title="{i18n>sectionRanking}" id="rankingSection" titleUppercase="false"
        visible="{= ${rfqDet>/ranking/ranking} &amp;&amp; ${rfqDet>/ranking/ranking}.length > 0}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <OverflowToolbar>
                  <Title text="{i18n>sectionRanking}" level="H4" />
                  <ObjectStatus text="{rfqDet>/ranking/status}" class="sapUiSmallMarginBegin" />
                  <ToolbarSpacer />
                  <Button text="{i18n>awardSelected}" icon="sap-icon://competitor" press=".onAwardSelected" type="Emphasized"
                    visible="{= ${rfqDet>/detail/state} === 'QUOTED'}" />
                </OverflowToolbar>
                <Table id="rankingTable" items="{rfqDet>/ranking/ranking}" noDataText="{i18n>noData}"
                  mode="{= ${rfqDet>/detail/state} === 'QUOTED' ? 'SingleSelectLeft' : 'None'}">
                  <columns>
                    <Column width="5rem"><header><Text text="{i18n>colRank}" /></header></Column>
                    <Column><header><Text text="{i18n>colCounterpartyName}" /></header></Column>
                    <Column hAlign="End"><header><Text text="{i18n>colSpreadValue}" /></header></Column>
                  </columns>
                  <items>
                    <ColumnListItem highlight="{= ${rfqDet>rank} === 1 ? 'Success' : 'None'}" selected="{= ${rfqDet>rank} === 1}">
                      <cells>
                        <HBox alignItems="Center">
                          <core:Icon src="sap-icon://competitor" color="{= ${rfqDet>rank} === 1 ? '#107E3E' : 'transparent'}" class="sapUiSmallMarginEnd" />
                          <Text text="{rfqDet>rank}" />
                        </HBox>
                        <ObjectIdentifier title="{rfqDet>_counterparty_name}" text="{path: 'rfqDet>counterparty_id', formatter: 'formatter.shortUuid'}" />
                        <ObjectNumber number="{path: 'rfqDet>spread_value', formatter: 'formatter.priceFourDecimals'}" unit="USD/MT" state="{= ${rfqDet>rank} === 1 ? 'Success' : 'None'}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <!-- Section: Timeline (State Events) -->
      <uxap:ObjectPageSection title="Timeline" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <List items="{rfqDet>/stateEvents}" noDataText="{i18n>noData}" mode="None">
                <items>
                  <FeedListItem
                    icon="{rfqDet>_icon}"
                    text="{rfqDet>_description}"
                    info="{rfqDet>to_state}"
                    timestamp="{path: 'rfqDet>created_at', formatter: 'formatter.dateTimeDisplay'}"
                    senderActive="false" />
                </items>
              </List>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

    </uxap:sections>

    <!-- ═══ Footer ═══ -->
    <uxap:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="{i18n>refresh}" icon="sap-icon://refresh" press=".onRefresh" type="Transparent"
          visible="{= ${rfqDet>/detail/state} === 'SENT' || ${rfqDet>/detail/state} === 'QUOTED'}" />
      </OverflowToolbar>
    </uxap:footer>

  </uxap:ObjectPageLayout>
</mvc:View>
