<mvc:View
  controllerName="hedgecontrol.controller.Pnl"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:t="sap.ui.table"
  xmlns:viz="sap.viz.ui5.controls"
  xmlns:vizData="sap.viz.ui5.data"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="pnlPage" headerExpanded="true" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>pnlTitle}" />
        </f:heading>
        <f:snappedContent>
          <Text text="{pl>/summaryText}" />
        </f:snappedContent>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <HBox alignItems="End" wrap="Wrap" class="sapUiSmallMargin">
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>pnlFilterDeals}" labelFor="pnlDealSelector" />
            <MultiComboBox id="pnlDealSelector"
              placeholder="{i18n>pnlFilterDealsPlaceholder}"
              width="28rem"
              items="{pl>/dealList}"
              selectionChange=".onDealSelectionChange">
              <core:Item key="{pl>id}" text="{pl>label}" />
            </MultiComboBox>
          </VBox>
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>pnlSnapshotDate}" labelFor="pnlDatePicker" />
            <DatePicker id="pnlDatePicker"
              displayFormat="dd/MM/yyyy"
              valueFormat="yyyy-MM-dd"
              placeholder="dd/MM/yyyy"
              width="12rem" />
          </VBox>
          <Button id="pnlGoButton"
            text="{i18n>pnlGoButton}"
            type="Emphasized"
            press=".onCalculateBreakdown"
            class="sapUiSmallMarginEnd" />
          <CheckBox id="pnlSelectAll"
            text="{i18n>pnlSelectAllDeals}"
            selected="{pl>/selectAll}"
            select=".onSelectAllDeals" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <VBox class="sapUiSmallMargin">

        <!-- Summary Strip -->
        <Panel visible="{pl>/resultLoaded}" class="sapUiSmallMarginBottom">
          <headerToolbar>
            <Toolbar>
              <Title text="{i18n>pnlSummary}" level="H4" />
            </Toolbar>
          </headerToolbar>
          <HBox wrap="Wrap" class="sapUiSmallMargin" justifyContent="SpaceBetween">
            <VBox class="sapUiSmallMarginEnd" width="auto">
              <Label text="{i18n>pnlPhysicalRevenue}" />
              <ObjectNumber number="{ path: 'pl>/totals/physical_revenue', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                state="{ path: 'pl>/totals/physical_revenue', formatter: '.formatPlState' }" />
            </VBox>
            <VBox class="sapUiSmallMarginEnd" width="auto">
              <Label text="{i18n>pnlPhysicalCost}" />
              <ObjectNumber number="{ path: 'pl>/totals/physical_cost', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                state="{ path: 'pl>/totals/physical_cost', formatter: '.formatPlState' }" />
            </VBox>
            <VBox class="sapUiSmallMarginEnd" width="auto">
              <Label text="{i18n>realizedPl}" />
              <ObjectNumber number="{ path: 'pl>/totals/hedge_pnl_realized', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                state="{ path: 'pl>/totals/hedge_pnl_realized', formatter: '.formatPlState' }" />
            </VBox>
            <VBox class="sapUiSmallMarginEnd" width="auto">
              <Label text="{i18n>unrealizedMtm}" />
              <ObjectNumber number="{ path: 'pl>/totals/hedge_pnl_mtm', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                state="{ path: 'pl>/totals/hedge_pnl_mtm', formatter: '.formatPlState' }" />
            </VBox>
            <VBox width="auto">
              <Label text="{i18n>pnlTotal}" design="Bold" />
              <ObjectNumber number="{ path: 'pl>/totals/total_pnl', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                state="{ path: 'pl>/totals/total_pnl', formatter: '.formatPlState' }" emphasized="true" />
            </VBox>
          </HBox>
        </Panel>

        <!-- VizFrame: P&L per deal bar chart -->
        <viz:VizFrame id="pnlChart"
          vizType="bar"
          width="100%"
          height="300px"
          class="hcVizFrame sapUiSmallMarginBottom"
          visible="{pl>/resultLoaded}"
          uiConfig="{applicationSet: 'fiori', scale: {theme: 'sap_horizon'}}">
          <viz:dataset>
            <vizData:FlattenedDataset data="{path: 'pl>/chartData'}">
              <vizData:dimensions>
                <vizData:DimensionDefinition name="Deal" value="{label}" />
              </vizData:dimensions>
              <vizData:measures>
                <vizData:MeasureDefinition name="P&amp;L" value="{pnl}" />
              </vizData:measures>
            </vizData:FlattenedDataset>
          </viz:dataset>
          <viz:feeds>
            <viz:FeedItem id="plValueAxis" uid="valueAxis" values="['P&amp;L']" />
            <viz:FeedItem id="plCategoryAxis" uid="categoryAxis" values="['Deal']" />
          </viz:feeds>
        </viz:VizFrame>

        <!-- TreeTable Breakdown -->
          rows="{path: 'pl>/treeData', parameters: { arrayNames: ['children'] }}"
          selectionMode="None"
          visibleRowCountMode="Auto"
          minAutoRowCount="8"
          enableColumnReordering="false"
          expandFirstLevel="true"
          visible="{pl>/resultLoaded}">
          <t:toolbar>
            <Toolbar>
              <Title text="{i18n>pnlBreakdown}" level="H4" />
              <ToolbarSpacer />
              <Button icon="sap-icon://expand-all" tooltip="{i18n>pnlExpandAll}" press=".onExpandAll" />
              <Button icon="sap-icon://collapse-all" tooltip="{i18n>pnlCollapseAll}" press=".onCollapseAll" />
            </Toolbar>
          </t:toolbar>
          <t:columns>
            <t:Column width="22rem">
              <Label text="{i18n>pnlColDescription}" />
              <t:template>
                <Text text="{pl>description}" wrapping="false" />
              </t:template>
            </t:Column>
            <t:Column width="8rem" hAlign="Center">
              <Label text="{i18n>pnlColType}" />
              <t:template>
                <Text text="{pl>type}" />
              </t:template>
            </t:Column>
            <t:Column width="8rem" hAlign="Center">
              <Label text="{i18n>pnlColCommodity}" />
              <t:template>
                <Text text="{pl>commodity}" />
              </t:template>
            </t:Column>
            <t:Column width="10rem" hAlign="End">
              <Label text="{i18n>pnlColQuantity}" />
              <t:template>
                <Text text="{ path: 'pl>quantity', formatter: 'formatter.numberTwoDecimals' }" />
              </t:template>
            </t:Column>
            <t:Column width="10rem" hAlign="End">
              <Label text="{i18n>pnlColPrice}" />
              <t:template>
                <Text text="{ path: 'pl>price', formatter: 'formatter.numberTwoDecimals' }" />
              </t:template>
            </t:Column>
            <t:Column width="12rem" hAlign="End">
              <Label text="{i18n>pnlColValue}" />
              <t:template>
                <ObjectNumber number="{ path: 'pl>value', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                  state="{ path: 'pl>value', formatter: '.formatPlState' }" />
              </t:template>
            </t:Column>
          </t:columns>
        </t:TreeTable>

        <!-- Empty state -->
        <IllustratedMessage
          visible="{= !${pl>/resultLoaded} }"
          illustrationType="sapIllus-NoData"
          title="{i18n>pnlEmptyTitle}"
          description="{i18n>pnlEmptyDescription}" />

      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
