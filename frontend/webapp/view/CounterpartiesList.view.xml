<mvc:View
  controllerName="hedgecontrol.controller.CounterpartiesList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="counterpartiesListPage" showFooter="false" busy="{cpty>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>counterpartiesTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newCounterparty}" icon="sap-icon://add" press=".onCreateCounterparty" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox>
        <MessageStrip
          text="{cpty>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${cpty>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <Table id="counterpartiesList" items="{cpty>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" itemPress=".onCounterpartySelect">
          <headerToolbar>
            <OverflowToolbar>
              <Title text="{i18n>counterpartiesTitle}" level="H3" />
              <ToolbarSpacer />
              <SearchField width="15rem" search=".onSearch" placeholder="{i18n>search}" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column><Text text="{i18n>colName}" /></Column>
            <Column><Text text="{i18n>colType}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colRiskRating}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colCountry}" /></Column>
            <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colKycStatus}" /></Column>
            <Column><Text text="{i18n>colActive}" /></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{cpty>name}" />
                <Text text="{path: 'cpty>type', formatter: 'formatter.counterpartyType'}" />
                <ObjectStatus
                  text="{path: 'cpty>risk_rating', formatter: 'formatter.capitalize'}"
                  state="{= ${cpty>risk_rating} === 'low' ? 'Success' : (${cpty>risk_rating} === 'high' ? 'Error' : 'Warning')}" />
                <Text text="{cpty>country}" />
                <ObjectStatus text="{path: 'cpty>kyc_status', formatter: 'formatter.capitalize'}"
                  state="{path: 'cpty>kyc_status', formatter: 'formatter.statusState'}" />
                <ObjectStatus
                  text="{= ${cpty>is_active} ? 'Ativa' : 'Inativa'}"
                  state="{= ${cpty>is_active} ? 'Success' : 'Error'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
