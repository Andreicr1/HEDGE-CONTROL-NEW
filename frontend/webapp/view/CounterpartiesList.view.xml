<mvc:View
  controllerName="hedgecontrol.controller.CounterpartiesList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="counterpartiesListPage" showFooter="false" busy="{cpty>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>counterpartiesTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newCounterparty}" icon="sap-icon://add" press=".onCreateCounterparty" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{cpty>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${cpty>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <Table id="counterpartiesTable" items="{cpty>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" selectionChange=".onCounterpartySelect">
          <headerToolbar>
            <OverflowToolbar>
              <Title text="{i18n>counterpartiesTitle}" level="H3" />
              <ToolbarSpacer />
              <SearchField width="15rem" search=".onSearch" />
            </OverflowToolbar>
          </headerToolbar>
          <columns>
            <Column><header><Text text="{i18n>colName}" /></header></Column>
            <Column width="6rem"><header><Text text="{i18n>colType}" /></header></Column>
            <Column><header><Text text="{i18n>colCountry}" /></header></Column>
            <Column><header><Text text="{i18n>colTaxId}" /></header></Column>
            <Column width="7rem"><header><Text text="{i18n>colKycStatus}" /></header></Column>
            <Column width="7rem"><header><Text text="{i18n>colRiskRating}" /></header></Column>
            <Column width="5rem" hAlign="Center"><header><Text text="{i18n>colActive}" /></header></Column>
          </columns>
          <items>
            <ColumnListItem type="Navigation">
              <cells>
                <Text text="{cpty>name}" />
                <ObjectStatus text="{path: 'cpty>type', formatter: 'formatter.capitalize'}" />
                <Text text="{cpty>country}" />
                <Text text="{cpty>tax_id}" />
                <ObjectStatus text="{path: 'cpty>kyc_status', formatter: 'formatter.capitalize'}"
                  state="{path: 'cpty>kyc_status', formatter: 'formatter.statusState'}" />
                <ObjectStatus text="{path: 'cpty>risk_rating', formatter: 'formatter.capitalize'}"
                  state="{= ${cpty>risk_rating} === 'low' ? 'Success' : (${cpty>risk_rating} === 'high' ? 'Error' : 'Warning')}" />
                <Icon src="{= ${cpty>is_active} ? 'sap-icon://accept' : 'sap-icon://decline'}"
                  color="{= ${cpty>is_active} ? '#107E3E' : '#BB0000'}" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
