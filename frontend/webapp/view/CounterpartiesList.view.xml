<mvc:View
  controllerName="hedgecontrol.controller.CounterpartiesList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="counterpartiesListPage" showFooter="false" busy="{cpty>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>counterpartiesTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newCounterparty}" icon="sap-icon://add" press=".onCreateCounterparty" type="Emphasized" />
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="20rem" search=".onSearch" placeholder="{i18n>search}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>
    <f:content>
      <VBox>
        <MessageStrip
          text="{cpty>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${cpty>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <List id="counterpartiesList" items="{cpty>/items}" growing="true" growingThreshold="50"
          noDataText="{i18n>noData}" mode="SingleSelectMaster" itemPress=".onCounterpartySelect"
          class="counterpartiesList">
          <items>
            <ObjectListItem
              title="{cpty>name}"
              intro="{path: 'cpty>type', formatter: 'formatter.counterpartyType'}"
              type="Navigation"
              number="{path: 'cpty>risk_rating', formatter: 'formatter.capitalize'}"
              numberUnit="Risk"
              numberState="{= ${cpty>risk_rating} === 'low' ? 'Success' : (${cpty>risk_rating} === 'high' ? 'Error' : 'Warning')}"
              class="sapUiSmallMarginTopBottom">
              <attributes>
                <ObjectAttribute text="{cpty>country}" />
              </attributes>
              <firstStatus>
                <ObjectStatus text="{path: 'cpty>kyc_status', formatter: 'formatter.capitalize'}"
                  state="{path: 'cpty>kyc_status', formatter: 'formatter.statusState'}" />
              </firstStatus>
              <secondStatus>
                <ObjectStatus text="{= ${cpty>is_active} ? 'Ativa' : 'Inativa'}"
                  state="{= ${cpty>is_active} ? 'Success' : 'Error'}" />
              </secondStatus>
            </ObjectListItem>
          </items>
        </List>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
