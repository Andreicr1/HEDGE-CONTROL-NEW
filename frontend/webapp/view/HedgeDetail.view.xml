<mvc:View
  controllerName="hedgecontrol.controller.HedgeDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <uxap:ObjectPageLayout id="hedgeDetailPage" busy="{hdgDet>/busy}" showTitleInHeaderContent="true">

    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <HBox alignItems="Center">
            <Title text="{hdgDet>/detail/reference}" class="sapUiSmallMarginEnd" />
            <ObjectStatus text="{path: 'hdgDet>/detail/status', formatter: 'formatter.capitalize'}"
              state="{path: 'hdgDet>/detail/status', formatter: 'formatter.statusState'}" />
          </HBox>
        </uxap:heading>
        <uxap:actions>
          <Button text="{i18n>edit}" icon="sap-icon://edit" press=".onToggleEdit"
            visible="{= !${hdgDet>/editMode} &amp;&amp; ${hdgDet>/detail/status} === 'active'}" />
          <Button text="{i18n>save}" icon="sap-icon://save" press=".onSave" type="Emphasized"
            visible="{hdgDet>/editMode}" />
          <MenuButton text="{i18n>changeStatus}" icon="sap-icon://status-positive"
            visible="{= ${hdgDet>/detail/status} === 'active' || ${hdgDet>/detail/status} === 'partially_settled'}">
            <menu>
              <Menu>
                <MenuItem text="{i18n>statusPartiallySettled}" press=".onSetStatus">
                  <customData>
                    <core:CustomData key="status" value="partially_settled" />
                  </customData>
                </MenuItem>
                <MenuItem text="{i18n>statusSettled}" press=".onSetStatus">
                  <customData>
                    <core:CustomData key="status" value="settled" />
                  </customData>
                </MenuItem>
              </Menu>
            </menu>
          </MenuButton>
          <Button text="{i18n>cancelHedge}" icon="sap-icon://decline" type="Reject" press=".onCancel"
            visible="{= ${hdgDet>/detail/status} === 'active'}" />
          <Button text="{i18n>close}" icon="sap-icon://decline" press=".onClose" type="Transparent" />
        </uxap:actions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>

    <uxap:headerContent>
      <HBox wrap="Wrap">
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colCommodity}" design="Bold" />
          <Text text="{path: 'hdgDet>/detail/commodity', formatter: 'formatter.capitalize'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colDirection}" design="Bold" />
          <ObjectStatus text="{path: 'hdgDet>/detail/direction', formatter: 'formatter.capitalize'}"
            state="{= ${hdgDet>/detail/direction} === 'buy' ? 'Information' : 'Warning'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colTons}" design="Bold" />
          <Text text="{path: 'hdgDet>/detail/tons', formatter: 'formatter.numberTwoDecimals'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colPricePerTon}" design="Bold" />
          <ObjectNumber number="{path: 'hdgDet>/detail/price_per_ton', formatter: 'formatter.priceFourDecimals'}" unit="USD/t" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colSource}" design="Bold" />
          <Text text="{path: 'hdgDet>/detail/source_type', formatter: 'formatter.capitalize'}" />
        </VBox>
        <VBox>
          <Label text="{i18n>createdAt}" design="Bold" />
          <Text text="{path: 'hdgDet>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
        </VBox>
      </HBox>
    </uxap:headerContent>

    <uxap:sections>

      <uxap:ObjectPageSection title="{i18n>sectionTradeDetails}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <MessageStrip text="{hdgDet>/errorMessage}" type="Error" showIcon="true"
                  showCloseButton="true" visible="{= !!${hdgDet>/errorMessage}}" class="sapUiSmallMarginBottom" />
                <form:Form editable="{hdgDet>/editMode}">
                  <form:layout>
                    <form:ColumnLayout columnsM="2" columnsL="3" columnsXL="4" />
                  </form:layout>
                  <form:formContainers>
                    <form:FormContainer title="{i18n>sectionPricing}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colPricePerTon}">
                          <Input value="{hdgDet>/detail/price_per_ton}" editable="{hdgDet>/editMode}" type="Number" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colPremiumDiscount}">
                          <Input value="{hdgDet>/detail/premium_discount}" editable="{hdgDet>/editMode}" type="Number" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colTons}">
                          <Input value="{hdgDet>/detail/tons}" editable="{hdgDet>/editMode}" type="Number" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>sectionDates}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colTradeDate}">
                          <Text text="{path: 'hdgDet>/detail/trade_date', formatter: 'formatter.dateDisplay'}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colSettlementDate}">
                          <Input value="{hdgDet>/detail/settlement_date}" editable="{hdgDet>/editMode}" placeholder="YYYY-MM-DD" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colPromptDate}">
                          <Input value="{hdgDet>/detail/prompt_date}" editable="{hdgDet>/editMode}" placeholder="YYYY-MM-DD" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>sectionProvenance}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colSource}">
                          <Text text="{path: 'hdgDet>/detail/source_type', formatter: 'formatter.capitalize'}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colSourceId}" visible="{= !!${hdgDet>/detail/source_id}}">
                          <Text text="{path: 'hdgDet>/detail/source_id', formatter: 'formatter.shortUuid'}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colContractId}" visible="{= !!${hdgDet>/detail/contract_id}}">
                          <Text text="{path: 'hdgDet>/detail/contract_id', formatter: 'formatter.shortUuid'}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colCreatedBy}" visible="{= !!${hdgDet>/detail/created_by}}">
                          <Text text="{hdgDet>/detail/created_by}" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>colNotes}">
                      <form:formElements>
                        <form:FormElement>
                          <TextArea value="{hdgDet>/detail/notes}" editable="{hdgDet>/editMode}" rows="3" growing="true" width="100%" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                  </form:formContainers>
                </form:Form>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

    </uxap:sections>

  </uxap:ObjectPageLayout>
</mvc:View>
