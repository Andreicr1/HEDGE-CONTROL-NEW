<mvc:View
  controllerName="hedgecontrol.controller.MarketData"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:table="sap.ui.table"
  xmlns:unified="sap.ui.unified">

  <f:DynamicPage id="marketDataPage" headerExpanded="true" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>marketDataTitle}" />
        </f:heading>
        <f:snappedContent>
          <Text text="{mkt>/summaryText}" />
        </f:snappedContent>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader pinnable="true">
        <HBox alignItems="End" class="sapUiSmallMargin">
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>symbol}" />
            <Select id="mktSymbolSelect" selectedKey="{mkt>/symbol}" width="18rem">
              <core:Item key="LME_ALU_CASH_SETTLEMENT_DAILY" text="Alumínio – Cash Settlement (Diário)" />
              <core:Item key="LME_ALU_MONTHLY_AVG" text="Alumínio – Média Mensal" />
            </Select>
          </VBox>
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>startDate}" />
            <DatePicker id="mktStartDate" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd"
              value="{mkt>/startDate}" width="10rem" />
          </VBox>
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>endDate}" />
            <DatePicker id="mktEndDate" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd"
              value="{mkt>/endDate}" width="10rem" />
          </VBox>
          <Button text="{i18n>search}" icon="sap-icon://search" type="Emphasized"
            press=".onSearch" class="sapUiSmallMarginEnd" />
          <Button text="{i18n>ingest}" icon="sap-icon://upload" type="Default"
            press=".onIngest"
            visible="{= ${mkt>/symbol} !== 'LME_ALU_MONTHLY_AVG' }" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <VBox class="sapUiSmallMargin">

        <!-- Summary strip -->
        <Panel visible="{mkt>/resultLoaded}" class="sapUiSmallMarginBottom">
          <headerToolbar>
            <Toolbar>
              <Title text="{i18n>results}" level="H4" />
            </Toolbar>
          </headerToolbar>
          <HBox justifyContent="SpaceBetween" class="sapUiSmallMargin">
            <VBox>
              <Label text="{i18n>mktRecordCount}" />
              <ObjectNumber number="{mkt>/totals/count}" unit="{i18n>mktRecords}" emphasized="false" />
            </VBox>
            <VBox>
              <Label text="{i18n>mktMinPrice}" />
              <ObjectNumber number="{
                path: 'mkt>/totals/minPrice',
                type: 'sap.ui.model.type.Float',
                formatOptions: { minFractionDigits: 2, maxFractionDigits: 2 }
              }" unit="USD" emphasized="false" />
            </VBox>
            <VBox>
              <Label text="{i18n>mktMaxPrice}" />
              <ObjectNumber number="{
                path: 'mkt>/totals/maxPrice',
                type: 'sap.ui.model.type.Float',
                formatOptions: { minFractionDigits: 2, maxFractionDigits: 2 }
              }" unit="USD" emphasized="false" />
            </VBox>
            <VBox>
              <Label text="{i18n>mktAvgPrice}" />
              <ObjectNumber number="{
                path: 'mkt>/totals/avgPrice',
                type: 'sap.ui.model.type.Float',
                formatOptions: { minFractionDigits: 2, maxFractionDigits: 2 }
              }" unit="USD" emphasized="false" />
            </VBox>
          </HBox>
        </Panel>

        <!-- Results table -->
        <table:Table id="mktResultsTable"
          rows="{ path: 'mkt>/prices' }"
          visibleRowCountMode="Auto"
          minAutoRowCount="12"
          selectionMode="None"
          rowHeight="36"
          visible="{mkt>/resultLoaded}">
          <table:toolbar>
            <Toolbar>
              <Title text="{i18n>mktPriceHistory}" level="H5" />
              <ToolbarSpacer />
              <Button icon="sap-icon://download" tooltip="Export"
                press=".onExportCSV" type="Transparent" />
            </Toolbar>
          </table:toolbar>
          <table:columns>
            <table:Column width="10rem" sortProperty="settlement_date">
              <Label text="{i18n>settlementDate}" />
              <table:template>
                <Text text="{mkt>settlement_date}" />
              </table:template>
            </table:Column>
            <table:Column width="12rem" sortProperty="price_usd" hAlign="End">
              <Label text="{i18n>priceUsd}" />
              <table:template>
                <ObjectNumber number="{
                  path: 'mkt>price_usd',
                  type: 'sap.ui.model.type.Float',
                  formatOptions: { minFractionDigits: 2, maxFractionDigits: 2 }
                }" unit="USD" emphasized="false" />
              </table:template>
            </table:Column>
            <table:Column width="16rem" sortProperty="symbol">
              <Label text="{i18n>symbol}" />
              <table:template>
                <Text text="{mkt>symbol}" />
              </table:template>
            </table:Column>
            <table:Column width="8rem" sortProperty="source">
              <Label text="{i18n>source}" />
              <table:template>
                <Text text="{mkt>source}" />
              </table:template>
            </table:Column>
            <table:Column width="12rem" sortProperty="fetched_at">
              <Label text="{i18n>mktFetchedAt}" />
              <table:template>
                <Text text="{mkt>fetched_at}" />
              </table:template>
            </table:Column>
          </table:columns>
        </table:Table>

        <!-- Empty state -->
        <IllustratedMessage
          visible="{= !${mkt>/resultLoaded} }"
          illustrationType="sapIllus-SearchEarth"
          title="{i18n>mktEmptyTitle}"
          description="{i18n>mktEmptyDescription}" />

      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
