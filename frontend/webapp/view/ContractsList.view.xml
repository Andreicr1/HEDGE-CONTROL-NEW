<mvc:View
  controllerName="hedgecontrol.controller.ContractsList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="contractsListPage" showFooter="false" busy="{ctr>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>contractsTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newHedgeContract}" icon="sap-icon://add" type="Emphasized" press=".onCreateContract" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <Table id="contractsList"
        items="{ path: 'ctr>/items', sorter: { path: 'trade_date', descending: true } }"
        growing="true"
        growingThreshold="50"
        mode="SingleSelectMaster"
        itemPress=".onContractSelect">
        <noData>
          <IllustratedMessage illustrationType="sapIllus-EmptyList"
              title="{i18n>emptyStateTitle}" description="{i18n>emptyStateDescription}" />
        </noData>
        <headerToolbar>
          <OverflowToolbar>
            <Title text="{i18n>contractsTitle}" level="H3" />
            <ToolbarSpacer />
            <SearchField width="15rem" liveChange=".onSearch" placeholder="{i18n>searchContracts}" />
          </OverflowToolbar>
        </headerToolbar>
        <columns>
          <Column><Text text="{i18n>colReference}" /></Column>
          <Column><Text text="{i18n>colCommodity}" /></Column>
          <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colClassification}" /></Column>
          <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colQuantityMt}" /></Column>
          <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colFixedPriceValue}" /></Column>
          <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colCounterpartyId}" /></Column>
          <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colTradeDate}" /></Column>
          <Column><Text text="{i18n>colStatus}" /></Column>
        </columns>
        <items>
          <ColumnListItem type="Navigation">
            <cells>
              <Text text="{ctr>reference}" />
              <Text text="{path: 'ctr>commodity', formatter: 'formatter.capitalize'}" />
              <Text text="{path: 'ctr>classification', formatter: 'formatter.classificationText'}" />
              <ObjectNumber number="{path: 'ctr>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
              <ObjectNumber number="{path: 'ctr>fixed_price_value', formatter: 'formatter.priceFourDecimals'}" unit="{ctr>fixed_price_unit}" />
              <Text text="{ctr>_counterparty_name}" />
              <Text text="{path: 'ctr>trade_date', formatter: 'formatter.dateDisplay'}" />
              <ObjectStatus text="{path: 'ctr>status', formatter: 'formatter.capitalize'}"
                state="{path: 'ctr>status', formatter: 'formatter.statusState'}" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </f:content>
  </f:DynamicPage>
</mvc:View>
