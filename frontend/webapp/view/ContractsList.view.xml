<mvc:View
  controllerName="hedgecontrol.controller.ContractsList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="contractsListPage" headerExpanded="true" showFooter="false" busy="{ctr>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>contractsTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newHedgeContract}" icon="sap-icon://add" type="Emphasized" press=".onCreateContract" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="20rem" liveChange=".onSearch" placeholder="{i18n>searchContracts}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <List id="contractsList"
        items="{ path: 'ctr>/items', sorter: { path: 'trade_date', descending: true } }"
        growing="true"
        growingThreshold="50"
        mode="SingleSelectMaster"
        itemPress=".onContractSelect"
        noDataText="{i18n>noContracts}">
        <items>
          <ObjectListItem
            title="{ctr>commodity} — {path: 'ctr>classification', formatter: 'formatter.classificationText'}"
            intro="{ctr>reference}"
            type="Navigation"
            number="{path: 'ctr>quantity_mt', formatter: 'formatter.numberTwoDecimals'}"
            numberUnit="MT"
            icon="sap-icon://document-text">
            <attributes>
              <ObjectAttribute text="{i18n>fixedPrice}: {path: 'ctr>fixed_price_value', formatter: 'formatter.priceFourDecimals'} {ctr>fixed_price_unit}" />
              <ObjectAttribute text="{i18n>counterparty}: {ctr>_counterparty_name}" />
              <ObjectAttribute text="{i18n>tradeDate}: {path: 'ctr>trade_date', formatter: 'formatter.dateDisplay'}" />
            </attributes>
            <firstStatus>
              <ObjectStatus text="{path: 'ctr>status', formatter: 'formatter.capitalize'}"
                state="{path: 'ctr>status', formatter: 'formatter.statusState'}" />
            </firstStatus>
          </ObjectListItem>
        </items>
      </List>
    </f:content>

  </f:DynamicPage>
</mvc:View>
