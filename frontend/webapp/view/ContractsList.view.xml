<mvc:View
  controllerName="hedgecontrol.controller.ContractsList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="contractsListPage" headerExpanded="true" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>contractsTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newHedgeContract}" icon="sap-icon://add" type="Emphasized" press=".onCreateContract" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="20rem" liveChange=".onSearch" placeholder="{i18n>searchContracts}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <Table id="contractsTable"
        items="{ path: 'ctr>/items', sorter: { path: 'created_at', descending: true } }"
        growing="true"
        growingThreshold="50"
        mode="SingleSelectMaster"
        selectionChange=".onContractSelect"
        noDataText="{i18n>noContracts}"
        busy="{ctr>/busy}">

        <columns>
          <Column><header><Text text="{i18n>id}" /></header></Column>
          <Column><header><Text text="{i18n>commodity}" /></header></Column>
          <Column><header><Text text="{i18n>quantityMt}" /></header></Column>
          <Column><header><Text text="{i18n>classification}" /></header></Column>
          <Column><header><Text text="{i18n>fixedLegSide}" /></header></Column>
          <Column><header><Text text="{i18n>variableLegSide}" /></header></Column>
          <Column><header><Text text="{i18n>counterparty}" /></header></Column>
          <Column><header><Text text="{i18n>fixedPrice}" /></header></Column>
          <Column><header><Text text="{i18n>status}" /></header></Column>
          <Column><header><Text text="{i18n>createdAt}" /></header></Column>
        </columns>

        <items>
          <ColumnListItem type="Navigation">
            <Text text="{ path: 'ctr>id', formatter: 'formatter.shortUuid' }" />
            <Text text="{ctr>commodity}" />
            <ObjectNumber number="{ path: 'ctr>quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
            <ObjectStatus text="{ path: 'ctr>classification', formatter: 'formatter.capitalize' }"
              state="{ path: 'ctr>classification', formatter: '.formatClassificationState' }" />
            <Text text="{ path: 'ctr>fixed_leg_side', formatter: 'formatter.capitalize' }" />
            <Text text="{ path: 'ctr>variable_leg_side', formatter: 'formatter.capitalize' }" />
            <Text text="{ctr>counterparty_id}" />
            <ObjectNumber number="{ path: 'ctr>fixed_price_value', formatter: 'formatter.priceFourDecimals' }"
              unit="{ctr>fixed_price_unit}" />
            <ObjectStatus text="{ path: 'ctr>status', formatter: 'formatter.capitalize' }"
              state="{ path: 'ctr>status', formatter: 'formatter.statusState' }" />
            <Text text="{ path: 'ctr>created_at', formatter: 'formatter.dateDisplay' }" />
          </ColumnListItem>
        </items>
      </Table>
    </f:content>

  </f:DynamicPage>
</mvc:View>
