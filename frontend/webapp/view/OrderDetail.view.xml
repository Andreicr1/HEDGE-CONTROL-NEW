<mvc:View
  controllerName="hedgecontrol.controller.OrderDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:f="sap.f"
  xmlns:l="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <uxap:ObjectPageLayout id="orderDetailPage" showTitleInHeaderContent="true" busy="{ordDet>/busy}">
    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <HBox alignItems="Center">
            <Title text="{i18n>orderDetailTitle}" class="sapUiSmallMarginEnd" />
            <ObjectStatus text="{ordDet>/detail/order_type}" state="{= ${ordDet>/detail/order_type} === 'SO' ? 'Information' : 'Warning'}" />
          </HBox>
        </uxap:heading>
        <uxap:actions>
          <Button icon="sap-icon://decline" press=".onClose" tooltip="{i18n>close}" type="Transparent" />
        </uxap:actions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>
    <uxap:headerContent>
      <l:HorizontalLayout class="sapUiSmallMarginBeginEnd">
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colId}" />
          <Text text="{path: 'ordDet>/detail/id', formatter: 'formatter.shortUuid'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colQuantityMt}" />
          <Text text="{path: 'ordDet>/detail/quantity_mt', formatter: 'formatter.numberTwoDecimals'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colCreatedAt}" />
          <Text text="{path: 'ordDet>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
        </VBox>
      </l:HorizontalLayout>
    </uxap:headerContent>
    <uxap:sections>
      <uxap:ObjectPageSection title="{i18n>sectionGeneral}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <MessageStrip
                  text="{ordDet>/errorMessage}"
                  type="Error"
                  showIcon="true"
                  showCloseButton="true"
                  visible="{= !!${ordDet>/errorMessage}}"
                  class="sapUiSmallMarginBottom" />
                <form:Form editable="false">
                  <form:layout>
                    <form:ColumnLayout columnsM="1" columnsL="2" columnsXL="2" />
                  </form:layout>
                  <form:formContainers>
                    <form:FormContainer title="{i18n>sectionOrderInfo}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colOrderType}">
                          <form:fields>
                            <Text text="{ordDet>/detail/order_type}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colPriceType}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/price_type', formatter: 'formatter.capitalize'}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colQuantityMt}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/quantity_mt', formatter: 'formatter.numberTwoDecimals'}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colPricingConvention}">
                          <form:fields>
                            <Text text="{ordDet>/detail/pricing_convention}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colAvgEntryPrice}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/avg_entry_price', formatter: 'formatter.priceFourDecimals'}" />
                          </form:fields>
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>sectionTimestamps}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colCreatedAt}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colDeletedAt}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/deleted_at', formatter: 'formatter.dateTimeDisplay'}" />
                          </form:fields>
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                  </form:formContainers>
                </form:Form>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
      <uxap:ObjectPageSection title="{i18n>sectionSoPoLinks}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <Table items="{ordDet>/links}" noDataText="{i18n>noSoPoLinks}">
                  <headerToolbar>
                    <OverflowToolbar>
                      <Title text="{i18n>sectionSoPoLinks}" level="H3" />
                      <ToolbarSpacer />
                      <Button text="{i18n>addSoPoLink}" icon="sap-icon://add" press=".onAddLink" type="Emphasized"
                        visible="{= !${ordDet>/detail/deleted_at}}" />
                    </OverflowToolbar>
                  </headerToolbar>
                  <columns>
                    <Column><header><Text text="{i18n>colSalesOrderId}" /></header></Column>
                    <Column><header><Text text="{i18n>colPurchaseOrderId}" /></header></Column>
                    <Column hAlign="End"><header><Text text="{i18n>linkedTons}" /></header></Column>
                    <Column><header><Text text="{i18n>colCreatedAt}" /></header></Column>
                  </columns>
                  <items>
                    <ColumnListItem>
                      <cells>
                        <Text text="{path: 'ordDet>sales_order_id', formatter: 'formatter.shortUuid'}" />
                        <Text text="{path: 'ordDet>purchase_order_id', formatter: 'formatter.shortUuid'}" />
                        <Text text="{path: 'ordDet>linked_tons', formatter: 'formatter.numberTwoDecimals'}" />
                        <Text text="{path: 'ordDet>created_at', formatter: 'formatter.dateTimeDisplay'}" />
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
      <uxap:ObjectPageSection title="{i18n>sectionActions}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <HBox>
                <Button text="{i18n>archiveOrder}" icon="sap-icon://delete" press=".onArchive" type="Reject"
                  visible="{= !${ordDet>/detail/deleted_at}}" />
              </HBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
    </uxap:sections>
  </uxap:ObjectPageLayout>
</mvc:View>
