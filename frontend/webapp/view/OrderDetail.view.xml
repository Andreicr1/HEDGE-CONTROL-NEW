<mvc:View
  controllerName="hedgecontrol.controller.OrderDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:f="sap.f"
  xmlns:l="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <uxap:ObjectPageLayout id="orderDetailPage" showTitleInHeaderContent="true" preserveHeaderStateOnScroll="true" busy="{ordDet>/busy}">
    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <HBox alignItems="Center">
            <Title text="{i18n>orderDetailTitle}" class="sapUiSmallMarginEnd" />
            <ObjectStatus text="{ordDet>/detail/order_type}" state="{= ${ordDet>/detail/order_type} === 'SO' ? 'Information' : 'Warning'}" />
          </HBox>
        </uxap:heading>
        <uxap:actions>
          <Button text="Hedge" icon="sap-icon://shield" press=".onHedge" type="Emphasized"
                  visible="{= !${ordDet>/detail/deleted_at} &amp;&amp; ${ordDet>/detail/price_type} === 'variable'}" />
          <Button icon="sap-icon://decline" press=".onClose" tooltip="{i18n>close}" type="Transparent" />
        </uxap:actions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>
    <uxap:headerContent>
      <l:HorizontalLayout class="sapUiSmallMarginBeginEnd">
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colId}" />
          <Text text="{path: 'ordDet>/detail/id', formatter: 'formatter.shortUuid'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colQuantityMt}" />
          <Text text="{path: 'ordDet>/detail/quantity_mt', formatter: 'formatter.numberTwoDecimals'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colCreatedAt}" />
          <Text text="{path: 'ordDet>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
        </VBox>
      </l:HorizontalLayout>
    </uxap:headerContent>
    <uxap:sections>
      <uxap:ObjectPageSection title="{i18n>sectionGeneral}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <MessageStrip
                  text="{ordDet>/errorMessage}"
                  type="Error"
                  showIcon="true"
                  showCloseButton="true"
                  visible="{= !!${ordDet>/errorMessage}}"
                  class="sapUiSmallMarginBottom" />
                <form:Form editable="false">
                  <form:layout>
                    <form:ColumnLayout columnsM="1" columnsL="2" columnsXL="2" />
                  </form:layout>
                  <form:formContainers>
                    <form:FormContainer title="{i18n>sectionOrderInfo}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colOrderType}">
                          <form:fields>
                            <Text text="{ordDet>/detail/order_type}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>counterpartyNameLabel}"
                          visible="{= !!${ordDet>/detail/counterparty_name} }">
                          <form:fields>
                            <Text text="{ordDet>/detail/counterparty_name}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colPriceType}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/price_type', formatter: 'formatter.capitalize'}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colQuantityMt}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/quantity_mt', formatter: 'formatter.numberTwoDecimals'}" />
                          </form:fields>
                        </form:FormElement>
                        <!-- Fixed price -->
                        <form:FormElement label="{i18n>colFixedPriceValue}"
                          visible="{= ${ordDet>/detail/price_type} === 'fixed' &amp;&amp; !!${ordDet>/detail/avg_entry_price} }">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/avg_entry_price', formatter: 'formatter.priceFourDecimals'}" />
                          </form:fields>
                        </form:FormElement>
                        <!-- Variable: convention -->
                        <form:FormElement label="{i18n>colPricingConvention}"
                          visible="{= ${ordDet>/detail/price_type} === 'variable' &amp;&amp; !!${ordDet>/detail/pricing_convention} }">
                          <form:fields>
                            <Text text="{ordDet>/detail/pricing_convention}" />
                          </form:fields>
                        </form:FormElement>
                        <!-- AVG: reference month -->
                        <form:FormElement label="{i18n>referenceMonth}"
                          visible="{= ${ordDet>/detail/pricing_convention} === 'AVG' &amp;&amp; !!${ordDet>/detail/reference_month} }">
                          <form:fields>
                            <Text text="{ordDet>/detail/reference_month}" />
                          </form:fields>
                        </form:FormElement>
                        <!-- AVGInter: observation dates -->
                        <form:FormElement label="{i18n>observationDateStart}"
                          visible="{= ${ordDet>/detail/pricing_convention} === 'AVGInter' &amp;&amp; !!${ordDet>/detail/observation_date_start} }">
                          <form:fields>
                            <Text text="{ordDet>/detail/observation_date_start}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>observationDateEnd}"
                          visible="{= ${ordDet>/detail/pricing_convention} === 'AVGInter' &amp;&amp; !!${ordDet>/detail/observation_date_end} }">
                          <form:fields>
                            <Text text="{ordDet>/detail/observation_date_end}" />
                          </form:fields>
                        </form:FormElement>
                        <!-- C2R: fixing date -->
                        <form:FormElement label="{i18n>fixingDate}"
                          visible="{= ${ordDet>/detail/pricing_convention} === 'C2R' &amp;&amp; !!${ordDet>/detail/fixing_date} }">
                          <form:fields>
                            <Text text="{ordDet>/detail/fixing_date}" />
                          </form:fields>
                        </form:FormElement>
                        <!-- Notes -->
                        <form:FormElement label="{i18n>notes}"
                          visible="{= !!${ordDet>/detail/notes} }">
                          <form:fields>
                            <Text text="{ordDet>/detail/notes}" />
                          </form:fields>
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>sectionTimestamps}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colCreatedAt}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
                          </form:fields>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colDeletedAt}">
                          <form:fields>
                            <Text text="{path: 'ordDet>/detail/deleted_at', formatter: 'formatter.dateTimeDisplay'}" />
                          </form:fields>
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                  </form:formContainers>
                </form:Form>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
      <uxap:ObjectPageSection title="{i18n>sectionDeal}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox class="sapUiSmallMargin">
                <MessageStrip text="{i18n>noDealLinked}" type="Warning" showIcon="true"
                  visible="{= !${ordDet>/deal} }" class="sapUiSmallMarginBottom" />
                <HBox alignItems="Center" visible="{= !!${ordDet>/deal} }">
                  <core:Icon src="sap-icon://chain-link" class="sapUiSmallMarginEnd" />
                  <Link text="{ordDet>/deal/name}" press=".onNavigateToDeal" />
                  <Text text=" — {ordDet>/deal/commodity}" class="sapUiSmallMarginBegin" />
                </HBox>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
      <uxap:ObjectPageSection title="{i18n>sectionLinkedContracts}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <Table items="{ordDet>/linkages}" noDataText="{i18n>noLinkedContracts}">
                <columns>
                  <Column><header><Text text="{i18n>colContractId}" /></header></Column>
                  <Column hAlign="End"><header><Text text="{i18n>colQuantityMt}" /></header></Column>
                  <Column><header><Text text="{i18n>createdAt}" /></header></Column>
                </columns>
                <items>
                  <ColumnListItem type="Navigation" press=".onNavigateToContract">
                    <cells>
                      <Text text="{path: 'ordDet>contract_id', formatter: 'formatter.shortUuid'}" />
                      <ObjectNumber number="{path: 'ordDet>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
                      <Text text="{path: 'ordDet>created_at', formatter: 'formatter.dateTimeDisplay'}" />
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
      <uxap:ObjectPageSection title="{i18n>sectionActions}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <HBox>
                <Button text="{i18n>archiveOrder}" icon="sap-icon://delete" press=".onArchive" type="Reject"
                  visible="{= !${ordDet>/detail/deleted_at}}" />
              </HBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
    </uxap:sections>
  </uxap:ObjectPageLayout>
</mvc:View>
