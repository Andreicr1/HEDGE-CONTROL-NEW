<mvc:View
  controllerName="hedgecontrol.controller.AuditTrail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">
  <f:DynamicPage id="auditTrailPage" showFooter="false" busy="{audit>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>auditTrailTitle}" />
        </f:heading>
        <f:actions>
          <Button icon="sap-icon://refresh" press=".onRefresh" tooltip="{i18n>refresh}" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{audit>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${audit>/errorMessage}}"
          class="sapUiSmallMarginBottom" />

        <!-- Verify result banner -->
        <MessageStrip
          text="{= ${audit>/verifyResult/valid} ? 'Assinatura v\u00e1lida (evento: ' + ${audit>/verifyResult/event_id} + ')' : ${audit>/verifyResult/detail}}"
          type="{= ${audit>/verifyResult/valid} ? 'Success' : 'Warning'}"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${audit>/verifyResult}}"
          class="sapUiSmallMarginBottom" />

        <!-- Filter bar -->
        <OverflowToolbar class="sapUiSmallMarginBottom">
          <Label text="{i18n>filterEntityType}" />
          <Select selectedKey="{audit>/entityTypeFilter}" change=".onFilterChange">
            <core:Item key="" text="{i18n>allEntities}" />
            <core:Item key="order" text="Order" />
            <core:Item key="contract" text="Contract" />
            <core:Item key="hedge" text="Hedge" />
            <core:Item key="rfq" text="RFQ" />
            <core:Item key="counterparty" text="Counterparty" />
            <core:Item key="deal" text="Deal" />
            <core:Item key="exposure" text="Exposure" />
          </Select>
          <ToolbarSpacer />
          <SearchField width="15rem" search=".onSearch" />
        </OverflowToolbar>

        <Table id="auditTable" items="{audit>/events}" growing="true" growingThreshold="50"
          noDataText="{i18n>noAuditEvents}" mode="None">
          <columns>
            <Column width="8rem"><header><Text text="{i18n>colId}" /></header></Column>
            <Column><header><Text text="{i18n>colTimestamp}" /></header></Column>
            <Column><header><Text text="{i18n>colEntityType}" /></header></Column>
            <Column><header><Text text="{i18n>colEntityId}" /></header></Column>
            <Column><header><Text text="{i18n>colEventType}" /></header></Column>
            <Column width="6rem" hAlign="Center"><header><Text text="{i18n>colSignature}" /></header></Column>
            <Column width="6rem" hAlign="Center"><header><Text text="" /></header></Column>
          </columns>
          <items>
            <ColumnListItem>
              <cells>
                <Text text="{path: 'audit>id', formatter: 'formatter.shortUuid'}" />
                <Text text="{path: 'audit>timestamp_utc', formatter: 'formatter.dateTimeDisplay'}" />
                <ObjectStatus text="{audit>entity_type}" />
                <Text text="{path: 'audit>entity_id', formatter: 'formatter.shortUuid'}" />
                <ObjectStatus text="{audit>event_type}"
                  state="{= ${audit>event_type} === 'created' ? 'Success' : (${audit>event_type} === 'deleted' ? 'Error' : 'Information')}" />
                <Icon src="{= ${audit>signature} ? 'sap-icon://accept' : 'sap-icon://alert'}"
                  color="{= ${audit>signature} ? '#107E3E' : '#E78C07'}" />
                <Button text="{i18n>verify}" icon="sap-icon://inspect" press=".onVerify" type="Transparent" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </f:content>
  </f:DynamicPage>
</mvc:View>
