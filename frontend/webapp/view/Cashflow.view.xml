<mvc:View
  controllerName="hedgecontrol.controller.Cashflow"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:t="sap.ui.table"
  xmlns:viz="sap.viz.ui5.controls"
  xmlns:vizData="sap.viz.ui5.data"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="cashflowPage" headerExpanded="true" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>cashflowTitle}" />
        </f:heading>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <HBox alignItems="End" class="sapUiSmallMarginBottom">
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>asOfDate}" />
            <DatePicker id="projectionDate" displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd" placeholder="dd/MM/yyyy" />
          </VBox>
          <Button text="{i18n>projectionLoadBtn}" type="Emphasized" press=".onLoadProjection" />
        </HBox>

        <!-- Summary cards -->
        <HBox class="sapUiSmallMarginBottom" visible="{cf>/projectionLoaded}">
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>projectionTotalInflows}" />
            <ObjectNumber number="{ path: 'cf>/projection/summary/total_inflows', formatter: 'formatter.numberTwoDecimals' }"
              unit="USD" state="Success" emphasized="true" />
          </VBox>
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>projectionTotalOutflows}" />
            <ObjectNumber number="{ path: 'cf>/projection/summary/total_outflows', formatter: 'formatter.numberTwoDecimals' }"
              unit="USD" state="Error" emphasized="true" />
          </VBox>
          <VBox class="sapUiSmallMarginEnd">
            <Label text="{i18n>projectionNetCashflow}" />
            <ObjectNumber number="{ path: 'cf>/projection/summary/net_cashflow', formatter: 'formatter.numberTwoDecimals' }"
              unit="USD" emphasized="true" />
          </VBox>
          <VBox>
            <Label text="{i18n>projectionInstrumentCount}" />
            <ObjectNumber number="{cf>/projection/summary/instrument_count}" />
          </VBox>
        </HBox>

        <!-- VizFrame: monthly Inflows / Outflows / Net -->
        <viz:VizFrame id="cashflowChart"
          vizType="line"
          width="100%"
          height="300px"
          class="hcVizFrame sapUiSmallMarginBottom"
          visible="{cf>/projectionLoaded}">
          <viz:dataset>
            <vizData:FlattenedDataset data="{path: 'cf>/chartData'}">
              <vizData:dimensions>
                <vizData:DimensionDefinition name="Período" value="{label}" />
              </vizData:dimensions>
              <vizData:measures>
                <vizData:MeasureDefinition name="Inflows" value="{inflows}" />
                <vizData:MeasureDefinition name="Outflows" value="{outflows}" />
                <vizData:MeasureDefinition name="Net" value="{net}" />
              </vizData:measures>
            </vizData:FlattenedDataset>
          </viz:dataset>
          <viz:feeds>
            <viz:FeedItem id="cfValueAxis" uid="valueAxis" values="['Inflows','Outflows','Net']" />
            <viz:FeedItem id="cfCategoryAxis" uid="categoryAxis" values="['Período']" />
          </viz:feeds>
        </viz:VizFrame>

        <!-- TreeTable: Quarter → Month → Day items -->
        <t:TreeTable id="projectionTreeTable"
          rows="{path: 'cf>/projectionTree', parameters: { arrayNames: ['children'] }}"
          selectionMode="None"
          visibleRowCountMode="Auto"
          minAutoRowCount="15"
          enableColumnReordering="false"
          expandFirstLevel="true"
          visible="{cf>/projectionLoaded}"
          busy="{cf>/projectionBusy}">
          <t:toolbar>
            <Toolbar>
              <Title text="{i18n>projectionTreeTitle}" level="H4" />
              <ToolbarSpacer />
              <Button icon="sap-icon://expand-all" tooltip="{i18n>projectionExpandAll}" press=".onProjectionExpandAll" />
              <Button icon="sap-icon://collapse-all" tooltip="{i18n>projectionCollapseAll}" press=".onProjectionCollapseAll" />
            </Toolbar>
          </t:toolbar>
          <t:columns>
            <t:Column width="22rem">
              <Label text="{i18n>projectionColDescription}" />
              <t:template>
                <Text text="{cf>description}" wrapping="false" />
              </t:template>
            </t:Column>
            <t:Column width="8rem" hAlign="Center">
              <Label text="{i18n>colInstrumentType}" />
              <t:template>
                <Text text="{cf>instrumentType}" />
              </t:template>
            </t:Column>
            <t:Column width="8rem" hAlign="Center">
              <Label text="{i18n>colCommodity}" />
              <t:template>
                <Text text="{cf>commodity}" />
              </t:template>
            </t:Column>
            <t:Column width="8rem" hAlign="Center">
              <Label text="{i18n>colSettlementDate}" />
              <t:template>
                <Text text="{cf>settlementDate}" />
              </t:template>
            </t:Column>
            <t:Column width="9rem" hAlign="End">
              <Label text="{i18n>colQuantityMt}" />
              <t:template>
                <Text text="{ path: 'cf>quantity', formatter: 'formatter.numberTwoDecimals' }" />
              </t:template>
            </t:Column>
            <t:Column width="9rem" hAlign="End">
              <Label text="{i18n>colPricePerMt}" />
              <t:template>
                <Text text="{ path: 'cf>price', formatter: 'formatter.numberTwoDecimals' }" />
              </t:template>
            </t:Column>
            <t:Column width="10rem" hAlign="End">
              <Label text="{i18n>projectionColInflows}" />
              <t:template>
                <ObjectNumber number="{ path: 'cf>inflows', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                  state="Success" />
              </t:template>
            </t:Column>
            <t:Column width="10rem" hAlign="End">
              <Label text="{i18n>projectionColOutflows}" />
              <t:template>
                <ObjectNumber number="{ path: 'cf>outflows', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                  state="Error" />
              </t:template>
            </t:Column>
            <t:Column width="10rem" hAlign="End">
              <Label text="{i18n>projectionColNet}" />
              <t:template>
                <ObjectNumber number="{ path: 'cf>net', formatter: 'formatter.numberTwoDecimals' }" unit="USD"
                  state="{ path: 'cf>net', formatter: '.formatAmountState' }" />
              </t:template>
            </t:Column>
            <t:Column width="6rem" hAlign="Center">
              <Label text="{i18n>colPriceSource}" />
              <t:template>
                <Text text="{cf>priceSource}" />
              </t:template>
            </t:Column>
            <t:Column width="7rem" hAlign="Center">
              <Label text="{i18n>colDealId}" />
              <t:template>
                <Text text="{cf>dealId}" />
              </t:template>
            </t:Column>
          </t:columns>
        </t:TreeTable>

        <!-- Empty state -->
        <IllustratedMessage
          visible="{= !${cf>/projectionLoaded} }"
          illustrationType="sapIllus-NoData"
          title="{i18n>projection}"
          description="{i18n>projectionNoItems}" />
      </VBox>
    </f:content>

  </f:DynamicPage>
</mvc:View>
