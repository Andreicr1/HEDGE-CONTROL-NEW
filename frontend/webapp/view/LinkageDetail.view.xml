<mvc:View
  controllerName="hedgecontrol.controller.LinkageDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:uxap="sap.uxap"
  xmlns:layout="sap.ui.layout"
  xmlns:form="sap.ui.layout.form"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <uxap:ObjectPageLayout id="linkageDetailPage" busy="{lnkDet>/busy}" showTitleInHeaderContent="true">

    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <Title text="{i18n>hedgeOrderLinkage}" />
        </uxap:heading>
        <uxap:actions>
          <Button text="{i18n>close}" icon="sap-icon://decline" type="Default" press=".onClose" />
        </uxap:actions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>

    <uxap:headerContent>
      <HBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>id}" />
          <Text text="{ path: 'lnkDet>/id', formatter: 'formatter.shortUuid' }" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>quantityMt}" />
          <ObjectNumber number="{ path: 'lnkDet>/quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
        </VBox>
        <VBox>
          <Label text="{i18n>createdAt}" />
          <Text text="{ path: 'lnkDet>/created_at', formatter: 'formatter.dateTimeDisplay' }" />
        </VBox>
      </HBox>
    </uxap:headerContent>

    <uxap:sections>

      <uxap:ObjectPageSection title="{i18n>linkageInfo}">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <form:Form editable="false">
                <form:layout>
                  <form:ColumnLayout columnsM="2" columnsL="2" columnsXL="2" />
                </form:layout>
                <form:formContainers>
                  <form:FormContainer title="{i18n>references}">
                    <form:formElements>
                      <form:FormElement label="{i18n>orderId}">
                        <Text text="{lnkDet>/order_id}" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>contractId}">
                        <Text text="{lnkDet>/contract_id}" />
                      </form:FormElement>
                      <form:FormElement label="{i18n>quantityMt}">
                        <ObjectNumber number="{ path: 'lnkDet>/quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
                      </form:FormElement>
                    </form:formElements>
                  </form:FormContainer>
                  <form:FormContainer title="{i18n>timestamps}">
                    <form:formElements>
                      <form:FormElement label="{i18n>createdAt}">
                        <Text text="{ path: 'lnkDet>/created_at', formatter: 'formatter.dateTimeDisplay' }" />
                      </form:FormElement>
                    </form:formElements>
                  </form:FormContainer>
                </form:formContainers>
              </form:Form>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

    </uxap:sections>

  </uxap:ObjectPageLayout>
</mvc:View>
