<mvc:View
  controllerName="hedgecontrol.controller.HedgeCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">
  <f:DynamicPage id="hedgeCreatePage" showFooter="true" busy="{hdgCrt>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>newHedge}" />
        </f:heading>
        <f:actions>
          <Button icon="sap-icon://decline" press=".onCancel" tooltip="{i18n>cancel}" type="Transparent" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{hdgCrt>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${hdgCrt>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <form:Form id="hedgeForm" editable="true">
          <form:layout>
            <form:ColumnLayout columnsM="2" columnsL="3" columnsXL="3" />
          </form:layout>
          <form:formContainers>
            <form:FormContainer title="{i18n>sectionTradeDetails}">
              <form:formElements>
                <form:FormElement label="{i18n>colCounterpartyId}">
                  <form:fields>
                    <Input value="{hdgCrt>/form/counterparty_id}" required="true" placeholder="UUID" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colCommodity}">
                  <form:fields>
                    <Select selectedKey="{hdgCrt>/form/commodity}">
                      <core:Item key="" text="{i18n>selectCommodity}" />
                      <core:Item key="aluminium" text="{i18n>commodityAluminium}" />
                      <core:Item key="copper" text="{i18n>commodityCopper}" />
                      <core:Item key="zinc" text="{i18n>commodityZinc}" />
                      <core:Item key="nickel" text="{i18n>commodityNickel}" />
                      <core:Item key="lead" text="{i18n>commodityLead}" />
                      <core:Item key="tin" text="{i18n>commodityTin}" />
                    </Select>
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colDirection}">
                  <form:fields>
                    <Select selectedKey="{hdgCrt>/form/direction}">
                      <core:Item key="buy" text="{i18n>directionBuy}" />
                      <core:Item key="sell" text="{i18n>directionSell}" />
                    </Select>
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
            <form:FormContainer title="{i18n>sectionPricing}">
              <form:formElements>
                <form:FormElement label="{i18n>colTons}">
                  <form:fields>
                    <Input value="{hdgCrt>/form/tons}" type="Number" required="true" placeholder="0.00" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colPricePerTon}">
                  <form:fields>
                    <Input value="{hdgCrt>/form/price_per_ton}" type="Number" required="true" placeholder="0.0000" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colPremiumDiscount}">
                  <form:fields>
                    <Input value="{hdgCrt>/form/premium_discount}" type="Number" placeholder="0.00" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
            <form:FormContainer title="{i18n>sectionDates}">
              <form:formElements>
                <form:FormElement label="{i18n>colSettlementDate}">
                  <form:fields>
                    <DatePicker value="{hdgCrt>/form/settlement_date}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" required="true" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colPromptDate}">
                  <form:fields>
                    <DatePicker value="{hdgCrt>/form/prompt_date}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colNotes}">
                  <form:fields>
                    <TextArea value="{hdgCrt>/form/notes}" rows="3" growing="true" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
          </form:formContainers>
        </form:Form>
      </VBox>
    </f:content>
    <f:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="{i18n>submit}" press=".onSubmit" type="Emphasized" />
        <Button text="{i18n>cancel}" press=".onCancel" />
      </OverflowToolbar>
    </f:footer>
  </f:DynamicPage>
</mvc:View>
