<mvc:View
  controllerName="hedgecontrol.controller.RfqDocument"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core">
  <Page
    id="rfqDocumentPage"
    title="{rfqDoc>/title}"
    busy="{rfqDoc>/busy}"
    class="sapUiResponsivePadding--header sapUiResponsivePadding--content">

    <headerContent>
      <Button icon="sap-icon://download" press=".onDownload" tooltip="{i18n>download}" type="Transparent"
        visible="{= !!${rfqDoc>/pdfSource}}" />
      <Button icon="sap-icon://full-screen" press=".onToggleEndFullScreen" tooltip="{i18n>fullScreen}" type="Transparent" />
      <Button icon="sap-icon://decline" press=".onCloseEndColumn" tooltip="{i18n>close}" type="Transparent" />
    </headerContent>

    <content>
      <!-- PDF Viewer -->
      <PDFViewer
        id="rfqPdfViewer"
        source="{rfqDoc>/pdfSource}"
        title="{rfqDoc>/title}"
        height="100%"
        isTrustedSource="true"
        showDownloadButton="false"
        visible="{= !!${rfqDoc>/pdfSource}}"
        loaded=".onPdfLoaded"
        error=".onPdfError" />

      <!-- Loading indicator -->
      <BusyIndicator
        size="L"
        visible="{= ${rfqDoc>/loading} &amp;&amp; !${rfqDoc>/pdfSource}}"
        class="sapUiMediumMarginTop" />

      <!-- Error message -->
      <MessageStrip
        text="{rfqDoc>/errorMessage}"
        type="Error"
        showIcon="true"
        showCloseButton="true"
        visible="{= !!${rfqDoc>/errorMessage}}"
        class="sapUiSmallMargin" />

      <!-- Placeholder when no document is loaded -->
      <IllustratedMessage
        illustrationType="sapIllus-NoData"
        title="{i18n>noDocumentSelected}"
        description="{i18n>noDocumentSelectedDesc}"
        visible="{= !${rfqDoc>/pdfSource} &amp;&amp; !${rfqDoc>/loading} &amp;&amp; !${rfqDoc>/errorMessage}}" />
    </content>
  </Page>
</mvc:View>
