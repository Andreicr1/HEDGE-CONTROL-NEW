<mvc:View
  controllerName="hedgecontrol.controller.RfqDocument"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:html="http://www.w3.org/1999/xhtml">
  <Page
    id="rfqDocumentPage"
    title="{rfqDoc>/title}"
    busy="{rfqDoc>/busy}"
    class="sapUiResponsivePadding--header sapUiResponsivePadding--content">

    <headerContent>
      <Button icon="sap-icon://full-screen" press=".onToggleEndFullScreen" tooltip="{i18n>fullScreen}" type="Transparent" />
      <Button icon="sap-icon://decline" press=".onCloseEndColumn" tooltip="{i18n>close}" type="Transparent" />
    </headerContent>

    <content>
      <MessageStrip
        text="{rfqDoc>/errorMessage}"
        type="Error"
        showIcon="true"
        showCloseButton="true"
        visible="{= !!${rfqDoc>/errorMessage}}"
        class="sapUiSmallMargin" />

      <BusyIndicator
        size="L"
        visible="{rfqDoc>/loading}"
        class="sapUiMediumMarginTop" />

      <ScrollContainer
        height="100%"
        width="100%"
        vertical="true"
        visible="{= !!${rfqDoc>/htmlContent}}">
        <core:HTML content="{rfqDoc>/htmlContent}" preferDOM="false" />
      </ScrollContainer>

      <IllustratedMessage
        illustrationType="sapIllus-NoData"
        title="{i18n>noDocumentSelected}"
        description="{i18n>noDocumentSelectedDesc}"
        visible="{= !${rfqDoc>/htmlContent} &amp;&amp; !${rfqDoc>/loading} &amp;&amp; !${rfqDoc>/errorMessage}}" />
    </content>
  </Page>
</mvc:View>
