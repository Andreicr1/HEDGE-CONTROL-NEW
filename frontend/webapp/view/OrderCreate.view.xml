<mvc:View
  controllerName="hedgecontrol.controller.OrderCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.f"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core">
  <f:DynamicPage id="orderCreatePage" showFooter="true" busy="{ordCrt>/busy}">
    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{ordCrt>/pageTitle}" />
        </f:heading>
        <f:actions>
          <Button icon="sap-icon://decline" press=".onCancel" tooltip="{i18n>cancel}" type="Transparent" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>
    <f:content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{ordCrt>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${ordCrt>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <form:Form id="orderForm" editable="true">
          <form:layout>
            <form:ColumnLayout columnsM="1" columnsL="1" columnsXL="1" />
          </form:layout>
          <form:formContainers>
            <!-- Deal -->
            <form:FormContainer title="{i18n>colDeal}">
              <form:formElements>
                <form:FormElement label="{i18n>selectDeal}">
                  <form:fields>
                    <Select id="dealSelect" selectedKey="{ordCrt>/form/deal_id}"
                      items="{ordCrt>/deals}" forceSelection="false"
                      change=".onDealChange">
                      <core:Item key="" text="— {i18n>selectDeal} —" />
                      <core:Item key="{ordCrt>id}" text="{ordCrt>name} ({ordCrt>commodity})" />
                    </Select>
                  </form:fields>
                </form:FormElement>
                <form:FormElement>
                  <form:fields>
                    <Link text="{i18n>createNewDeal}" press=".onCreateNewDeal" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>

            <!-- Client / Supplier -->
            <form:FormContainer title="{i18n>sectionCounterparty}">
              <form:formElements>
                <form:FormElement label="{i18n>counterpartyNameLabel}">
                  <form:fields>
                    <Input id="counterpartyName" value="{ordCrt>/form/counterparty_name}"
                      placeholder="{i18n>placeholderCounterpartyName}" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>

            <!-- Price Type -->
            <form:FormContainer title="{i18n>sectionPricing}">
              <form:formElements>
                <form:FormElement label="{i18n>colPriceType}">
                  <form:fields>
                    <Select id="priceType" selectedKey="{ordCrt>/form/price_type}"
                      change=".onPriceTypeChange">
                      <core:Item key="fixed" text="{i18n>priceTypeFixed}" />
                      <core:Item key="variable" text="{i18n>priceTypeVariable}" />
                    </Select>
                  </form:fields>
                </form:FormElement>

                <!-- Fixed: price value -->
                <form:FormElement label="{i18n>colFixedPriceValue}"
                  visible="{= ${ordCrt>/form/price_type} === 'fixed'}">
                  <form:fields>
                    <Input id="avgEntryPrice" value="{ordCrt>/form/avg_entry_price}" type="Number"
                      placeholder="0.0000" required="true" />
                  </form:fields>
                </form:FormElement>

                <!-- Variable: pricing convention -->
                <form:FormElement label="{i18n>colPricingConvention}"
                  visible="{= ${ordCrt>/form/price_type} === 'variable'}">
                  <form:fields>
                    <Select id="pricingConvention" selectedKey="{ordCrt>/form/pricing_convention}"
                      change=".onConventionChange">
                      <core:Item key="" text="— {i18n>selectConvention} —" />
                      <core:Item key="AVG" text="{i18n>optAvg}" />
                      <core:Item key="AVGInter" text="{i18n>optAvgInter}" />
                      <core:Item key="C2R" text="{i18n>optC2R}" />
                    </Select>
                  </form:fields>
                </form:FormElement>

                <!-- AVG: reference month -->
                <form:FormElement label="{i18n>referenceMonth}"
                  visible="{= ${ordCrt>/form/price_type} === 'variable' &amp;&amp; ${ordCrt>/form/pricing_convention} === 'AVG'}">
                  <form:fields>
                    <Input id="referenceMonth" value="{ordCrt>/form/reference_month}"
                      placeholder="yyyy-MM" maxLength="7" />
                  </form:fields>
                </form:FormElement>

                <!-- AVGInter: observation date range -->
                <form:FormElement label="{i18n>observationDateStart}"
                  visible="{= ${ordCrt>/form/price_type} === 'variable' &amp;&amp; ${ordCrt>/form/pricing_convention} === 'AVGInter'}">
                  <form:fields>
                    <DatePicker id="obsStart" value="{ordCrt>/form/observation_date_start}"
                      valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" placeholder="dd/MM/yyyy" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>observationDateEnd}"
                  visible="{= ${ordCrt>/form/price_type} === 'variable' &amp;&amp; ${ordCrt>/form/pricing_convention} === 'AVGInter'}">
                  <form:fields>
                    <DatePicker id="obsEnd" value="{ordCrt>/form/observation_date_end}"
                      valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" placeholder="dd/MM/yyyy" />
                  </form:fields>
                </form:FormElement>

                <!-- C2R: fixing date -->
                <form:FormElement label="{i18n>fixingDate}"
                  visible="{= ${ordCrt>/form/price_type} === 'variable' &amp;&amp; ${ordCrt>/form/pricing_convention} === 'C2R'}">
                  <form:fields>
                    <DatePicker id="fixingDate" value="{ordCrt>/form/fixing_date}"
                      valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" placeholder="dd/MM/yyyy" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>

            <!-- Quantity -->
            <form:FormContainer title="{i18n>sectionQuantity}">
              <form:formElements>
                <form:FormElement label="{i18n>colQuantityMt}">
                  <form:fields>
                    <Input id="quantityMt" value="{ordCrt>/form/quantity_mt}" type="Number"
                      placeholder="0.00" required="true" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>

            <!-- Notes -->
            <form:FormContainer title="{i18n>sectionNotes}">
              <form:formElements>
                <form:FormElement label="{i18n>notes}">
                  <form:fields>
                    <TextArea id="orderNotes" value="{ordCrt>/form/notes}" rows="3"
                      placeholder="{i18n>placeholderNotes}" growing="true" growingMaxLines="6" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
          </form:formContainers>
        </form:Form>
      </VBox>
    </f:content>
    <f:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="{i18n>submit}" press=".onSubmit" type="Emphasized" />
        <Button text="{i18n>cancel}" press=".onCancel" />
      </OverflowToolbar>
    </f:footer>
  </f:DynamicPage>
</mvc:View>
