<mvc:View
  controllerName="hedgecontrol.controller.ContractCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  xmlns:layout="sap.ui.layout"
  xmlns:form="sap.ui.layout.form">

  <f:DynamicPage id="contractCreatePage" showFooter="true">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>newHedgeContract}" />
        </f:heading>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <VBox class="sapUiSmallMargin">
        <form:Form id="contractCreateForm" editable="true">
          <form:layout>
            <form:ColumnLayout columnsM="1" columnsL="2" columnsXL="2" />
          </form:layout>
          <form:formContainers>

            <form:FormContainer title="{i18n>contractInfo}">
              <form:formElements>
                <form:FormElement label="{i18n>commodity}">
                  <Input id="commodityInput" value="{ctrCrt>/commodity}" required="true" placeholder="{i18n>placeholderCommodity}" />
                </form:FormElement>
                <form:FormElement label="{i18n>quantityMt}">
                  <Input id="quantityInput" value="{ctrCrt>/quantity_mt}" type="Number" required="true" placeholder="0.00" />
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>

            <form:FormContainer title="{i18n>fixedLeg}">
              <form:formElements>
                <form:FormElement label="{i18n>side}">
                  <Select id="fixedLegSideSelect" selectedKey="{ctrCrt>/fixed_leg_side}">
                    <core:Item key="buy" text="{i18n>buy}" />
                    <core:Item key="sell" text="{i18n>sell}" />
                  </Select>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>

            <form:FormContainer title="{i18n>variableLeg}">
              <form:formElements>
                <form:FormElement label="{i18n>side}">
                  <Select id="variableLegSideSelect" selectedKey="{ctrCrt>/variable_leg_side}" enabled="false">
                    <core:Item key="buy" text="{i18n>buy}" />
                    <core:Item key="sell" text="{i18n>sell}" />
                  </Select>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>

          </form:formContainers>
        </form:Form>

        <MessageStrip text="{ctrCrt>/errorMessage}" type="Error" showIcon="true"
          visible="{ path: 'ctrCrt>/errorMessage', formatter: '.hasError' }" class="sapUiSmallMarginTop" />
      </VBox>
    </f:content>

    <f:footer>
      <OverflowToolbar>
        <ToolbarSpacer />
        <Button text="{i18n>submit}" type="Emphasized" press=".onSubmit" />
        <Button text="{i18n>cancel}" press=".onCancel" />
      </OverflowToolbar>
    </f:footer>

  </f:DynamicPage>
</mvc:View>
