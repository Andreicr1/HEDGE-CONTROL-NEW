<mvc:View
  controllerName="hedgecontrol.controller.CounterpartyDetail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:form="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <uxap:ObjectPageLayout id="counterpartyDetailPage" busy="{cptyDet>/busy}" showTitleInHeaderContent="true">

    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:heading>
          <HBox alignItems="Center">
            <Title text="{cptyDet>/detail/name}" class="sapUiSmallMarginEnd" />
            <ObjectStatus text="{path: 'cptyDet>/detail/kyc_status', formatter: 'formatter.capitalize'}"
              state="{path: 'cptyDet>/detail/kyc_status', formatter: 'formatter.statusState'}" />
          </HBox>
        </uxap:heading>
        <uxap:actions>
          <Button text="{i18n>edit}" icon="sap-icon://edit" press=".onToggleEdit"
            visible="{= !${cptyDet>/editMode}}" />
          <Button text="{i18n>save}" icon="sap-icon://save" press=".onSave" type="Emphasized"
            visible="{cptyDet>/editMode}" />
          <Button text="{i18n>deactivate}" icon="sap-icon://delete" type="Reject" press=".onDeactivate"
            visible="{= ${cptyDet>/detail/is_active} === true}" />
          <Button text="{i18n>close}" icon="sap-icon://decline" press=".onClose" />
        </uxap:actions>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>

    <uxap:headerContent>
      <HBox wrap="Wrap">
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colType}" design="Bold" />
          <ObjectStatus text="{path: 'cptyDet>/detail/type', formatter: 'formatter.capitalize'}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colCountry}" design="Bold" />
          <Text text="{cptyDet>/detail/country}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colRiskRating}" design="Bold" />
          <ObjectStatus text="{path: 'cptyDet>/detail/risk_rating', formatter: 'formatter.capitalize'}"
            state="{= ${cptyDet>/detail/risk_rating} === 'low' ? 'Success' : (${cptyDet>/detail/risk_rating} === 'high' ? 'Error' : 'Warning')}" />
        </VBox>
        <VBox class="sapUiSmallMarginEnd">
          <Label text="{i18n>colActive}" design="Bold" />
          <Text text="{path: 'cptyDet>/detail/is_active', formatter: 'formatter.booleanText'}" />
        </VBox>
        <VBox>
          <Label text="{i18n>createdAt}" design="Bold" />
          <Text text="{path: 'cptyDet>/detail/created_at', formatter: 'formatter.dateTimeDisplay'}" />
        </VBox>
      </HBox>
    </uxap:headerContent>

    <uxap:sections>

      <uxap:ObjectPageSection title="{i18n>sectionCompanyInfo}" titleUppercase="false">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <uxap:blocks>
              <VBox>
                <MessageStrip text="{cptyDet>/errorMessage}" type="Error" showIcon="true"
                  showCloseButton="true" visible="{= !!${cptyDet>/errorMessage}}" class="sapUiSmallMarginBottom" />
                <form:Form editable="{cptyDet>/editMode}">
                  <form:layout>
                    <form:ColumnLayout columnsM="2" columnsL="3" columnsXL="4" />
                  </form:layout>
                  <form:formContainers>
                    <form:FormContainer title="{i18n>sectionIdentification}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colName}">
                          <Input value="{cptyDet>/detail/name}" editable="{cptyDet>/editMode}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colShortName}">
                          <Input value="{cptyDet>/detail/short_name}" editable="{cptyDet>/editMode}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colTaxId}">
                          <Input value="{cptyDet>/detail/tax_id}" editable="{cptyDet>/editMode}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colCountry}">
                          <Input value="{cptyDet>/detail/country}" editable="{cptyDet>/editMode}" maxLength="3" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colCity}">
                          <Input value="{cptyDet>/detail/city}" editable="{cptyDet>/editMode}" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>sectionContact}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colContactName}">
                          <Input value="{cptyDet>/detail/contact_name}" editable="{cptyDet>/editMode}" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colContactEmail}">
                          <Input value="{cptyDet>/detail/contact_email}" editable="{cptyDet>/editMode}" type="Email" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colContactPhone}">
                          <Input value="{cptyDet>/detail/contact_phone}" editable="{cptyDet>/editMode}" type="Tel" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>sectionFinancial}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colPaymentTerms}">
                          <Input value="{cptyDet>/detail/payment_terms_days}" editable="{cptyDet>/editMode}" type="Number" />
                        </form:FormElement>
                        <form:FormElement label="{i18n>colCreditLimit}">
                          <Input value="{cptyDet>/detail/credit_limit_usd}" editable="{cptyDet>/editMode}" type="Number" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                    <form:FormContainer title="{i18n>sectionCompliance}">
                      <form:formElements>
                        <form:FormElement label="{i18n>colKycStatus}">
                          <Select selectedKey="{cptyDet>/detail/kyc_status}" enabled="{cptyDet>/editMode}">
                            <core:Item key="pending" text="{i18n>kycPending}" />
                            <core:Item key="approved" text="{i18n>kycApproved}" />
                            <core:Item key="expired" text="{i18n>kycExpired}" />
                            <core:Item key="rejected" text="{i18n>kycRejected}" />
                          </Select>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colRiskRating}">
                          <Select selectedKey="{cptyDet>/detail/risk_rating}" enabled="{cptyDet>/editMode}">
                            <core:Item key="low" text="{i18n>riskLow}" />
                            <core:Item key="medium" text="{i18n>riskMedium}" />
                            <core:Item key="high" text="{i18n>riskHigh}" />
                          </Select>
                        </form:FormElement>
                        <form:FormElement label="{i18n>colNotes}">
                          <TextArea value="{cptyDet>/detail/notes}" editable="{cptyDet>/editMode}" rows="3" growing="true" />
                        </form:FormElement>
                      </form:formElements>
                    </form:FormContainer>
                  </form:formContainers>
                </form:Form>
              </VBox>
            </uxap:blocks>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

    </uxap:sections>

  </uxap:ObjectPageLayout>
</mvc:View>
