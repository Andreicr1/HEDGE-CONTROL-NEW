<mvc:View
  controllerName="hedgecontrol.controller.LinkagesList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="linkagesListPage" showFooter="false" busy="{lnk>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>linkagesTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newLinkage}" icon="sap-icon://add" type="Emphasized" press=".onCreateLinkage" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:content>
      <Table id="linkagesList"
        items="{ path: 'lnk>/items', sorter: { path: 'created_at', descending: true } }"
        growing="true"
        growingThreshold="50"
        mode="SingleSelectMaster"
        itemPress=".onLinkageSelect">
        <noData>
          <IllustratedMessage illustrationType="sapIllus-EmptyList"
              title="{i18n>emptyStateTitle}" description="{i18n>emptyStateDescription}" />
        </noData>
        <headerToolbar>
          <OverflowToolbar>
            <Title text="{i18n>linkagesTitle}" level="H3" />
            <ToolbarSpacer />
            <SearchField width="15rem" liveChange=".onSearch" placeholder="{i18n>searchLinkages}" />
          </OverflowToolbar>
        </headerToolbar>
        <columns>
          <Column><Text text="{i18n>colId}" /></Column>
          <Column><Text text="{i18n>colOrderId}" /></Column>
          <Column><Text text="{i18n>colContractId}" /></Column>
          <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colQuantityMt}" /></Column>
          <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colCreatedAt}" /></Column>
        </columns>
        <items>
          <ColumnListItem type="Navigation">
            <cells>
              <Text text="{path: 'lnk>id', formatter: 'formatter.shortUuid'}" />
              <Text text="{path: 'lnk>order_id', formatter: 'formatter.shortUuid'}" />
              <Text text="{path: 'lnk>contract_id', formatter: 'formatter.shortUuid'}" />
              <ObjectNumber number="{path: 'lnk>quantity_mt', formatter: 'formatter.numberTwoDecimals'}" unit="MT" />
              <Text text="{path: 'lnk>created_at', formatter: 'formatter.dateDisplay'}" />
            </cells>
          </ColumnListItem>
        </items>
      </Table>
    </f:content>
  </f:DynamicPage>
</mvc:View>
