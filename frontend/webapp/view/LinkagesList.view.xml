<mvc:View
  controllerName="hedgecontrol.controller.LinkagesList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="linkagesListPage" headerExpanded="true" showFooter="false" busy="{lnk>/busy}">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>linkagesTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newLinkage}" icon="sap-icon://add" type="Emphasized" press=".onCreateLinkage" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="20rem" liveChange=".onSearch" placeholder="{i18n>searchLinkages}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <List id="linkagesList"
        items="{ path: 'lnk>/items', sorter: { path: 'created_at', descending: true } }"
        growing="true"
        growingThreshold="50"
        mode="SingleSelectMaster"
        selectionChange=".onLinkageSelect"
        noDataText="{i18n>noLinkages}">
        <items>
          <ObjectListItem
            title="{path: 'lnk>id', formatter: 'formatter.shortUuid'}"
            type="Navigation"
            number="{path: 'lnk>quantity_mt', formatter: 'formatter.numberTwoDecimals'}"
            numberUnit="MT"
            icon="sap-icon://chain-link">
            <attributes>
              <ObjectAttribute text="{i18n>orderId}: {path: 'lnk>order_id', formatter: 'formatter.shortUuid'}" />
              <ObjectAttribute text="{i18n>contractId}: {path: 'lnk>contract_id', formatter: 'formatter.shortUuid'}" />
              <ObjectAttribute text="{path: 'lnk>created_at', formatter: 'formatter.dateDisplay'}" />
            </attributes>
          </ObjectListItem>
        </items>
      </List>
    </f:content>

  </f:DynamicPage>
</mvc:View>
