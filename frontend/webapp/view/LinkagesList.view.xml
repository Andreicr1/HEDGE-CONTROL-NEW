<mvc:View
  controllerName="hedgecontrol.controller.LinkagesList"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:f="sap.f"
  core:require="{ formatter: 'hedgecontrol/util/formatter' }">

  <f:DynamicPage id="linkagesListPage" headerExpanded="true" showFooter="false">

    <f:title>
      <f:DynamicPageTitle>
        <f:heading>
          <Title text="{i18n>linkagesTitle}" />
        </f:heading>
        <f:actions>
          <Button text="{i18n>newLinkage}" icon="sap-icon://add" type="Emphasized" press=".onCreateLinkage" />
        </f:actions>
      </f:DynamicPageTitle>
    </f:title>

    <f:header>
      <f:DynamicPageHeader>
        <HBox alignItems="Center">
          <SearchField width="20rem" liveChange=".onSearch" placeholder="{i18n>searchLinkages}" />
        </HBox>
      </f:DynamicPageHeader>
    </f:header>

    <f:content>
      <Table id="linkagesTable"
        items="{ path: 'lnk>/items', sorter: { path: 'created_at', descending: true } }"
        growing="true"
        growingThreshold="50"
        mode="SingleSelectMaster"
        selectionChange=".onLinkageSelect"
        noDataText="{i18n>noLinkages}"
        busy="{lnk>/busy}">

        <columns>
          <Column><header><Text text="{i18n>id}" /></header></Column>
          <Column><header><Text text="{i18n>orderId}" /></header></Column>
          <Column><header><Text text="{i18n>contractId}" /></header></Column>
          <Column><header><Text text="{i18n>quantityMt}" /></header></Column>
          <Column><header><Text text="{i18n>createdAt}" /></header></Column>
        </columns>

        <items>
          <ColumnListItem type="Navigation">
            <Text text="{ path: 'lnk>id', formatter: 'formatter.shortUuid' }" />
            <Text text="{ path: 'lnk>order_id', formatter: 'formatter.shortUuid' }" />
            <Text text="{ path: 'lnk>contract_id', formatter: 'formatter.shortUuid' }" />
            <ObjectNumber number="{ path: 'lnk>quantity_mt', formatter: 'formatter.numberTwoDecimals' }" unit="MT" />
            <Text text="{ path: 'lnk>created_at', formatter: 'formatter.dateDisplay' }" />
          </ColumnListItem>
        </items>
      </Table>
    </f:content>

  </f:DynamicPage>
</mvc:View>
