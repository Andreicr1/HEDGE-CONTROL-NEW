<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form">
  <Dialog
    id="rfqCreateDialog"
    title="{i18n>newRfq}"
    contentWidth="40rem"
    draggable="true"
    resizable="true"
    stretch="{device>/system/phone}">
    <content>
      <VBox class="sapUiSmallMargin">
        <MessageStrip
          text="{rfqCrt>/errorMessage}"
          type="Error"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${rfqCrt>/errorMessage}}"
          class="sapUiSmallMarginBottom" />
        <form:Form id="rfqCreateForm" editable="true">
          <form:layout>
            <form:ColumnLayout columnsM="1" columnsL="2" columnsXL="2" />
          </form:layout>
          <form:formContainers>
            <form:FormContainer title="{i18n>sectionRfqInfo}">
              <form:formElements>
                <form:FormElement label="{i18n>colIntent}">
                  <form:fields>
                    <Select id="rfqCreateIntent" selectedKey="{rfqCrt>/form/intent}">
                      <core:Item key="COMMERCIAL_HEDGE" text="{i18n>optCommercialHedge}" />
                      <core:Item key="GLOBAL_POSITION" text="{i18n>optGlobalPosition}" />
                      <core:Item key="SPREAD" text="{i18n>optSpread}" />
                    </Select>
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colCommodity}">
                  <form:fields>
                    <Input id="rfqCreateCommodity" value="{rfqCrt>/form/commodity}" placeholder="{i18n>placeholderCommodity}" required="true" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colDirection}">
                  <form:fields>
                    <Select id="rfqCreateDirection" selectedKey="{rfqCrt>/form/direction}">
                      <core:Item key="BUY" text="{i18n>optBuy}" />
                      <core:Item key="SELL" text="{i18n>optSell}" />
                    </Select>
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colQuantityMt}">
                  <form:fields>
                    <Input id="rfqCreateQuantity" value="{rfqCrt>/form/quantity_mt}" type="Number" placeholder="0.00" required="true" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
            <form:FormContainer title="{i18n>sectionDeliveryWindow}">
              <form:formElements>
                <form:FormElement label="{i18n>colDeliveryStart}">
                  <form:fields>
                    <DatePicker id="rfqCreateDeliveryStart" value="{rfqCrt>/form/delivery_window_start}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" required="true" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colDeliveryEnd}">
                  <form:fields>
                    <DatePicker id="rfqCreateDeliveryEnd" value="{rfqCrt>/form/delivery_window_end}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" required="true" />
                  </form:fields>
                </form:FormElement>
                <form:FormElement label="{i18n>colOrderId}">
                  <form:fields>
                    <Input id="rfqCreateOrderId" value="{rfqCrt>/form/order_id}" placeholder="{i18n>optionalUuid}" />
                  </form:fields>
                </form:FormElement>
              </form:formElements>
            </form:FormContainer>
          </form:formContainers>
        </form:Form>
      </VBox>
    </content>
    <beginButton>
      <Button text="{i18n>submit}" type="Emphasized" press=".onSubmitRfq" />
    </beginButton>
    <buttons>
      <Button text="{i18n>previewText}" icon="sap-icon://document-text" press=".onPreviewRfqText" type="Ghost" />
    </buttons>
    <endButton>
      <Button text="{i18n>cancel}" press=".onCancelCreateRfq" />
    </endButton>
  </Dialog>
</core:FragmentDefinition>
