<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form">

  <Dialog id="rfqCreateDialog"
    title="{i18n>rfqCreateTitle}"
    contentWidth="480px"
    draggable="true"
    resizable="true">

    <content>
      <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="1" columnsL="1">

        <Label text="{i18n>colIntent}" required="true" />
        <Select selectedKey="{rfqCrt>/intent}">
          <core:Item key="SPREAD" text="{i18n>optSpread}" />
          <core:Item key="BUY" text="{i18n>optBuy}" />
          <core:Item key="SELL" text="{i18n>optSell}" />
        </Select>

        <Label text="{i18n>colCommodity}" required="true" />
        <Input value="{rfqCrt>/commodity}" placeholder="{i18n>placeholderCommodity}" />

        <Label text="{i18n>colDirection}" required="true" />
        <Select selectedKey="{rfqCrt>/direction}">
          <core:Item key="BUY" text="{i18n>buy}" />
          <core:Item key="SELL" text="{i18n>sell}" />
        </Select>

        <Label text="{i18n>colQuantityMt}" required="true" />
        <Input value="{rfqCrt>/quantity_mt}" type="Number" placeholder="0" />

        <Label text="{i18n>colDeliveryStart}" required="true" />
        <DatePicker value="{rfqCrt>/delivery_window_start}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" />

        <Label text="{i18n>colDeliveryEnd}" required="true" />
        <DatePicker value="{rfqCrt>/delivery_window_end}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" />

        <Label text="{i18n>colOrderId}" />
        <Input value="{rfqCrt>/order_id}" placeholder="{i18n>placeholderOrderId}" />

      </form:SimpleForm>
    </content>

    <beginButton>
      <Button text="{i18n>submit}" type="Emphasized" press=".onSubmitRfq" />
    </beginButton>
    <endButton>
      <Button text="{i18n>cancel}" press=".onCancelCreateRfq" />
    </endButton>

  </Dialog>

</core:FragmentDefinition>
